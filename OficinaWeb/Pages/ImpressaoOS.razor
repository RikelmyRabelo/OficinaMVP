@inject HttpClient Http
@using OficinaWeb.Models
@using System.Globalization

<style>
    .print-field {
        position: absolute;
        font-family: Arial, sans-serif;
        font-size: 10pt;
        color: black;
        white-space: nowrap;
        overflow: hidden;
        line-height: 1;
    }

    @@media screen {
        .d-print-block {
            display: none !important;
        }
    }
</style>

@if (Os != null)
{
    <div id="print-section" class="d-print-block" style="position: relative; width: 210mm; height: 297mm; background-color: white; margin: 0 auto;">
        <img src="images/OrdemServico.png" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; z-index: -1;" />

        @* CABEÇALHO *@
        <div class="print-field" style="top: 17.1%; left: 81.5%; font-size: 14pt; font-weight: bold;">#@Os.Id</div>
        <div class="print-field" style="top: 21.1%; left: 19.5%;">@Os.Vehicle?.CustomerName</div>
        @if (!string.IsNullOrEmpty(Os.Vehicle?.CustomerAddress))
        {
            <div class="print-field" style="top: 24.1%; left: 19.5%; font-size: 9pt;">@Os.Vehicle?.CustomerAddress</div>
        }
        <div class="print-field" style="top: 26.7%; left: 22%;">@Os.Vehicle?.Model</div>
        <div class="print-field" style="top: 34%; left: 30%;">@Os.EntryDate.ToString("dd/MM/yyyy")</div>

        @* SEÇÃO DE PEÇAS *@
        @{
            var pecas = Os.Items.Where(i => !IsService(i)).ToList();
            var slotsNoPapel = new ServiceItemDTO[7];

            foreach (var p in pecas.Where(x => x.PrintLine >= 1 && x.PrintLine <= 7))
                slotsNoPapel[p.PrintLine - 1] = p;

            var semPosicao = pecas.Where(x => x.PrintLine < 1 || x.PrintLine > 7).ToList();
            int pIndex = 0;
            for (int i = 0; i < 7; i++)
            {
                if (slotsNoPapel[i] == null && pIndex < semPosicao.Count)
                {
                    slotsNoPapel[i] = semPosicao[pIndex];
                    pIndex++;
                }
            }

            for (int i = 0; i < 7; i++)
            {
                var item = slotsNoPapel[i];
                if (item != null)
                {
                    string topCSS = CoordenadasSlots[i].ToString("0.00", CultureInfo.InvariantCulture);
                    string leftCodCSS = ColLeftCodigo.ToString("0.00", CultureInfo.InvariantCulture);
                    string leftDescCSS = ColLeftDescricao.ToString("0.00", CultureInfo.InvariantCulture);
                    string leftTotalCSS = ColLeftTotal.ToString("0.00", CultureInfo.InvariantCulture);

                    @* Coluna 1: CÓDIGO *@
                    <div class="print-field" style="top: @(topCSS)%; left: @(leftCodCSS)%; width: 55pt;">
                        @(item.Description.Contains(" - ") ? item.Description.Split(" - ")[0] : "AVULSO")
                    </div>

                    @* Coluna 2: PRODUTO / SERVIÇO *@
                    <div class="print-field" style="top: @(topCSS)%; left: @(leftDescCSS)%; width: 330pt; text-overflow: ellipsis;">
                        @(item.Quantity > 1 ? $"{item.Quantity}x " : "")
                        @(item.Description.Contains(" - ") ? item.Description.Split(" - ")[1] : item.Description)
                    </div>

                    @* Coluna 3: TOTAL *@
                    <div class="print-field" style="top: @(topCSS)%; left: @(leftTotalCSS)%; width: 100pt; text-align: right;">
                        R$ @item.Price.ToString("N2")
                    </div>
                }
            }
        }

        @* SEÇÃO DE MÃO DE OBRA *@
        <div class="print-field" style="top: 69.8%; left: 7.5%; width: 85%;">
            @foreach (var item in Os.Items.Where(i => IsService(i)))
            {
                <div style="position:relative; height: 14pt; margin-bottom: 2pt;">
                    <span style="position:absolute; left:0;"><strong>[M.O]</strong> @item.Description</span>
                    <span style="position:absolute; right:0;">R$ @item.Price.ToString("N2")</span>
                </div>
            }
        </div>

        @* TOTAIS *@
        <div class="print-field" style="top: 80.2%; left: 81%; font-size: 16pt; font-weight: bold;">R$ @Os.TotalAmount.ToString("N2")</div>
        <div class="print-field" style="top: 85.9%; left: 30%; font-size: 13pt; font-weight: bold;">R$ @Os.AmountPaid.ToString("N2")</div>
        <div class="print-field" style="top: 85.9%; left: 81%; font-size: 13pt; font-weight: bold;">R$ @Os.RemainingAmount.ToString("N2")</div>
    </div>
}

@code {
    [Parameter] public ServiceOrderDTO? Os { get; set; }
    private List<LaborServiceDTO>? catalogoServicos;

    private double[] CoordenadasSlots = new double[] {
        42, 45, 48, 51.5, 55, 58, 62
    };

    private double ColLeftCodigo = 8;
    private double ColLeftDescricao = 20;
    private double ColLeftTotal = 62;

    private bool IsService(ServiceItemDTO item)
    {
        return item.ItemType == "Service" ||
               (item.ProductId == null && item.Mechanic != null) ||
               (item.ProductId == null && (catalogoServicos?.Any(c => string.Equals(c.Name, item.Description, StringComparison.OrdinalIgnoreCase)) ?? false));
    }

    protected override async Task OnInitializedAsync()
    {
        try { catalogoServicos = await Http.GetFromJsonAsync<List<LaborServiceDTO>>("https://localhost:7082/api/laborservices"); }
        catch { }
    }
}