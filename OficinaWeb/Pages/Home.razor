@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>FREITAS AUTOCENTER - Início</PageTitle>

<div class="text-center mb-5">
    <h1 class="fw-bold display-4" style="color: #ff6600; text-transform: uppercase; letter-spacing: 2px;">
        FREITAS AUTOCENTER
    </h1>
    <p class="text-white-50">Período Ativo: <span class="text-white fw-bold">@MesNome(@activeMonth)/@activeYear</span></p>
</div>

@* Cards de Navegação Principal *@
<div class="row g-4 mb-5 justify-content-center">
    <div class="col-md-4">
        <a href="estoque" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-box-seam-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Estoque</h4>
                <small class="text-white-50 text-uppercase">Peças e Insumos</small>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="manutencao" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-wrench-adjustable fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Oficina</h4>
                <small class="text-white-50 text-uppercase">Ordens de Serviço</small>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="relatorios" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-graph-up-arrow fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Relatórios</h4>
                <small class="text-white-50 text-uppercase">Estatísticas e Histórico</small>
            </div>
        </a>
    </div>
</div>

<hr style="border-color: #333; margin: 3rem 0;" />

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-warning" role="status"></div>
        <p class="text-white-50 mt-2">Sincronizando período...</p>
    </div>
}
else
{
    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-sm btn-outline-secondary border-0 text-white-50" @onclick="async () => await AlternarVisibilidade()">
            <i class="bi @(ocultarValores ? "bi-eye-fill" : "bi-eye-slash-fill") me-1"></i>
            @(ocultarValores ? "Mostrar Resumo" : "Ocultar Resumo")
        </button>
    </div>

    <div class="row g-4 mb-5 align-items-stretch">
        <div class="col-md-4">
            <div class="p-4 rounded-3 border-start border-4 border-warning h-100" style="background: #0a0a0a;">
                <h6 class="text-white-50 text-uppercase small">Veículos no Período</h6>
                <h1 class="text-white display-5 fw-bold mb-0">@(ocultarValores ? "****" : osAbertas.ToString())</h1>
            </div>
        </div>

        <div class="col-md-4">
            <a href="estoque" class="text-decoration-none d-block h-100 nav-card">
                <div class="p-4 rounded-3 border-start border-4 border-danger h-100" style="background: #0a0a0a; border: 1px solid #dc3545;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 text-uppercase small">Alertas de Estoque</h6>
                            <h1 class="text-white display-5 fw-bold mb-0">@(ocultarValores ? "****" : estoqueBaixo.ToString()) <span class="fs-5 text-white-50">itens</span></h1>
                        </div>
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="faturamento" class="text-decoration-none d-block nav-card h-100 border-0">
                <div class="p-4 rounded-3 border-start border-4 border-success h-100" style="background: #0a0a0a; border: 1px solid #28a745;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-white-50 text-uppercase small">Faturamento Total</h6>
                            <h1 class="text-white display-5 fw-bold mb-0">@(ocultarValores ? "****" : faturamentoTotal.ToString("C2"))</h1>
                        </div>
                        <i class="bi bi-box-arrow-in-up-right text-success fs-3 opacity-50"></i>
                    </div>
                    <small class="text-success mt-2 d-block fw-bold small"><i class="bi bi-wallet2 me-1"></i>FECHAMENTO DE CAIXA</small>
                </div>
            </a>
        </div>
    </div>

    <div class="p-4 rounded-3 border border-secondary" style="background: #111;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div class="mb-3 mb-md-0 text-center text-md-start">
                <h4 class="fw-bold mb-1" style="color: #ff6600;">Gestão do Período Ativo</h4>
                <p class="text-white-50 small mb-0">Zere os indicadores e avance para o próximo mês.</p>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-danger fw-bold px-4" @onclick="FecharMesManual" disabled="@isBusy">
                    @if (isBusy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-calendar-check-fill me-2"></i>FECHAR MÊS
                </button>
                <button class="btn btn-outline-light fw-bold" @onclick="() => ProcessarAcao(true)" disabled="@isBusy">
                    <i class="bi bi-hdd-fill me-2"></i>Backup Sistema
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(feedbackMsg))
        {
            <div class="mt-3 alert @(opSucesso ? "alert-success" : "alert-danger") bg-dark border-0 text-white fade show d-flex align-items-center">
                <i class="bi @(opSucesso ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2 fs-5"></i>
                <div>@feedbackMsg</div>
            </div>
        }
    </div>
}

<style>
    .nav-card { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); cursor: pointer; }
    .nav-card:hover { transform: translateY(-8px); border-color: #ff6600 !important; background: #1a1a1a !important; box-shadow: 0 10px 20px rgba(255, 102, 0, 0.2) !important; }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";
    private bool isLoading = true, isBusy, opSucesso, ocultarValores;
    private int osAbertas, estoqueBaixo, activeMonth = 3, activeYear = 2026;
    private decimal faturamentoTotal;
    private string feedbackMsg = "";

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        try
        {
            isLoading = true;
            var settings = await Http.GetFromJsonAsync<JsonElement>($"{ApiUrl}/api/settings");
            activeMonth = settings.GetProperty("activeMonth").GetInt32();
            activeYear = settings.GetProperty("activeYear").GetInt32();

            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders");
            var prodList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/products");

            if (osList != null)
            {
                osAbertas = osList.Count(x => 
                    x.TryGetProperty("status", out var s) && s.ToString() == "Completed" &&
                    x.TryGetProperty("completionDate", out var d) && d.ValueKind != JsonValueKind.Null &&
                    d.GetDateTime().Month == activeMonth && d.GetDateTime().Year == activeYear);

                faturamentoTotal = osList
                    .Where(x => x.TryGetProperty("status", out var s) && s.ToString() == "Completed")
                    .Sum(x => x.TryGetProperty("amountPaid", out var t) ? t.GetDecimal() : 0);
            }

            if (prodList != null)
                estoqueBaixo = prodList.Count(x => x.GetProperty("stockQuantity").GetInt32() <= x.GetProperty("minimumStock").GetInt32());
        }
        catch { }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task FecharMesManual()
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Deseja encerrar o período de {MesNome(activeMonth)} e iniciar o próximo?");
        if (!confirm) return;

        isBusy = true;
        try {
            var res = await Http.PostAsync($"{ApiUrl}/api/settings/close-period", null);
            if (res.IsSuccessStatusCode) {
                opSucesso = true;
                feedbackMsg = "Período encerrado! Indicadores resetados para o novo mês.";
                await CarregarDados();
            }
        } catch { opSucesso = false; feedbackMsg = "Erro ao fechar período."; }
        finally { isBusy = false; }
    }

    private async Task ProcessarAcao(bool sistema) {}
    private async Task AlternarVisibilidade(){}
    private string MesNome(int m) => System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m).ToUpper();
}