@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config
@using System.Net.Http.Json
@using OficinaWeb.Models

<PageTitle>FREITAS AUTOCENTER - Início</PageTitle>

<div class="text-center mb-5">
    <div class="mb-3">
        <img src="Images/logo.png" alt="FREITAS AUTOCENTER" style="max-width: 300px; height: auto;" />
    </div>
    <p class="text-white-50">Ciclo de Trabalho Ativo: <span class="text-white fw-bold">@MesNome(activeMonth)/@activeYear</span></p>
</div>

@* Cards de Navegação Principal *@
<div class="row g-4 mb-5 justify-content-center">
    <div class="col-md-4">
        <a href="estoque" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-box-seam-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Estoque</h4>
                <small class="text-white-50 text-uppercase">Peças e Insumos</small>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="manutencao" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-wrench-adjustable fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Oficina</h4>
                <small class="text-white-50 text-uppercase">Ordens de Serviço</small>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="relatorios" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-pie-chart-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Dashboard</h4>
                <small class="text-white-50 text-uppercase">Estatísticas e Finanças</small>
            </div>
        </a>
    </div>
</div>

<hr style="border-color: #333; margin: 3rem 0;" />

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-warning" role="status"></div>
        <p class="text-white-50 mt-2">Sincronizando período contábil...</p>
    </div>
}
else
{
    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-sm btn-outline-secondary border-0 text-white-50" @onclick="AlternarVisibilidade">
            <i class="bi @(ocultarValores ? "bi-eye-fill" : "bi-eye-slash-fill") me-1"></i>
            @(ocultarValores ? "Mostrar Resumo" : "Ocultar Resumo")
        </button>
    </div>

    <div class="row g-4 mb-5 align-items-stretch">
        <div class="col-md-4">
            <div class="p-4 rounded-3 border-start border-4 border-warning h-100" style="background: #0a0a0a;">
                <h6 class="text-white-50 text-uppercase small">Veículos no Ciclo</h6>
                <h1 class="text-white display-5 fw-bold mb-0">@(ocultarValores ? "****" : veiculosNoCiclo.ToString())</h1>
                <small class="text-white-50">O.S. finalizadas no período</small>
            </div>
        </div>

        <div class="col-md-4">
            <a href="estoque" class="text-decoration-none d-block h-100 nav-card">
                <div class="p-4 rounded-3 border-start border-4 border-danger h-100" style="background: #0a0a0a; border: 1px solid #dc3545;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50 text-uppercase small">Alertas de Estoque</h6>
                            <h1 class="text-white display-5 fw-bold mb-0">@(ocultarValores ? "****" : estoqueBaixo.ToString()) <span class="fs-5 text-white-50">itens</span></h1>
                        </div>
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="relatorios" class="text-decoration-none d-block nav-card h-100 border-0">
                <div class="p-4 rounded-3 border-start border-4 border-success h-100" style="background: #0a0a0a; border: 1px solid #28a745;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-white-50 text-uppercase small">Faturamento Total</h6>
                            <h1 class="text-white display-5 fw-bold mb-0">@(ocultarValores ? "****" : faturamentoTotalGeral.ToString("C2"))</h1>
                        </div>
                        <i class="bi bi-cash-stack text-success fs-3 opacity-50"></i>
                    </div>
                    <small class="text-success mt-2 d-block fw-bold small text-uppercase"><i class="bi bi-arrow-right-circle me-1"></i>Ver Detalhes Financeiros</small>
                </div>
            </a>
        </div>
    </div>

    @* Painel de Gestão *@
    <div class="p-4 rounded-3 border border-secondary" style="background: #111;">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-3 mb-lg-0 text-center text-lg-start">
                <h4 class="fw-bold mb-1" style="color: #ff6600;">Gestão do Período Ativo</h4>
                <p class="text-white-50 small mb-0">Encerre o ciclo atual para resetar os indicadores e avançar.</p>
            </div>

            <div class="col-lg-7 text-center text-lg-end">
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-end">
                    <button class="btn btn-danger fw-bold px-4 shadow-sm" @onclick="FecharMesManual" disabled="@isBusy">
                        @if (isBusy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-calendar-check-fill me-2"></i>ENCERRAR MÊS
                    </button>

                    <button class="btn btn-outline-light fw-bold" @onclick="GerarBackup" disabled="@isBusy">
                        <i class="bi bi-hdd-fill me-2"></i>Backup
                    </button>

                    <button class="btn fw-bold text-white px-4" style="background: #217346;" @onclick="ExportarExcel" disabled="@isBusy">
                        <i class="bi bi-file-earmark-excel-fill me-2"></i>Excel
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(feedbackMsg))
        {
            <div class="mt-3 alert @(opSucesso ? "alert-success" : "alert-danger") bg-dark border-0 text-white fade show d-flex align-items-center">
                <i class="bi @(opSucesso ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2 fs-5"></i>
                <div>@feedbackMsg</div>
            </div>
        }
    </div>
}

<style>
    .nav-card { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); cursor: pointer; }
    .nav-card:hover { transform: translateY(-8px); border-color: #ff6600 !important; background: #1a1a1a !important; box-shadow: 0 10px 20px rgba(255, 102, 0, 0.2) !important; }
</style>

@code {
    private string ApiUrl = "";
    private bool isLoading = true, isBusy, opSucesso, ocultarValores;
    private int veiculosNoCiclo, estoqueBaixo, activeMonth, activeYear;
    private decimal faturamentoTotalGeral;
    private string feedbackMsg = "";

    protected override async Task OnInitializedAsync()
    {
        ApiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7082";
        await CarregarDados();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var pref = await JS.InvokeAsync<string>("localStorage.getItem", "ocultarValoresHome");
                if (!string.IsNullOrEmpty(pref))
                {
                    ocultarValores = bool.Parse(pref);
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task CarregarDados()
    {
        try
        {
            isLoading = true;
            
            // Busca configurações do sistema (Mês e Ano ativos)
            var settings = await Http.GetFromJsonAsync<SystemSettingsDTO>($"{ApiUrl}/api/settings");
            
            // Correção: Tratamento de nulos para converter de int? (do DTO) para int (variável local)
            activeMonth = settings?.ActiveMonth ?? DateTime.Now.Month;
            activeYear = settings?.ActiveYear ?? DateTime.Now.Year;

            // Busca O.S. filtradas pelo período ativo
            var osListPorPeriodo = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/periodo?mes={activeMonth}&ano={activeYear}");
            
            // Busca todas as O.S. finalizadas para o faturamento total acumulado
            var osListAllCompleted = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/completed?take=1000");
            
            // Busca lista de produtos para verificar alertas de estoque
            var prodList = await Http.GetFromJsonAsync<List<ProductDTO>>($"{ApiUrl}/api/products");

            // Atribuição dos indicadores
            faturamentoTotalGeral = osListAllCompleted?.Sum(x => x.AmountPaid) ?? 0;
            veiculosNoCiclo = osListPorPeriodo?.Count(x => x.Status == "Completed") ?? 0;
            
            // Correção: Verificação de estoque baixo tratando o StockQuantity nulo
            estoqueBaixo = prodList?.Count(x => (x.StockQuantity ?? 0) <= x.MinimumStock) ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro no carregamento Home: {ex.Message}");
        }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task FecharMesManual()
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Encerrar o ciclo de {MesNome(activeMonth)} e abrir o próximo?");
        if (!confirm) return;

        isBusy = true;
        try {
            var res = await Http.PostAsync($"{ApiUrl}/api/settings/close-period", null);
            if (res.IsSuccessStatusCode) {
                opSucesso = true;
                feedbackMsg = "Ciclo atualizado com sucesso!";
                await CarregarDados();
            }
        } catch { opSucesso = false; feedbackMsg = "Erro ao fechar período."; }
        finally { isBusy = false; StateHasChanged(); }
    }

    private async Task GerarBackup() => await ExecutarAcao("api/backup/gerar", "Backup concluído!");
    private async Task ExportarExcel() => await ExecutarAcao("api/backup/exportar-excel", "Excel exportado!");

    private async Task ExecutarAcao(string rota, string msgSucesso)
    {
        isBusy = true;
        try {
            var res = await Http.PostAsync($"{ApiUrl}/{rota}", null);
            opSucesso = res.IsSuccessStatusCode;
            feedbackMsg = opSucesso ? msgSucesso : "Falha na operação.";
        } catch { opSucesso = false; feedbackMsg = "Erro de conexão."; }
        finally { isBusy = false; StateHasChanged(); }
    }

    private async Task AlternarVisibilidade()
    {
        ocultarValores = !ocultarValores;
        await JS.InvokeVoidAsync("localStorage.setItem", "ocultarValoresHome", ocultarValores.ToString());
    }

    private string MesNome(int m) => System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m > 0 && m <= 12 ? m : 1).ToUpper();
}