@page "/"
@inject HttpClient Http
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>FJ Centro Automotivo</PageTitle>

<div class="text-center mb-5">
    <h1 class="fw-bold display-4" style="color: #ff6600; text-transform: uppercase; letter-spacing: 2px;">
        FJ CENTRO AUTOMOTIVO
    </h1>
</div>

<div class="row g-4 mb-5 justify-content-center">

    <div class="col-md-3">
        <a href="estoque" class="card text-decoration-none h-100 border-0 shadow"
           style="background: #111; border: 1px solid #333; transition: 0.3s;">
            <div class="card-body text-center py-4 nav-card">
                <i class="bi bi-box-seam-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Estoque</h4>
                <small class="text-white">Gerenciar Peças</small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a href="rh" class="card text-decoration-none h-100 border-0 shadow"
           style="background: #111; border: 1px solid #333; transition: 0.3s;">
            <div class="card-body text-center py-4 nav-card">
                <i class="bi bi-people-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">RH e Pagamentos</h4>
                <small class="text-white">Funcionários e Salários</small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a href="manutencao" class="card text-decoration-none h-100 border-0 shadow"
           style="background: #111; border: 1px solid #333; transition: 0.3s;">
            <div class="card-body text-center py-4 nav-card">
                <i class="bi bi-wrench-adjustable fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Oficina</h4>
                <small class="text-white">Ordens de Serviço</small>
            </div>
        </a>
    </div>
</div>

<hr style="border-color: #333; margin-bottom: 3rem;" />

<h3 class="mb-4 fw-bold" style="color: #ff6600;">
    <i class="bi bi-activity me-2"></i>Resumo da Operação
</h3>

@if (isLoading)
{
    <div class="text-center text-white">Carregando dados...</div>
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <div class="p-4 rounded-3" style="background-color: #0a0a0a; border-left: 5px solid #ff6600;">
                <h6 class="text-white text-uppercase">Veículos na Oficina</h6>
                <h1 class="text-white display-5 fw-bold">@osAbertas</h1>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-3" style="background-color: #0a0a0a; border-left: 5px solid #dc3545;">
                <h6 class="text-white text-uppercase">Estoque Crítico</h6>
                <h1 class="text-white display-5 fw-bold">@estoqueBaixo <span class="fs-6 text-white">itens</span></h1>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-3" style="background-color: #0a0a0a; border-left: 5px solid #198754;">
                <h6 class="text-white text-uppercase">Faturamento Total</h6>
                <h1 class="text-white display-5 fw-bold">@faturamento.ToString("C2")</h1>
            </div>
        </div>
    </div>
}

<style>
    .nav-card:hover {
        background-color: #1a1a1a;
        transform: translateY(-5px);
        border-color: #ff6600;
    }
</style>

@code {
    private string ApiUrl = "https://localhost:7082"; // CONFIRA SUA PORTA

    bool isLoading = true;
    int osAbertas = 0;
    int estoqueBaixo = 0;
    decimal faturamento = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders");
            var prodList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/products");

            if (osList != null)
            {
                osAbertas = osList.Count(x => x.GetProperty("status").ToString() != "Completed");
                foreach (var os in osList.Where(x => x.GetProperty("status").ToString() == "Completed"))
                {
                    if (os.TryGetProperty("totalAmount", out var val) && val.ValueKind == JsonValueKind.Number)
                        faturamento += val.GetDecimal();
                }
            }
            if (prodList != null) estoqueBaixo = prodList.Count(x => x.GetProperty("stockQuantity").GetInt32() <= 5);
        }
        catch { }
        finally { isLoading = false; }
    }
}