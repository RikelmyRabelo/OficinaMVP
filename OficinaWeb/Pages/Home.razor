@page "/"
@inject HttpClient Http
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>FJ Centro Automotivo - Início</PageTitle>

<div class="text-center mb-5">
    <h1 class="fw-bold display-4" style="color: #ff6600; text-transform: uppercase; letter-spacing: 2px;">
        FJ CENTRO AUTOMOTIVO
    </h1>
    <p class="text-white-50">Gestão Profissional de Oficina</p>
</div>

@* Cards de Navegação Principal *@
<div class="row g-4 mb-5 justify-content-center">
    <div class="col-md-3">
        <a href="estoque" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-box-seam-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Estoque</h4>
                <small class="text-white-50">Peças e Insumos</small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a href="rh" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-people-fill fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Equipe</h4>
                <small class="text-white-50">RH e Pagamentos</small>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a href="manutencao" class="card text-decoration-none h-100 border-0 shadow-lg nav-card" style="background: #111; border: 1px solid #333;">
            <div class="card-body text-center py-4">
                <i class="bi bi-wrench-adjustable fs-1 mb-3 d-block text-white"></i>
                <h4 class="fw-bold" style="color: #ff6600;">Oficina</h4>
                <small class="text-white-50">Ordens de Serviço</small>
            </div>
        </a>
    </div>
</div>

<hr style="border-color: #333; margin: 3rem 0;" />

@* Seção de Resumo e Segurança *@
@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-warning" role="status"></div>
    </div>
}
else
{
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="p-4 rounded-3 border-start border-4 border-warning" style="background: #0a0a0a;">
                <h6 class="text-white-50 text-uppercase small">Veículos em Reparo</h6>
                <h1 class="text-white display-5 fw-bold">@osAbertas</h1>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-3 border-start border-4 border-danger" style="background: #0a0a0a;">
                <h6 class="text-white-50 text-uppercase small">Alertas de Estoque</h6>
                <h1 class="text-white display-5 fw-bold">@estoqueBaixo <span class="fs-5 text-white-50">itens</span></h1>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-3 border-start border-4 border-success" style="background: #0a0a0a;">
                <h6 class="text-white-50 text-uppercase small">Faturamento Concluído</h6>
                <h1 class="text-white display-5 fw-bold">@faturamento.ToString("C2")</h1>
            </div>
        </div>
    </div>

    @* Painel de Backup *@
    <div class="p-4 rounded-3 border border-secondary" style="background: #111;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div class="mb-3 mb-md-0">
                <h4 class="fw-bold mb-1" style="color: #ff6600;">Backup Diário Inteligente</h4>
                <p class="text-white-50 small mb-0">Os arquivos serão salvos em: <code class="text-light">D:\Backups_Oficina\@DateTime.Now.ToString("dd-MM-yyyy")\</code></p>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-light fw-bold" @onclick="() => ProcessarAcao(true)" disabled="@isBusy">
                    <i class="bi bi-hdd-fill me-2"></i>Backup Sistema
                </button>
                <button class="btn fw-bold text-white px-4" style="background: #217346;" @onclick="() => ProcessarAcao(false)" disabled="@isBusy">
                    @if (isBusy && !isBackupSistema)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-file-earmark-excel-fill me-2"></i>Exportar Excel
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(feedbackMsg))
        {
            <div class="mt-3 alert @(opSucesso ? "alert-success" : "alert-danger") bg-dark border-0 text-white fade show">
                <i class="bi @(opSucesso ? "bi-check-circle" : "bi-x-circle") me-2"></i> @feedbackMsg
            </div>
        }
    </div>
}

<style>
    .nav-card {
        transition: all 0.3s;
        cursor: pointer;
    }

        .nav-card:hover {
            transform: translateY(-8px);
            border-color: #ff6600 !important;
            background: #1a1a1a !important;
        }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";
    private bool isLoading = true;
    private int osAbertas, estoqueBaixo;
    private decimal faturamento;

    private bool isBusy, isBackupSistema, opSucesso;
    private string feedbackMsg = "";

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        try
        {
            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders");
            var prodList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/products");

            if (osList != null)
            {
                osAbertas = osList.Count(x => x.GetProperty("status").ToString() != "Completed");
                faturamento = osList.Where(x => x.GetProperty("status").ToString() == "Completed")
                                    .Sum(x => x.GetProperty("totalAmount").GetDecimal());
            }
            if (prodList != null)
                estoqueBaixo = prodList.Count(x => x.GetProperty("stockQuantity").GetInt32() <= x.GetProperty("minimumStock").GetInt32());
        }
        catch { }
        finally { isLoading = false; }
    }

    private async Task ProcessarAcao(bool sistema)
    {
        isBusy = true; isBackupSistema = sistema; feedbackMsg = "Aguarde, processando...";
        string rota = sistema ? "api/backup/gerar" : "api/backup/exportar-excel";

        try
        {
            var res = await Http.PostAsync($"{ApiUrl}/{rota}", null);
            opSucesso = res.IsSuccessStatusCode;
            feedbackMsg = opSucesso ? (sistema ? "Backup de segurança salvo!" : "Planilha Excel organizada com sucesso!") : "Erro ao gerar arquivo.";
        }
        catch (Exception ex) { opSucesso = false; feedbackMsg = "Erro: " + ex.Message; }
        finally { isBusy = false; }
    }
}