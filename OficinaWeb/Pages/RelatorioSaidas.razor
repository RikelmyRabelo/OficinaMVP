@page "/relatorio-saidas"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using OficinaWeb.Models

<div class="container mt-4 no-print">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <h2 class="fw-bold text-uppercase m-0" style="color: #00ffff;">
            <i class="bi bi-graph-up-arrow me-2"></i>Relatório Geral de Saídas
        </h2>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary border-0 text-white me-2" @onclick='() => Nav.NavigateTo("manutencao")'>
                <i class="bi bi-arrow-left me-1"></i>Voltar
            </button>

            <button class="btn btn-outline-warning fw-bold shadow-sm" @onclick="ImprimirEstoque"
                    disabled="@(isLoading || !itensVendidos.Any(i => !i.IsAvulso))">
                <i class="bi bi-upc-scan me-1"></i>PDF ESTOQUE
            </button>

            <button class="btn btn-outline-info fw-bold shadow-sm" @onclick="ImprimirAvulsos"
                    disabled="@(isLoading || !itensVendidos.Any(i => i.IsAvulso))">
                <i class="bi bi-tag-fill me-1"></i>PDF AVULSOS
            </button>

            <button class="btn btn-info fw-bold shadow-sm" @onclick="ImprimirGeral"
                    disabled="@(isLoading || !itensVendidos.Any())">
                <i class="bi bi-printer-fill me-1"></i>GERAR PDF GERAL
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" role="status"></div>
            <p class="text-white-50 mt-2">Calculando patrimônio e consolidando peças...</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="background: #111; border-left: 4px solid #ffeb3b !important;">
                    <div class="card-body">
                        <small class="text-white-50 text-uppercase fw-bold" style="font-size: 0.7rem;">Valor em Estoque (Atual)</small>
                        <h3 class="text-white fw-bold m-0">R$ @valorTotalEstoque.ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="background: #111; border-left: 4px solid #00ffff !important;">
                    <div class="card-body">
                        <small class="text-white-50 text-uppercase fw-bold" style="font-size: 0.7rem;">Total Vendido (Cadastrados)</small>
                        <h3 class="text-white fw-bold m-0">R$ @valorTotalSaidasEstoque.ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm" style="background: #000; border: 1px solid #222; border-left: 4px solid #4caf50 !important;">
                    <div class="card-body">
                        <small class="text-success text-uppercase fw-bold" style="font-size: 0.7rem;">Patrimônio Total (Código)</small>
                        <h3 class="text-success fw-bold m-0">R$ @((valorTotalEstoque + valorTotalSaidasEstoque).ToString("N2"))</h3>
                    </div>
                </div>
            </div>
        </div>

        @if (!itensVendidos.Any())
        {
            <div class="alert alert-dark text-center border-secondary text-white-50">
                Nenhuma peça ou insumo encontrado no histórico de Ordens de Serviço.
            </div>
        }
        else
        {
            <div class="card border-0 shadow-lg" style="background: #111; border-top: 4px solid #00ffff !important;">
                <div class="card-body p-0">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr class="text-white-50 border-secondary">
                                <th class="ps-4">Item (Peças e Insumos)</th>
                                <th class="text-center">Origem</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-end">Vlr. Unitário</th>
                                <th class="text-end pe-4">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itensVendidos)
                            {
                                <tr class="border-secondary">
                                    <td class="ps-4">
                                        <div class="fw-bold text-white">@item.Description</div>
                                        <small class="text-white-50">Ref. OS: #@item.ServiceOrderId</small>
                                    </td>
                                    <td class="text-center">
                                        @if (item.IsAvulso)
                                        {
                                            <span class="badge bg-secondary text-uppercase" style="font-size: 0.65rem; border-radius: 50px;">Avulso</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark text-uppercase" style="font-size: 0.65rem; border-radius: 50px;">Estoque</span>
                                        }
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end text-white-50">R$ @item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end pe-4 fw-bold text-info">R$ @item.SubtotalManual.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="bg-dark border-top border-info">
                                <td colspan="4" class="text-end py-3 fw-bold text-white">VALOR TOTAL DAS SAÍDAS (GERAL):</td>
                                <td class="text-end pe-4 py-3 fw-bold text-warning fs-5">R$ @TotalGeral.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
    }
</div>

@* ÁREA DE IMPRESSÃO  *@
<div id="print-section" class="d-none d-print-block" style="width: 210mm; background-color: white; color: black !important; padding: 15mm; font-family: Arial, sans-serif;">
    <div style="border-bottom: 2px solid black; padding-bottom: 10px; margin-bottom: 20px; text-align: center;">
        <h1 style="margin: 0; font-size: 20pt;">FREITAS AUTOCENTER</h1>
        <h3 style="margin: 5px 0; color: #333; text-transform: uppercase;">@tituloRelatorio</h3>
        <p style="font-size: 9pt;">Gerado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    <table style="width: 100%; border-collapse: collapse; font-size: 10pt; color: black !important;">
        <thead>
            <tr style="background-color: #eee; border-top: 2px solid black; border-bottom: 2px solid black;">
                <th style="padding: 8px; text-align: left; border-bottom: 1px solid black;">DESCRIÇÃO DO ITEM</th>
                <th style="padding: 8px; text-align: center; border-bottom: 1px solid black;">ORIGEM</th>
                <th style="padding: 8px; text-align: center; border-bottom: 1px solid black;">QTD</th>
                <th style="padding: 8px; text-align: right; border-bottom: 1px solid black;">UNITÁRIO</th>
                <th style="padding: 8px; text-align: right; border-bottom: 1px solid black;">SUBTOTAL</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in itensParaImprimir)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 8px;">
                        <span style="font-weight: bold;">@item.Description</span><br />
                        <small style="color: #666;">OS: #@item.ServiceOrderId</small>
                    </td>
                    <td style="padding: 8px; text-align: center;">@(item.IsAvulso ? "Avulso" : "Sistema")</td>
                    <td style="padding: 8px; text-align: center;">@item.Quantity</td>
                    <td style="padding: 8px; text-align: right;">R$ @item.UnitPrice.ToString("N2")</td>
                    <td style="padding: 8px; text-align: right; font-weight: bold;">R$ @item.SubtotalManual.ToString("N2")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr style="border-top: 2px solid black; background-color: #f9f9f9;">
                <td colspan="4" style="padding: 15px; text-align: right; font-weight: bold; font-size: 11pt;">VALOR TOTAL:</td>
                <td style="padding: 15px; text-align: right; font-weight: bold; font-size: 11pt;">R$ @itensParaImprimir.Sum(i => i.SubtotalManual).ToString("N2")</td>
            </tr>
        </tfoot>
    </table>
</div>

<style>
    @@media print {
        .sidebar, .top-row, .no-print, nav, header {
            display: none !important;
        }

        .main, .content, .container-fluid {
            padding: 0 !important;
            margin: 0 !important;
        }

        .d-print-block {
            display: block !important;
        }

        body {
            background: white !important;
        }
    }
</style>

@code {
    public class VendidoDTO
    {
        public int ServiceOrderId { get; set; }
        public string Description { get; set; } = "";
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
        public decimal SubtotalManual { get; set; }
        public bool IsAvulso { get; set; }
        public string Type { get; set; } = "";
        public int? MechanicId { get; set; }
    }

    private List<VendidoDTO> itensVendidos = new();
    private List<VendidoDTO> itensParaImprimir = new();
    private string tituloRelatorio = "";
    private bool isLoading = true;
    private decimal TotalGeral => itensVendidos.Sum(i => i.SubtotalManual);

    private decimal valorTotalEstoque = 0;
    private decimal valorTotalSaidasEstoque => itensVendidos.Where(i => !i.IsAvulso).Sum(i => i.SubtotalManual);

    protected override async Task OnInitializedAsync() => await CarregarDadosConsolidados();

    private async Task CarregarDadosConsolidados()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            // 1. Buscar valor total do que está no estoque
            var listaProdutos = await Http.GetFromJsonAsync<List<ProductListDTO>>("https://localhost:7082/api/products");
            if (listaProdutos != null)
            {
                valorTotalEstoque = listaProdutos.Sum(p => p.salePrice * p.stockQuantity);
            }

            // 2. Buscar saídas
            var todasOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>("https://localhost:7082/api/serviceorders");

            if (todasOS != null)
            {
                itensVendidos = todasOS
                    .SelectMany(os => os.Items.Select(item => new VendidoDTO
                    {
                        ServiceOrderId = os.Id,
                        Description = item.Description,
                        UnitPrice = item.Quantity > 0 ? (item.Price / item.Quantity) : item.Price,
                        Quantity = item.Quantity,
                        SubtotalManual = item.Price,
                        IsAvulso = item.ProductId == null,
                        Type = item.ItemType ?? "",
                        MechanicId = item.MechanicId
                    }))
                    .Where(i =>
                        !i.Type.Contains("Service", StringComparison.OrdinalIgnoreCase) &&
                        !i.Type.Contains("Serviço", StringComparison.OrdinalIgnoreCase) &&
                        !i.Type.Contains("Mão de Obra", StringComparison.OrdinalIgnoreCase) &&
                        !i.Description.Contains("(M.O)", StringComparison.OrdinalIgnoreCase) &&
                        !i.Description.Contains("M.O", StringComparison.OrdinalIgnoreCase) &&
                        i.MechanicId == null
                    )
                    .OrderByDescending(i => i.ServiceOrderId).ToList();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Erro: {ex.Message}"); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task ImprimirGeral()
    {
        tituloRelatorio = "Relatório Consolidado de Saída de Materiais";
        itensParaImprimir = itensVendidos;
        StateHasChanged();
        await Task.Delay(150);
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ImprimirAvulsos()
    {
        tituloRelatorio = "Relatório de Saída - Itens Avulsos";
        itensParaImprimir = itensVendidos.Where(i => i.IsAvulso).ToList();
        StateHasChanged();
        await Task.Delay(150);
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ImprimirEstoque()
    {
        tituloRelatorio = "Relatório de Saída - Itens de Estoque";
        itensParaImprimir = itensVendidos.Where(i => !i.IsAvulso).ToList();
        StateHasChanged();
        await Task.Delay(150);
        await JS.InvokeVoidAsync("window.print");
    }
}