@page "/relatorio-saidas"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using OficinaWeb.Models

<PageTitle>Relatório de Saídas - FREITAS AUTOCENTER</PageTitle>

<div class="container mt-4 no-print">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <h2 class="fw-bold text-uppercase m-0" style="color: #00ffff;">
            <i class="bi bi-graph-up-arrow me-2"></i>Relatório Geral de Saídas
        </h2>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary border-0 text-white me-2" @onclick='() => Nav.NavigateTo("manutencao")'>
                <i class="bi bi-arrow-left me-1"></i>Voltar
            </button>

            <button class="btn btn-outline-warning fw-bold shadow-sm" @onclick="ImprimirEstoque" disabled="@(isLoading || !TemItensEstoque)">
                <i class="bi bi-upc-scan me-1"></i>PDF ESTOQUE
            </button>

            <button class="btn btn-outline-info fw-bold shadow-sm" @onclick="ImprimirAvulsos" disabled="@(isLoading || !TemItensAvulsos)">
                <i class="bi bi-tag-fill me-1"></i>PDF AVULSOS
            </button>

            <button class="btn btn-info fw-bold shadow-sm" @onclick="ImprimirGeral" disabled="@(isLoading || !TemItensVendidos)">
                <i class="bi bi-printer-fill me-1"></i>GERAR PDF GERAL
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" role="status"></div>
            <p class="text-white-50 mt-2">Calculando patrimônio e consolidando peças...</p>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm card-resumo border-amarelo">
                    <div class="card-body">
                        <small class="label-resumo">Valor em Estoque (Atual)</small>
                        <h3 class="valor-resumo">R$ @valorTotalEstoque.ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm card-resumo border-ciano">
                    <div class="card-body">
                        <small class="label-resumo">Total Vendido (Cadastrados)</small>
                        <h3 class="valor-resumo">R$ @ValorTotalSaidasEstoque.ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm card-resumo border-verde patrimonio-box">
                    <div class="card-body">
                        <small class="label-resumo text-success">Patrimônio Total (Código)</small>
                        <h3 class="valor-resumo text-success">R$ @PatrimonioTotal.ToString("N2")</h3>
                    </div>
                </div>
            </div>
        </div>

        @if (!TemItensVendidos)
        {
            <div class="alert alert-dark text-center border-secondary text-white-50">
                Nenhuma peça ou insumo encontrado no histórico de Ordens de Serviço.
            </div>
        }
        else
        {
            <div class="card border-0 shadow-lg tab-container">
                <div class="card-body p-0">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr class="text-white-50 border-secondary">
                                <th class="ps-4">Item (Peças e Insumos)</th>
                                <th class="text-center">Origem</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-end">Vlr. Unitário</th>
                                <th class="text-end pe-4">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itensVendidos)
                            {
                                <tr class="border-secondary">
                                    <td class="ps-4">
                                        <div class="fw-bold text-white">@item.Description</div>
                                        <small class="text-white-50">Ref. OS: #@item.ServiceOrderId</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(item.IsAvulso ? "bg-secondary" : "bg-info text-dark") badge-origem">
                                            @(item.IsAvulso ? "Avulso" : "Estoque")
                                        </span>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end text-white-50">R$ @item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end pe-4 fw-bold text-info">R$ @item.SubtotalManual.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="bg-dark border-top border-info">
                                <td colspan="4" class="text-end py-3 fw-bold text-white">VALOR TOTAL DAS SAÍDAS (GERAL):</td>
                                <td class="text-end pe-4 py-3 fw-bold text-warning fs-5">R$ @TotalGeral.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
    }
</div>

<RelatorioImpressao Titulo="@tituloRelatorio" Itens="itensParaImprimir" Total="ValorTotalImpressao" />

<style>
    .card-resumo { background: #111; }
    .border-amarelo { border-left: 4px solid #ffeb3b !important; }
    .border-ciano { border-left: 4px solid #00ffff !important; }
    .border-verde { border-left: 4px solid #4caf50 !important; }
    .patrimonio-box { background: #000; border: 1px solid #222; }
    .label-resumo { font-size: 0.7rem; text-transform: uppercase; font-weight: bold; color: rgba(255,255,255,0.5); }
    .valor-resumo { font-weight: bold; margin: 0; color: white; }
    .tab-container { background: #111; border-top: 4px solid #00ffff !important; }
    .badge-origem { font-size: 0.65rem; border-radius: 50px; text-transform: uppercase; }

    @@media print {
        .no-print { display: none !important; }
        .d-print-block { display: block !important; }
        body { background: white !important; }
    }
</style>

@code {
    public class VendidoDTO
    {
        public int ServiceOrderId { get; set; }
        public string Description { get; set; } = "";
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
        public decimal SubtotalManual { get; set; }
        public bool IsAvulso { get; set; }
        public string Type { get; set; } = "";
        public int? MechanicId { get; set; }
    }

    private List<VendidoDTO> itensVendidos = new();
    private List<VendidoDTO> itensParaImprimir = new();
    private string tituloRelatorio = "";
    private bool isLoading = true;
    private decimal valorTotalEstoque = 0;

    private decimal TotalGeral => itensVendidos.Sum(i => i.SubtotalManual);
    private decimal ValorTotalSaidasEstoque => itensVendidos.Where(i => !i.IsAvulso).Sum(i => i.SubtotalManual);
    private decimal PatrimonioTotal => valorTotalEstoque + ValorTotalSaidasEstoque;
    private decimal ValorTotalImpressao => itensParaImprimir.Sum(i => i.SubtotalManual);
    
    private bool TemItensVendidos => itensVendidos.Any();
    private bool TemItensEstoque => itensVendidos.Any(i => !i.IsAvulso);
    private bool TemItensAvulsos => itensVendidos.Any(i => i.IsAvulso);

    protected override async Task OnInitializedAsync() => await CarregarDadosConsolidados();

    private async Task CarregarDadosConsolidados()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var listaProdutos = await Http.GetFromJsonAsync<List<ProductListDTO>>("https://localhost:7082/api/products");
            if (listaProdutos != null) valorTotalEstoque = listaProdutos.Sum(p => p.salePrice * p.stockQuantity);

            var todasOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>("https://localhost:7082/api/serviceorders");
            if (todasOS != null)
            {
                itensVendidos = todasOS
                    .SelectMany(os => os.Items.Select(item => new VendidoDTO
                    {
                        ServiceOrderId = os.Id,
                        Description = item.Description,
                        UnitPrice = item.Quantity > 0 ? (item.Price / item.Quantity) : item.Price,
                        Quantity = item.Quantity,
                        SubtotalManual = item.Price,
                        IsAvulso = item.ProductId == null,
                        Type = item.ItemType ?? "",
                        MechanicId = item.MechanicId
                    }))
                    .Where(i => !i.Type.Contains("Service", StringComparison.OrdinalIgnoreCase) && 
                                !i.Type.Contains("Serviço", StringComparison.OrdinalIgnoreCase) &&
                                i.MechanicId == null)
                    .OrderByDescending(i => i.ServiceOrderId).ToList();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Erro: {ex.Message}"); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task DispararImpressao(string titulo, List<VendidoDTO> itens)
    {
        tituloRelatorio = titulo;
        itensParaImprimir = itens;
        StateHasChanged();
        await Task.Delay(150);
        await JS.InvokeVoidAsync("window.print");
    }

    private Task ImprimirGeral() => DispararImpressao("Relatório Consolidado de Saída de Materiais", itensVendidos);
    private Task ImprimirAvulsos() => DispararImpressao("Relatório de Saída - Itens Avulsos", itensVendidos.Where(i => i.IsAvulso).ToList());
    private Task ImprimirEstoque() => DispararImpressao("Relatório de Saída - Itens de Estoque", itensVendidos.Where(i => !i.IsAvulso).ToList());
}