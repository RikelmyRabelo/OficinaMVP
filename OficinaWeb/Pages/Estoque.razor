@page "/estoque"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Catálogo & Estoque - FREITAS AUTOCENTER</PageTitle>

<div class="toast-container position-fixed bottom-0 end-0 p-3 no-print" style="z-index: 1100;">
    @if (mostrarToast)
    {
        <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                    @toastMensagem
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
            </div>
        </div>
    }
</div>

@if (mostrarModalExclusao)
{
    <div class="modal fade show d-block no-print" style="background-color: rgba(0,0,0,0.8); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold text-danger"><i class="bi bi-trash-fill me-2"></i>Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalExclusao = false"></button>
                </div>
                <div class="modal-body">
                    <p>Deseja remover <strong>@produtoParaExcluir?.name</strong> do catálogo?</p>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" @onclick="() => mostrarModalExclusao = false">Cancelar</button>
                    <button type="button" class="btn btn-danger fw-bold" @onclick="ConfirmarExclusao">EXCLUIR</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="container py-4 no-print">

    <div class="row align-items-center mb-4 position-relative">
        <div class="col-md-2">
            <a href="/" class="btn btn-outline-secondary border-0 text-white">
                <i class="bi bi-arrow-left me-2"></i>Painel
            </a>
        </div>
        <div class="col-md-5 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;">
                <i class="bi bi-box-seam-fill me-2"></i>Gerenciamento
            </h2>
        </div>
        <div class="col-md-5 text-end d-flex gap-2 justify-content-end">
            <button class="btn btn-warning fw-bold shadow-sm" @onclick='() => Nav.NavigateTo("lista-compras")'>
                <i class="bi bi-cart-check-fill me-1"></i>
                LISTA DE COMPRAS
            </button>

            <button class="btn btn-light fw-bold shadow-sm" @onclick="ImprimirRelatorio">
                <i class="bi bi-file-pdf-fill text-danger me-2"></i>
                @(abaAtiva == "pecas" ? "PDF ESTOQUE" : "PDF MÃO DE OBRA")
            </button>
        </div>
    </div>

    <ul class="nav nav-pills nav-fill mb-4 p-1 bg-black rounded border border-secondary">
        <li class="nav-item">
            <button class="nav-link @(abaAtiva == "pecas" ? "active bg-warning text-dark fw-bold" : "text-white")" @onclick='() => abaAtiva = "pecas"'>
                <i class="bi bi-tools me-2"></i>PEÇAS EM ESTOQUE
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(abaAtiva == "servicos" ? "active bg-warning text-dark fw-bold" : "text-white")" @onclick='() => abaAtiva = "servicos"'>
                <i class="bi bi-person-gear me-2"></i>CATÁLOGO DE MÃO DE OBRA
            </button>
        </li>
    </ul>

    @if (abaAtiva == "pecas")
    {
        @if (valoresHistoricos != null)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card bg-dark border-secondary text-white shadow-sm h-100">
                        <div class="card-body p-3 text-center">
                            <small class="text-secondary fw-bold text-uppercase d-block mb-1">Valor em Prateleira (Atual)</small>
                            <h4 class="fw-bold text-success mb-0">R$ @valoresHistoricos.currentInventoryValue.ToString("N2")</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark border-secondary text-white shadow-sm h-100">
                        <div class="card-body p-3 text-center">
                            <small class="text-secondary fw-bold text-uppercase d-block mb-1">Total Saídas (O.S.)</small>
                            <h4 class="fw-bold text-info mb-0">R$ @valoresHistoricos.totalExitedValue.ToString("N2")</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark border-secondary text-white shadow-sm h-100" style="border-left: 4px solid #ff6600 !important;">
                        <div class="card-body p-3 text-center">
                            <small class="text-warning fw-bold text-uppercase d-block mb-1">Patrimônio Total Histórico</small>
                            <h4 class="fw-bold text-white mb-0">R$ @valoresHistoricos.totalHistoricalValue.ToString("N2")</h4>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm mb-5" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
            <div class="card-body p-4">
                <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Novo Produto</h5>
                <div class="row g-3">
                    <div class="col-md-2"><input class="form-control bg-dark text-white border-secondary text-uppercase" @bind="novoProduto.code" placeholder="Cód *" /></div>
                    <div class="col-md-4"><input class="form-control bg-dark text-white border-secondary" @bind="novoProduto.name" placeholder="Nome *" /></div>
                    <div class="col-md-2"><input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novoProduto.salePrice" placeholder="R$ Preço *" /></div>
                    <div class="col-md-2"><input type="number" class="form-control bg-dark text-white border-secondary" @bind="novoProduto.stockQuantity" placeholder="Qtd *" /></div>
                    <div class="col-md-2"><button class="btn w-100 fw-bold btn-warning text-dark" @onclick="SalvarProduto">ADICIONAR</button></div>
                </div>
            </div>
        </div>

        @if (produtos != null)
        {
            <div class="input-group mb-3">
                <span class="input-group-text bg-dark text-secondary border-secondary"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Buscar peça por nome ou código..." @bind="termoBusca" @bind:event="oninput" />
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead style="border-bottom: 2px solid #ffeb3b;">
                        <tr>
                            <th style="color: #ffeb3b;">Código</th>
                            <th style="color: #ffeb3b;">Nome</th>
                            <th style="color: #ffeb3b;">Preço</th>
                            <th style="color: #ffeb3b;" class="text-center">Estoque</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in produtosFiltrados)
                        {
                            var qtdAtual = p.stockQuantity ?? 0;
                            var rowColor = qtdAtual <= 0 ? "#ff4444" : (qtdAtual <= p.minimumStock ? "#ff8800" : "#fff");
                            <tr>
                                <td style="color: @rowColor;">@p.code.ToUpper()</td>
                                <td style="color: @rowColor;">@p.name</td>
                                <td style="color: @rowColor;">R$ @p.salePrice?.ToString("N2")</td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <button class="btn btn-sm text-white" @onclick="() => AjustarEstoque(p, -1)"><i class="bi bi-dash-lg"></i></button>
                                        <span class="fw-bold" style="min-width: 30px;">@qtdAtual</span>
                                        <button class="btn btn-sm text-white" @onclick="() => AjustarEstoque(p, 1)"><i class="bi bi-plus-lg"></i></button>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-warning border-0" @onclick="() => AbrirModalEdicao(p)"><i class="bi bi-pencil-fill"></i></button>
                                    <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => SolicitarExclusao(p)"><i class="bi bi-trash3-fill"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="card border-0 shadow-sm mb-5" style="background-color: #111; border-top: 4px solid #00bcff !important;">
            <div class="card-body p-4">
                <h5 class="mb-3 fw-bold" style="color: #00bcff;">Novo Serviço (Mão de Obra)</h5>
                <div class="row g-3">
                    <div class="col-md-7">
                        <input class="form-control bg-dark text-white border-secondary" @bind="novoServico.Name" placeholder="Ex: Limpeza de Bicos *" />
                    </div>
                    <div class="col-md-3">
                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novoServico.DefaultPrice" placeholder="R$ Valor Base *" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn w-100 fw-bold btn-info text-dark" @onclick="SalvarServico">CADASTRAR</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead style="border-bottom: 2px solid #00bcff;">
                    <tr>
                        <th style="color: #00bcff;">Descrição do Serviço</th>
                        <th style="color: #00bcff;" class="text-end">Preço Sugerido</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (servicosCatalogo != null)
                    {
                        @foreach (var s in servicosCatalogo)
                        {
                            <tr>
                                <td>@s.Name</td>
                                <td class="text-end text-success fw-bold">R$ @s.DefaultPrice.ToString("N2")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => ExcluirServico(s.Id)"><i class="bi bi-trash3-fill"></i></button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="print-only">
    @if (abaAtiva == "pecas" && produtos != null)
    {
        <div class="p-5">
            <div class="text-center mb-4 border-bottom border-dark pb-3">
                <h1 style="color: black !important; font-weight: bold;">RELATÓRIO DE INVENTÁRIO</h1>
                <h3 style="color: #666 !important;">FREITAS AUTOCENTER</h3>
                <p style="color: black !important;">Data: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>

            <table class="table table-bordered border-dark" style="color: black !important;">
                <thead>
                    <tr style="background-color: #f2f2f2 !important;">
                        <th style="color: black !important; border: 1px solid black !important;">CÓD</th>
                        <th style="color: black !important; border: 1px solid black !important;">NOME DO PRODUTO</th>
                        <th style="color: black !important; border: 1px solid black !important;" class="text-end">VALOR UNIT.</th>
                        <th style="color: black !important; border: 1px solid black !important;" class="text-center">QTD</th>
                        <th style="color: black !important; border: 1px solid black !important;" class="text-center">STATUS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in produtos.OrderBy(x => x.stockQuantity > 0 ? 0 : 1).ThenBy(x => x.name))
                    {
                        var qtd = p.stockQuantity ?? 0;
                        var isEsgotado = qtd <= 0;
                        var isBaixo = qtd <= p.minimumStock && !isEsgotado;

                        <tr style="@(isEsgotado ? "background-color: #ffebee !important;" : (isBaixo ? "background-color: #fff3e0 !important;" : ""))">
                            <td style="color: black !important; border: 1px solid black !important;">@p.code</td>
                            <td style="color: black !important; border: 1px solid black !important;">@p.name</td>
                            <td style="color: black !important; border: 1px solid black !important;" class="text-end">R$ @p.salePrice?.ToString("N2")</td>
                            <td style="color: black !important; border: 1px solid black !important; font-weight: bold;" class="text-center">@qtd</td>
                            <td style="color: black !important; border: 1px solid black !important; font-size: 0.8rem;" class="text-center">
                                @if (isEsgotado) { <strong style="color: #d32f2f !important;">ESGOTADO</strong> }
                                else if (isBaixo) { <strong style="color: #ef6c00 !important;">REPOR</strong> }
                                else { <span style="color: #2e7d32 !important;">OK</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .nav-pills .nav-link { border-radius: 0; }
    .table-dark { --bs-table-bg: #000; }
    .print-only { display: none; }
    @@media print {
        body * { visibility: hidden; }
        .print-only, .print-only * { visibility: visible !important; }
        .print-only { display: block !important; position: absolute; left: 0; top: 0; width: 100%; background-color: white !important; color: black !important; }
        .table th, .table td { border: 1px solid black !important; color: black !important; }
    }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";
    private string abaAtiva = "pecas";

    public class ProductDTO { public int id { get; set; } public string code { get; set; } = ""; public string name { get; set; } = ""; public decimal? salePrice { get; set; } public int? stockQuantity { get; set; } public int minimumStock { get; set; } = 5; }
    public class LaborServiceDTO { public int Id { get; set; } public string Name { get; set; } = ""; public decimal DefaultPrice { get; set; } }
    public class HistoricalValueDTO { public decimal currentInventoryValue { get; set; } public decimal totalExitedValue { get; set; } public decimal totalHistoricalValue { get; set; } }

    private List<ProductDTO>? produtos;
    private List<LaborServiceDTO>? servicosCatalogo;
    private HistoricalValueDTO? valoresHistoricos;

    private ProductDTO novoProduto = new();
    private LaborServiceDTO novoServico = new();

    bool mostrarToast = false;
    string toastMensagem = "";
    string toastTipo = "sucesso";
    bool mostrarModalExclusao = false;
    ProductDTO? produtoParaExcluir;
    string termoBusca = "";

    List<ProductDTO> produtosFiltrados => produtos?
        .Where(p => string.IsNullOrEmpty(termoBusca) || p.code.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) || p.name.Contains(termoBusca, StringComparison.OrdinalIgnoreCase))
        .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        await Carregar();
        await CarregarServicos();
        await CarregarValoresHistoricos();
    }

    private async Task Carregar() => produtos = await Http.GetFromJsonAsync<List<ProductDTO>>($"{ApiUrl}/api/products");
    private async Task CarregarServicos() => servicosCatalogo = await Http.GetFromJsonAsync<List<LaborServiceDTO>>($"{ApiUrl}/api/laborservices");
    private async Task CarregarValoresHistoricos() => valoresHistoricos = await Http.GetFromJsonAsync<HistoricalValueDTO>($"{ApiUrl}/api/products/historical-value");

    private async void MostrarSucesso(string msg)
    {
        toastMensagem = msg; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged();
        await Task.Delay(3000); mostrarToast = false; StateHasChanged();
    }

    private async Task SalvarProduto()
    {
        if (string.IsNullOrWhiteSpace(novoProduto.code) || novoProduto.salePrice == null) return;
        novoProduto.code = novoProduto.code.ToUpper();
        await Http.PostAsJsonAsync($"{ApiUrl}/api/products", novoProduto);
        novoProduto = new(); 
        await Carregar(); 
        await CarregarValoresHistoricos();
        MostrarSucesso("Peça cadastrada!");
    }

    private async Task AjustarEstoque(ProductDTO p, int delta)
    {
        p.stockQuantity = (p.stockQuantity ?? 0) + delta;
        await Http.PutAsJsonAsync($"{ApiUrl}/api/products/{p.id}", p);
        await CarregarValoresHistoricos();
        StateHasChanged();
    }

    private void SolicitarExclusao(ProductDTO p) { produtoParaExcluir = p; mostrarModalExclusao = true; }

    private async Task ConfirmarExclusao()
    {
        await Http.DeleteAsync($"{ApiUrl}/api/products/{produtoParaExcluir?.id}");
        mostrarModalExclusao = false; 
        await Carregar(); 
        await CarregarValoresHistoricos();
        MostrarSucesso("Produto removido.");
    }

    private async Task SalvarServico()
    {
        if (string.IsNullOrWhiteSpace(novoServico.Name)) return;
        await Http.PostAsJsonAsync($"{ApiUrl}/api/laborservices", novoServico);
        novoServico = new(); await CarregarServicos(); MostrarSucesso("Serviço adicionado ao catálogo!");
    }

    private async Task ExcluirServico(int id)
    {
        await Http.DeleteAsync($"{ApiUrl}/api/laborservices/{id}");
        await CarregarServicos(); MostrarSucesso("Serviço removido.");
    }

    private async Task ImprimirRelatorio()
    {
        await Task.Delay(200);
        await JS.InvokeVoidAsync("window.print");
    }

    private void AbrirModalEdicao(ProductDTO p) { }
}