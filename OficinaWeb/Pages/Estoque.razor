@page "/estoque"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Estoque - FJ Centro Automotivo</PageTitle>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
    @if (mostrarToast)
    {
        <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                    @toastMensagem
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
            </div>
        </div>
    }
</div>

@if (mostrarModalExclusao)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold text-danger"><i class="bi bi-trash-fill me-2"></i>Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalExclusao = false"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja remover o produto <strong>@produtoParaExcluir?.name</strong> do estoque?</p>
                    <small class="text-secondary">Esta ação não poderá ser desfeita.</small>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" @onclick="() => mostrarModalExclusao = false">Cancelar</button>
                    <button type="button" class="btn btn-danger fw-bold" @onclick="ConfirmarExclusao">SIM, EXCLUIR</button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarModalEdicao && produtoParaEditar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold" style="color: #ffeb3b;">
                        <i class="bi bi-pencil-square me-2"></i>Editar Produto
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalEdicao"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-secondary">Código</label>
                        <input class="form-control bg-dark text-white border-secondary text-uppercase" @bind="produtoParaEditar.code" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary">Nome da Peça</label>
                        <input class="form-control bg-dark text-white border-secondary" @bind="produtoParaEditar.name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary">Preço (R$)</label>
                        <input type="number" min="0" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="produtoParaEditar.salePrice" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary">Estoque</label>
                        <input type="number" min="0" class="form-control bg-dark text-white border-secondary" @bind="produtoParaEditar.stockQuantity" />
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" @onclick="FecharModalEdicao">Cancelar</button>
                    <button type="button" class="btn fw-bold" style="background-color: #ffeb3b; color: #000;" @onclick="SalvarEdicao">SALVAR ALTERAÇÕES</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="container py-4">

    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <a href="/" class="btn btn-outline-secondary border-0 text-white">
                <i class="bi bi-arrow-left me-2"></i>Voltar para o painel
            </a>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;">
                <i class="bi bi-box-seam-fill me-2"></i>Controle de Estoque
            </h2>
        </div>
        <div class="col-md-3"></div>
    </div>

    <div class="card border-0 shadow-sm mb-5" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
        <div class="card-body p-4">
            <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Novo Produto</h5>

            <div class="row g-3">
                <div class="col-md-2">
                    <input class="form-control bg-dark text-white border-secondary text-uppercase"
                           @bind="novoProduto.code"
                           placeholder="Código *" />
                </div>
                <div class="col-md-4">
                    <input class="form-control bg-dark text-white border-secondary"
                           @bind="novoProduto.name"
                           placeholder="Nome da Peça *" />
                </div>
                <div class="col-md-2">
                    <input type="number" min="0" step="0.01" class="form-control bg-dark text-white border-secondary"
                           @bind="novoProduto.salePrice"
                           placeholder="Preço (R$) *" />
                </div>
                <div class="col-md-2">
                    <input type="number" min="0" class="form-control bg-dark text-white border-secondary"
                           @bind="novoProduto.stockQuantity"
                           placeholder="Qtd. *" />
                </div>
                <div class="col-md-2">
                    <button class="btn w-100 fw-bold"
                            style="background-color: #ffeb3b; color: #000000;"
                            @onclick="SalvarProduto">
                        ADICIONAR <i class="bi bi-plus-lg ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (produtos != null)
    {
        <div class="mb-3">
            <div class="input-group">
                <span class="input-group-text bg-dark text-secondary border-secondary"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control bg-dark text-white border-secondary"
                       placeholder="Buscar por código ou nome..."
                       @bind="termoBusca"
                       @bind:event="oninput" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle" style="border-color: #333;">
                <thead style="border-bottom: 2px solid #ffeb3b;">
                    <tr>
                        <th style="color: #ffeb3b;">Código</th>
                        <th style="color: #ffeb3b;">Nome da Peça</th>
                        <th style="color: #ffeb3b;">Preço</th>
                        <th style="color: #ffeb3b;" class="text-center">Estoque</th>
                        <th class="text-end" style="color: #ffeb3b; width: 120px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in produtosFiltrados)
                    {
                        var rowColor = (p.stockQuantity ?? 0) <= p.minimumStock ? "#ff4444" : "#fff";

                        <tr>
                            <td style="color: @rowColor;"><strong>@p.code.ToUpper()</strong></td>
                            <td style="color: @rowColor;">@p.name</td>
                            <td style="color: @rowColor;">R$ @(p.salePrice?.ToString("N2") ?? "0.00")</td>
                            <td class="text-center" style="color: @rowColor;">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <button class="btn btn-sm btn-outline-secondary text-white border-0" @onclick="() => AjustarEstoque(p, -1)">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>

                                    <span class="fw-bold fs-6" style="min-width: 30px;">
                                        @p.stockQuantity
                                    </span>

                                    <button class="btn btn-sm btn-outline-secondary text-white border-0" @onclick="() => AjustarEstoque(p, 1)">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>

                                @if ((p.stockQuantity ?? 0) == 0)
                                {
                                    <div class="text-center mt-1"><small class="badge bg-secondary border border-secondary text-white">INDISPONÍVEL</small></div>
                                }
                                else if ((p.stockQuantity ?? 0) <= p.minimumStock)
                                {
                                    <div class="text-center mt-1"><small class="badge bg-danger">BAIXO</small></div>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-outline-warning btn-sm border-0 me-1"
                                        @onclick="() => AbrirModalEdicao(p)"
                                        title="Editar Produto">
                                    <i class="bi bi-pencil-fill fs-5"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm border-0"
                                        @onclick="() => SolicitarExclusao(p)"
                                        title="Excluir Produto">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (produtosFiltrados.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Nenhum produto encontrado para "<strong>@termoBusca</strong>"
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-warning" role="status"></div>
            <p class="text-muted mt-2">Carregando estoque...</p>
        </div>
    }
</div>

<style>
    .form-control::placeholder {
        color: #b0b0b0 !important;
        opacity: 1;
    }

    .form-control:focus {
        background-color: #222 !important;
        color: #fff !important;
        border-color: #ffeb3b !important;
        box-shadow: 0 0 5px rgba(255, 235, 59, 0.5);
    }

    .table-dark {
        --bs-table-bg: #000;
        background-color: #000;
    }

    .text-uppercase {
        text-transform: uppercase;
    }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";

    public class ProductDTO
    {
        public int id { get; set; }
        public string code { get; set; } = "";
        public string name { get; set; } = "";
        public decimal? salePrice { get; set; }
        public int? stockQuantity { get; set; }
        public int minimumStock { get; set; } = 5;
    }

    private List<ProductDTO>? produtos;
    private ProductDTO novoProduto = new ProductDTO();

    // Controles de UI
    bool mostrarToast = false;
    string toastMensagem = "";
    string toastTipo = "sucesso";

    // Variáveis de Exclusão
    bool mostrarModalExclusao = false;
    ProductDTO? produtoParaExcluir;

    // Variáveis de Edição
    bool mostrarModalEdicao = false;
    ProductDTO? produtoParaEditar;

    // Busca
    string termoBusca = "";
    List<ProductDTO> produtosFiltrados => produtos?
        .Where(p => string.IsNullOrEmpty(termoBusca) ||
                    p.code.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ||
                    p.name.Contains(termoBusca, StringComparison.OrdinalIgnoreCase))
        .ToList() ?? new List<ProductDTO>();

    protected override async Task OnInitializedAsync() { await Carregar(); }

    private async Task Carregar()
    {
        try { produtos = await Http.GetFromJsonAsync<List<ProductDTO>>($"{ApiUrl}/api/products"); } catch { MostrarErro("Erro ao carregar estoque."); }
    }

    private async void MostrarSucesso(string msg)
    {
        toastMensagem = msg; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged();
        await Task.Delay(3000); mostrarToast = false; StateHasChanged();
    }

    private async void MostrarErro(string msg)
    {
        toastMensagem = msg; toastTipo = "erro"; mostrarToast = true; StateHasChanged();
        await Task.Delay(5000); mostrarToast = false; StateHasChanged();
    }

    private async Task SalvarProduto()
    {
        if (string.IsNullOrWhiteSpace(novoProduto.code) ||
            string.IsNullOrWhiteSpace(novoProduto.name) ||
            novoProduto.salePrice == null ||
            novoProduto.stockQuantity == null)
        {
            MostrarErro("Todos os campos (Código, Nome, Preço e Qtd) são obrigatórios!");
            return;
        }

        novoProduto.code = novoProduto.code.ToUpper();

        try
        {
            var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/products", novoProduto);
            if (res.IsSuccessStatusCode)
            {
                await Carregar();
                novoProduto = new ProductDTO();
                MostrarSucesso("Produto adicionado com sucesso!");
            }
            else
            {
                var erro = await res.Content.ReadAsStringAsync();
                MostrarErro(string.IsNullOrEmpty(erro) ? "Erro ao salvar." : erro);
            }
        }
        catch { MostrarErro("Erro de conexão ao salvar."); }
    }

    private async Task AjustarEstoque(ProductDTO p, int delta)
    {
        if (p.stockQuantity + delta < 0) { MostrarErro("Estoque não pode ser negativo."); return; }

        p.stockQuantity += delta;
        try
        {
            var res = await Http.PutAsJsonAsync($"{ApiUrl}/api/products/{p.id}", p);
            if (!res.IsSuccessStatusCode)
            {
                p.stockQuantity -= delta;
                MostrarErro("Erro ao atualizar estoque.");
            }
        }
        catch
        {
            p.stockQuantity -= delta;
            MostrarErro("Erro de conexão.");
        }
    }

    private void SolicitarExclusao(ProductDTO p)
    {
        produtoParaExcluir = p;
        mostrarModalExclusao = true;
    }

    private async Task ConfirmarExclusao()
    {
        if (produtoParaExcluir == null) return;

        try
        {
            var res = await Http.DeleteAsync($"{ApiUrl}/api/products/{produtoParaExcluir.id}");
            if (res.IsSuccessStatusCode)
            {
                await Carregar();
                MostrarSucesso("Produto excluído!");
            }
            else
            {
                var erro = await res.Content.ReadAsStringAsync();
                if (erro.Contains("message")) MostrarErro("Produto em uso. Não pode excluir.");
                else MostrarErro("Erro ao excluir.");
            }
        }
        catch { MostrarErro("Erro ao excluir."); }

        mostrarModalExclusao = false;
        produtoParaExcluir = null;
    }

    private void AbrirModalEdicao(ProductDTO p)
    {
        produtoParaEditar = new ProductDTO
        {
            id = p.id,
            code = p.code,
            name = p.name,
            salePrice = p.salePrice,
            stockQuantity = p.stockQuantity,
            minimumStock = p.minimumStock
        };
        mostrarModalEdicao = true;
    }

    private void FecharModalEdicao()
    {
        mostrarModalEdicao = false;
        produtoParaEditar = null;
    }

    private async Task SalvarEdicao()
    {
        if (produtoParaEditar == null) return;

        if (string.IsNullOrWhiteSpace(produtoParaEditar.code) ||
            string.IsNullOrWhiteSpace(produtoParaEditar.name) ||
            produtoParaEditar.salePrice == null ||
            produtoParaEditar.stockQuantity == null)
        {
            MostrarErro("Todos os campos são obrigatórios para edição!");
            return;
        }

        produtoParaEditar.code = produtoParaEditar.code.ToUpper();

        try
        {
            var res = await Http.PutAsJsonAsync($"{ApiUrl}/api/products/{produtoParaEditar.id}", produtoParaEditar);

            if (res.IsSuccessStatusCode)
            {
                await Carregar();
                FecharModalEdicao();
                MostrarSucesso("Produto atualizado com sucesso!");
            }
            else
            {
                var erro = await res.Content.ReadAsStringAsync();
                MostrarErro(string.IsNullOrEmpty(erro) ? "Erro ao atualizar o produto." : erro);
            }
        }
        catch
        {
            MostrarErro("Erro de conexão ao salvar a edição.");
        }
    }
}