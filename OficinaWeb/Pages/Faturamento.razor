@page "/faturamento"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Financeiro e Caixa - FJ Centro Automotivo</PageTitle>

<div class="container-fluid py-4 px-4 no-print">
    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("/")'>
                <i class="bi bi-arrow-left me-2"></i>Voltar
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #28a745;"><i class="bi bi-wallet2 me-2"></i>Fechamento de Caixa</h2>
        </div>
        <div class="col-md-3 text-end">
            <button class="btn btn-outline-success fw-bold" @onclick="CarregarDados" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>ATUALIZAR
            </button>
        </div>
    </div>

    @* SISTEMA DE TOASTS *@
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (mostrarToast)
        {
            <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0 shadow-lg" role="alert">
                <div class="d-flex">
                    <div class="toast-body fw-bold">
                        <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                        @toastMensagem
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
                </div>
            </div>
        }
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="text-white-50 mt-2">Calculando saldos e transações...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @* CARD DA GAVETA*@
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm position-relative" style="background: #111; border-top: 4px solid #28a745 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-cash-coin mb-2 d-block" style="font-size: 2.5rem; color: #28a745;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Dinheiro na Gaveta</h6>
                        <h2 class="text-white fw-bold mb-3">R$ @totalDinheiro.ToString("N2")</h2>

                        @* Botões de Ação para a Gaveta *@
                        <div class="d-flex flex-column gap-2 mt-3 pt-3 border-top border-secondary">
                            @if (editandoGaveta)
                            {
                                <div class="input-group input-group-sm">
                                    <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary text-end" @bind="valorAjusteGaveta" placeholder="R$ (ex: 50 ou -50)" />
                                    <button class="btn btn-success fw-bold" @onclick="LancarAjusteGaveta" title="Confirmar Ajuste"><i class="bi bi-check-lg"></i></button>
                                    <button class="btn btn-outline-secondary" @onclick="() => editandoGaveta = false" title="Cancelar"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-info fw-bold w-100" @onclick="() => editandoGaveta = true">
                                    <i class="bi bi-pencil-square me-1"></i>AJUSTE MANUAL
                                </button>
                            }

                            <button class="btn btn-sm btn-danger fw-bold w-100 mt-1" @onclick="ZerarGaveta" disabled="@(totalDinheiro <= 0)">
                                <i class="bi bi-trash3-fill me-1"></i>ZERAR GAVETA (RETIRADA)
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #0dcaf0 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-phone-vibrate mb-2 d-block" style="font-size: 2.5rem; color: #0dcaf0;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Recebido via PIX</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalPix.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #ffc107 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-credit-card-fill mb-2 d-block" style="font-size: 2.5rem; color: #ffc107;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Cartão de Crédito</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalCredito.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #fd7e14 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-credit-card-2-front mb-2 d-block" style="font-size: 2.5rem; color: #fd7e14;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Cartão de Débito</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalDebito.ToString("N2")</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-secondary shadow-sm" style="background: #0a0a0a;">
                    <div class="card-header border-secondary bg-transparent py-3">
                        <h5 class="mb-0 fw-bold text-white"><i class="bi bi-bar-chart-line-fill me-2"></i>Resumo Geral</h5>
                    </div>
                    <div class="card-body">

                        @* --- BLOCO ATUALIZADO: GANHOS DA SEMANA COM AJUSTE --- *@
                        <div class="mb-3 pb-3 border-bottom border-secondary" style="background-color: #1a1a1a; padding: 10px; border-radius: 5px;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-info fw-bold d-block"><i class="bi bi-calendar-week me-1"></i>Ganhos da Semana:</span>
                                    <small class="text-muted" style="font-size: 0.75rem;">Reinicia todo domingo</small>
                                </div>
                                <div class="text-end">
                                    <span class="text-info fw-bold fs-4" style="cursor:pointer;" title="Clique para ajustar valor" @onclick="() => editandoSemana = !editandoSemana">
                                        R$ @faturamentoSemanal.ToString("N2") <i class="bi bi-pencil-square text-secondary fs-6 ms-1"></i>
                                    </span>
                                </div>
                            </div>

                            @* Mini formulário que aparece ao clicar no lápis *@
                            @if (editandoSemana)
                            {
                                <div class="mt-2 pt-2 border-top border-dark d-flex flex-column gap-2">
                                    <small class="text-secondary fw-bold">Novo Ajuste de Faturamento:</small>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control bg-dark text-white border-secondary" @bind="descricaoAjusteSemana" placeholder="Motivo (Ex: Pgto Extra)" />
                                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary text-end w-25" @bind="valorAjusteSemana" placeholder="R$ (+ ou -)" />
                                    </div>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => editandoSemana = false">Cancelar</button>
                                        <button class="btn btn-sm btn-info fw-bold text-dark" @onclick="LancarAjusteSemana">Salvar Ajuste</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-secondary">
                            <span class="text-white-50">Total Faturado (Recebido):</span>
                            <span class="text-success fw-bold fs-5">R$ @faturamentoTotal.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-secondary">
                            <span class="text-white-50">Vendas Avulsas (Soma do balcão):</span>
                            <span class="text-white fw-bold">R$ @totalVendasAvulsas.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between pt-2">
                            <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>Inadimplência (A receber):</span>
                            <span class="text-danger fw-bold fs-5">R$ @totalInadimplencia.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card border-secondary shadow-sm h-100" style="background: #0a0a0a;">
                    <div class="card-header border-secondary bg-transparent py-3">
                        <h5 class="mb-0 fw-bold text-white"><i class="bi bi-receipt-cutoff me-2"></i>Últimos Pagamentos (O.S)</h5>
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-dark table-hover mb-0">
                            <thead style="position: sticky; top: 0; background: #111; z-index: 1;">
                                <tr>
                                    <th class="border-secondary">O.S.</th>
                                    <th class="border-secondary">Cliente</th>
                                    <th class="border-secondary">Data</th>
                                    <th class="border-secondary text-center">Forma</th>
                                    <th class="border-secondary text-end">Valor Pago</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transacoesRecentes != null && transacoesRecentes.Any())
                                {
                                    @foreach (var t in transacoesRecentes)
                                    {
                                        <tr>
                                            <td class="text-warning fw-bold border-secondary">#@t.Id</td>
                                            <td class="border-secondary">@t.Cliente</td>
                                            <td class="border-secondary">@t.DataPagamento.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-center border-secondary">
                                                @if (t.Forma == "DINHEIRO")
                                                {
                                                    <span class="badge bg-success">DINHEIRO</span>
                                                }
                                                else if (t.Forma == "PIX")
                                                {

                                                    <span class="badge bg-info text-dark">PIX</span>
                                                }
                                                else if (t.Forma == "CRÉDITO" || t.Forma == "CREDITO")
                                                {

                                                    <span class="badge bg-warning text-dark">CRÉDITO</span>
                                                }
                                                else if (t.Forma == "DÉBITO" || t.Forma == "DEBITO")
                                                {

                                                    <span class="badge" style="background-color: #fd7e14;">DÉBITO</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-secondary">@(string.IsNullOrEmpty(t.Forma) ? "NÃO INFORMADO" : t.Forma)</span>
                                                }
                                            </td>
                                            <td class="text-end fw-bold text-white border-secondary">R$ @t.ValorPago.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-white-50 border-secondary">Nenhum pagamento registrado nas O.S concluídas.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string ApiUrl = "https://localhost:7082";
    private bool isLoading = true;

    // Variáveis de Gaveta
    private bool editandoGaveta = false;
    private decimal valorAjusteGaveta = 0;

    // --- VARIÁVEIS DO NOVO AJUSTE SEMANAL ---
    private bool editandoSemana = false;
    private decimal valorAjusteSemana = 0;
    private string descricaoAjusteSemana = "";

    // Feedback
    private bool mostrarToast = false;
    private string toastMensagem = "";
    private string toastTipo = "sucesso";

    private decimal faturamentoTotal = 0;
    private decimal faturamentoSemanal = 0;
    private decimal totalDinheiro = 0;
    private decimal totalPix = 0;
    private decimal totalCredito = 0;
    private decimal totalDebito = 0;
    private decimal totalInadimplencia = 0;
    private decimal totalVendasAvulsas = 0;

    public class TransacaoVisao
    {
        public int Id { get; set; }
        public string Cliente { get; set; } = "";
        public DateTime DataPagamento { get; set; }
        public string Forma { get; set; } = "";
        public decimal ValorPago { get; set; }
    }

    public class CashAdjustmentDTO
    {
        public decimal Amount { get; set; }
        public string Description { get; set; } = "";
    }

    // Novo DTO para ler os ajustes do banco
    public class RevenueAdjustmentDTO
    {
        public int Id { get; set; }
        public decimal Amount { get; set; }
        public string Description { get; set; } = "";
        public DateTime Date { get; set; }
    }

    private List<TransacaoVisao> transacoesRecentes = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        try
        {
            isLoading = true;

            faturamentoTotal = faturamentoSemanal = totalPix = totalCredito = totalDebito = totalInadimplencia = totalVendasAvulsas = 0;
            totalDinheiro = 0;
            transacoesRecentes.Clear();

            DateTime hoje = DateTime.Now.Date;
            DateTime inicioDaSemana = hoje.AddDays(-(int)hoje.DayOfWeek);

            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders");
            var vendasAvulsas = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/quicksales");

            try
            {
                totalDinheiro = await Http.GetFromJsonAsync<decimal>($"{ApiUrl}/api/serviceorders/cash-balance");
            }
            catch
            {
                Console.WriteLine("Aviso: Falha ao buscar saldo de gaveta ajustado.");
            }

            if (osList != null)
            {
                var concluidas = osList.Where(x => x.TryGetProperty("status", out var s) && s.ToString() == "Completed").ToList();

                foreach (var os in concluidas)
                {
                    try
                    {
                        decimal valorTotal = os.TryGetProperty("totalAmount", out var t) ? t.GetDecimal() : 0;
                        decimal valorPago = os.TryGetProperty("amountPaid", out var p) ? p.GetDecimal() : 0;

                        DateTime data = DateTime.MinValue;
                        if (os.TryGetProperty("completionDate", out var dtElement) && dtElement.ValueKind != JsonValueKind.Null)
                        {
                            DateTime.TryParse(dtElement.ToString(), out data);
                        }

                        string formaOriginal = os.TryGetProperty("paymentMethod", out var m) && m.ValueKind != JsonValueKind.Null ? m.ToString() : "";
                        string formaFormatada = formaOriginal.Trim().ToUpper();

                        string cliente = "Cliente Não Identificado";
                        if (os.TryGetProperty("vehicle", out var v) && v.ValueKind != JsonValueKind.Null)
                        {
                            cliente = v.TryGetProperty("customerName", out var cn) && cn.ValueKind != JsonValueKind.Null ? cn.ToString() : cliente;
                        }

                        int id = os.TryGetProperty("id", out var i) ? i.GetInt32() : 0;
                        decimal faltaPagar = Math.Max(0, valorTotal - valorPago);

                        totalInadimplencia += faltaPagar;
                        faturamentoTotal += valorPago;

                        if (data >= inicioDaSemana)
                        {
                            faturamentoSemanal += valorPago;
                        }

                        if (valorPago > 0)
                        {
                            if (formaFormatada == "PIX") totalPix += valorPago;
                            else if (formaFormatada == "CRÉDITO" || formaFormatada == "CREDITO") totalCredito += valorPago;
                            else if (formaFormatada == "DÉBITO" || formaFormatada == "DEBITO") totalDebito += valorPago;

                            transacoesRecentes.Add(new TransacaoVisao
                            {
                                Id = id,
                                Cliente = cliente,
                                DataPagamento = data == DateTime.MinValue ? DateTime.Now : data,
                                Forma = formaFormatada,
                                ValorPago = valorPago
                            });
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Erro ao processar O.S: {ex.Message}");
                    }
                }
            }

            if (vendasAvulsas != null)
            {
                foreach (var venda in vendasAvulsas)
                {
                    decimal valorVenda = venda.TryGetProperty("price", out var vp) ? vp.GetDecimal() : 0;

                    DateTime dataVenda = DateTime.MinValue;
                    if (venda.TryGetProperty("date", out var dtVenda) && dtVenda.ValueKind != JsonValueKind.Null)
                    {
                        DateTime.TryParse(dtVenda.ToString(), out dataVenda);
                    }

                    totalVendasAvulsas += valorVenda;
                    faturamentoTotal += valorVenda;

                    if (dataVenda >= inicioDaSemana)
                    {
                        faturamentoSemanal += valorVenda;
                    }
                }
            }

            // --- NOVO: BUSCA E SOMA OS AJUSTES DA SEMANA ---
            try
            {
                var ajustesSemana = await Http.GetFromJsonAsync<List<RevenueAdjustmentDTO>>($"{ApiUrl}/api/serviceorders/revenue-adjustments");
                if (ajustesSemana != null)
                {
                    foreach (var ajuste in ajustesSemana)
                    {
                        // Soma apenas os ajustes que foram feitos DESTE domingo em diante
                        if (ajuste.Date >= inicioDaSemana)
                        {
                            faturamentoSemanal += ajuste.Amount;
                        }
                        // Soma no Faturamento Total Histórico também!
                        faturamentoTotal += ajuste.Amount;
                    }
                }
            }
            catch
            {
                Console.WriteLine("Aviso: Falha ao buscar ajustes de receita.");
            }

            transacoesRecentes = transacoesRecentes.OrderByDescending(t => t.DataPagamento).ToList();
        }
        catch (Exception ex)
        {
            MostrarErro("Falha geral ao carregar faturamento.");
        }
        finally
        {
            isLoading = false;
        }
    }

    // --- NOVO MÉTODO PARA SALVAR AJUSTE SEMANAL ---
    private async Task LancarAjusteSemana()
    {
        if (valorAjusteSemana == 0)
        {
            MostrarErro("O valor não pode ser zero.");
            return;
        }
        if (string.IsNullOrWhiteSpace(descricaoAjusteSemana))
        {
            descricaoAjusteSemana = "Ajuste manual de faturamento";
        }

        try
        {
            var request = new CashAdjustmentDTO
            {
                Amount = valorAjusteSemana,
                Description = descricaoAjusteSemana
            };

            var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/revenue-adjustment", request);

            if (res.IsSuccessStatusCode)
            {
                valorAjusteSemana = 0;
                descricaoAjusteSemana = "";
                editandoSemana = false;
                await CarregarDados();
                MostrarSucesso("Faturamento atualizado!");
            }
            else
            {
                MostrarErro("Falha ao registrar ajuste.");
            }
        }
        catch
        {
            MostrarErro("Erro de comunicação com a API.");
        }
    }

    // MÉTODOS DE CONTROLE DA GAVETA
    private async Task LancarAjusteGaveta()
    {
        if (valorAjusteGaveta == 0) { editandoGaveta = false; return; }

        try
        {
            var request = new CashAdjustmentDTO
            {
                Amount = valorAjusteGaveta,
                Description = "Ajuste manual de Gaveta via Painel"
            };

            var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/cash-adjustment", request);

            if (res.IsSuccessStatusCode)
            {
                valorAjusteGaveta = 0;
                editandoGaveta = false;
                await CarregarDados();
                MostrarSucesso("Ajuste de gaveta registrado com sucesso!");
            }
            else
            {
                MostrarErro("Falha ao registrar ajuste no backend.");
            }
        }
        catch
        {
            MostrarErro("Erro de comunicação com a API.");
        }
    }

    private async Task ZerarGaveta()
    {
        if (totalDinheiro <= 0) return;

        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"Atenção: Você está prestes a zerar a gaveta.\n\nUma retirada de R$ {totalDinheiro:N2} será registrada para os sócios.\n\nDeseja confirmar?");
        if (!confirmado) return;

        try
        {
            var request = new CashAdjustmentDTO
            {
                Amount = -totalDinheiro,
                Description = "Sangria Total de Caixa (Retirada Sócios)"
            };

            var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/cash-adjustment", request);

            if (res.IsSuccessStatusCode)
            {
                await CarregarDados();
                MostrarSucesso("Gaveta zerada com sucesso!");
            }
            else
            {
                MostrarErro("Falha ao processar sangria.");
            }
        }
        catch
        {
            MostrarErro("Erro de comunicação com a API.");
        }
    }

    private void MostrarSucesso(string msg) { toastMensagem = msg; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged(); Task.Delay(3000).ContinueWith(_ => { mostrarToast = false; InvokeAsync(StateHasChanged); }); }
    private void MostrarErro(string msg) { toastMensagem = msg; toastTipo = "erro"; mostrarToast = true; StateHasChanged(); Task.Delay(5000).ContinueWith(_ => { mostrarToast = false; InvokeAsync(StateHasChanged); }); }
}