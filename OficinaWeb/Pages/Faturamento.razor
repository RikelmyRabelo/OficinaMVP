@page "/faturamento"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json
@using System.Text.Json
@using OficinaWeb.Models

<PageTitle>Financeiro e Caixa - FREITAS AUTOCENTER</PageTitle>

<div class="container-fluid py-4 px-4 no-print">
    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("/")'>
                <i class="bi bi-arrow-left me-2"></i>Voltar
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #28a745;"><i class="bi bi-wallet2 me-2"></i>Fechamento de Caixa</h2>
        </div>
        <div class="col-md-3 text-end">
            <button class="btn btn-outline-success fw-bold" @onclick="CarregarDados" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>ATUALIZAR
            </button>
        </div>
    </div>

    @* SISTEMA DE TOASTS *@
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (mostrarToast)
        {
            <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0 shadow-lg" role="alert">
                <div class="d-flex">
                    <div class="toast-body fw-bold">
                        <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                        @toastMensagem
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
                </div>
            </div>
        }
    </div>

    @* MODAL DETALHES DO PAGAMENTO *@
    @if (mostrarModalDetalhes && transacaoSelecionada != null)
    {
        <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8); z-index: 1050;" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-white border-secondary">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title fw-bold text-info"><i class="bi bi-receipt me-2"></i>Detalhes do Pagamento</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="FecharDetalhes"></button>
                    </div>
                    <div class="modal-body">
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-dark">
                            <div>
                                <h6 class="text-white mb-0">@transacaoSelecionada.Cliente</h6>
                                <small class="text-warning fw-bold">Ordem de Serviço #@transacaoSelecionada.Id</small>
                            </div>
                            <div class="text-end">
                                <small class="text-muted d-block"><i class="bi bi-calendar-event me-1"></i>Data do Registro</small>
                                <span class="text-white-50">@transacaoSelecionada.DataPagamento.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>

                        <div class="row g-2 mb-3 text-center">
                            <div class="col-4">
                                <div class="p-2 bg-black rounded border border-secondary">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">VALOR DA O.S.</small>
                                    <strong class="text-white">R$ @transacaoSelecionada.ValorTotal.ToString("N2")</strong>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2 bg-black rounded border border-success">
                                    <small class="text-success d-block fw-bold" style="font-size: 0.7rem;">TOTAL PAGO</small>
                                    <strong class="text-success">R$ @transacaoSelecionada.ValorPago.ToString("N2")</strong>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="p-2 bg-black rounded border @(transacaoSelecionada.FaltaPagar > 0 ? "border-danger" : "border-secondary")">
                                    <small class="@(transacaoSelecionada.FaltaPagar > 0 ? "text-danger" : "text-muted") d-block fw-bold" style="font-size: 0.7rem;">FALTA PAGAR</small>
                                    <strong class="@(transacaoSelecionada.FaltaPagar > 0 ? "text-danger" : "text-white-50")">R$ @transacaoSelecionada.FaltaPagar.ToString("N2")</strong>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <small class="text-info fw-bold mb-2 d-block">Formas Utilizadas:</small>
                            @if (transacaoSelecionada.DivisaoPagamento.Any())
                            {
                                <ul class="list-group list-group-flush rounded border border-secondary">
                                    @foreach (var split in transacaoSelecionada.DivisaoPagamento)
                                    {
                                        <li class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                                            <div>
                                                <span class="d-block">@split.PaymentMethod</span>
                                                <small class="text-white-50" style="font-size: 0.70rem;">
                                                    <i class="bi bi-clock me-1"></i>@split.PaymentDate.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            </div>
                                            <span class="fw-bold">R$ @split.Amount.ToString("N2")</span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="p-2 bg-black rounded border border-secondary d-flex justify-content-between">
                                    <span class="text-white-50">@transacaoSelecionada.Forma</span>
                                    <span class="text-white fw-bold">R$ @transacaoSelecionada.ValorPago.ToString("N2")</span>
                                </div>
                            }
                        </div>

                    </div>
                    <div class="modal-footer border-secondary">
                        <button type="button" class="btn btn-outline-light w-100" @onclick="FecharDetalhes">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="text-white-50 mt-2">Calculando saldos e transações com alta performance...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @* CARD DA GAVETA *@
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm position-relative" style="background: #111; border-top: 4px solid #28a745 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-cash-coin mb-2 d-block" style="font-size: 2.5rem; color: #28a745;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Dinheiro na Gaveta</h6>
                        <h2 class="text-white fw-bold mb-3">R$ @totalDinheiro.ToString("N2")</h2>

                        <div class="d-flex flex-column gap-2 mt-3 pt-3 border-top border-secondary">
                            @if (editandoGaveta)
                            {
                                <div class="input-group input-group-sm">
                                    <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary text-end" @bind="valorAjusteGaveta" placeholder="R$ (ex: 50 ou -50)" />
                                    <button class="btn btn-success fw-bold" @onclick="LancarAjusteGaveta" title="Confirmar Ajuste"><i class="bi bi-check-lg"></i></button>
                                    <button class="btn btn-outline-secondary" @onclick="() => editandoGaveta = false" title="Cancelar"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-info fw-bold w-100" @onclick="() => editandoGaveta = true">
                                    <i class="bi bi-pencil-square me-1"></i>AJUSTE MANUAL
                                </button>
                            }

                            <button class="btn btn-sm btn-danger fw-bold w-100 mt-1" @onclick="ZerarGaveta" disabled="@(totalDinheiro <= 0)">
                                <i class="bi bi-trash3-fill me-1"></i>ZERAR GAVETA (RETIRADA)
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #0dcaf0 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-phone-vibrate mb-2 d-block" style="font-size: 2.5rem; color: #0dcaf0;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Recebido via PIX</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalPix.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #ffc107 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-credit-card-fill mb-2 d-block" style="font-size: 2.5rem; color: #ffc107;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Cartão de Crédito</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalCredito.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #fd7e14 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-credit-card-2-front mb-2 d-block" style="font-size: 2.5rem; color: #fd7e14;"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Cartão de Débito</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalDebito.ToString("N2")</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-secondary shadow-sm" style="background: #0a0a0a;">
                    <div class="card-header border-secondary bg-transparent py-3">
                        <h5 class="mb-0 fw-bold text-white"><i class="bi bi-bar-chart-line-fill me-2"></i>Resumo do Mês</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3 pb-3 border-bottom border-secondary" style="background-color: #1a1a1a; padding: 10px; border-radius: 5px;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-info fw-bold d-block"><i class="bi bi-calendar-week me-1"></i>Ganhos da Semana:</span>
                                    <small class="text-muted" style="font-size: 0.75rem;">Reinicia todo domingo</small>
                                </div>
                                <div class="text-end">
                                    <span class="text-info fw-bold fs-4" style="cursor:pointer;" title="Clique para ajustar valor" @onclick="() => editandoSemana = !editandoSemana">
                                        R$ @faturamentoSemanal.ToString("N2") <i class="bi bi-pencil-square text-secondary fs-6 ms-1"></i>
                                    </span>
                                </div>
                            </div>

                            @if (editandoSemana)
                            {
                                <div class="mt-2 pt-2 border-top border-dark d-flex flex-column gap-2">
                                    <small class="text-secondary fw-bold">Novo Ajuste de Faturamento:</small>
                                    <div class="input-group input-group-sm">
                                        <input type="text" class="form-control bg-dark text-white border-secondary" @bind="descricaoAjusteSemana" placeholder="Motivo (Ex: Pgto Extra)" />
                                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary text-end w-25" @bind="valorAjusteSemana" placeholder="R$ (+ ou -)" />
                                    </div>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => editandoSemana = false">Cancelar</button>
                                        <button class="btn btn-sm btn-info fw-bold text-dark" @onclick="LancarAjusteSemana">Salvar Ajuste</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-secondary">
                            <span class="text-white-50">Faturamento Mensal (Recebido):</span>
                            <span class="text-success fw-bold fs-5">R$ @faturamentoTotal.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between pt-2">
                            <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>Inadimplência (A receber):</span>
                            <span class="text-danger fw-bold fs-5">R$ @totalInadimplencia.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card border-secondary shadow-sm h-100" style="background: #0a0a0a;">
                    <div class="card-header border-secondary bg-transparent py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-white"><i class="bi bi-receipt-cutoff me-2"></i>Pagamentos em Março/2026</h5>
                        <small class="text-white-50">Clique em uma linha para ver detalhes</small>
                    </div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-dark table-hover mb-0">
                            <thead style="position: sticky; top: 0; background: #111; z-index: 1;">
                                <tr>
                                    <th class="border-secondary">O.S.</th>
                                    <th class="border-secondary">Cliente</th>
                                    <th class="border-secondary">Data</th>
                                    <th class="border-secondary text-center">Forma</th>
                                    <th class="border-secondary text-end">Valor Pago</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transacoesRecentes != null && transacoesRecentes.Any())
                                {
                                    @foreach (var t in transacoesRecentes)
                                    {
                                        <tr style="cursor: pointer;" @onclick="() => AbrirDetalhes(t)" title="Ver detalhes do pagamento">
                                            <td class="text-warning fw-bold border-secondary align-middle">#@t.Id</td>
                                            <td class="border-secondary align-middle">@t.Cliente</td>
                                            <td class="border-secondary align-middle text-white-50">@t.DataPagamento.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-center border-secondary align-middle">
                                                @if (t.DivisaoPagamento.Count > 1)
                                                {
                                                    <span class="badge bg-secondary border border-light text-white">MISTO</span>
                                                }
                                                else
                                                {
                                                    <span class="badge @GetBadgeClass(t.Forma)">@t.Forma</span>
                                                }
                                            </td>
                                            <td class="text-end border-secondary align-middle">
                                                <span class="fw-bold text-white d-block">R$ @t.ValorPago.ToString("N2")</span>
                                                @if (t.FaltaPagar > 0)
                                                {
                                                    <span class="badge bg-danger mt-1" style="font-size: 0.65rem;">FALTA R$ @t.FaltaPagar.ToString("N2")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-white-50 border-secondary">Nenhum pagamento registrado em março.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string ApiUrl = "https://localhost:7082";
    private bool isLoading = true;
    private bool editandoGaveta = false;
    private decimal valorAjusteGaveta = 0;
    private bool editandoSemana = false;
    private decimal valorAjusteSemana = 0;
    private string descricaoAjusteSemana = "";
    private bool mostrarToast = false;
    private string toastMensagem = "";
    private string toastTipo = "sucesso";

    private decimal faturamentoTotal = 0;
    private decimal faturamentoSemanal = 0;
    private decimal totalDinheiro = 0;
    private decimal totalPix = 0;
    private decimal totalCredito = 0;
    private decimal totalDebito = 0;
    private decimal totalInadimplencia = 0;

    private bool mostrarModalDetalhes = false;
    private TransacaoVisao? transacaoSelecionada;
    private List<TransacaoVisao> transacoesRecentes = new();

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private void AbrirDetalhes(TransacaoVisao transacao) { transacaoSelecionada = transacao; mostrarModalDetalhes = true; }
    private void FecharDetalhes() { mostrarModalDetalhes = false; transacaoSelecionada = null; }

    private async Task CarregarDados()
    {
        try
        {
            isLoading = true;
            DateTime agora = DateTime.Now;

            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders") ?? new();
            var ajustes = await Http.GetFromJsonAsync<List<RevenueAdjustmentDTO>>($"{ApiUrl}/api/serviceorders/revenue-adjustments") ?? new();
            totalDinheiro = await Http.GetFromJsonAsync<decimal>($"{ApiUrl}/api/serviceorders/cash-balance");

            // Reset mensal manual para garantir "zeramento" visual de Março/2026
            faturamentoTotal = 0; faturamentoSemanal = 0; totalPix = 0; totalCredito = 0; totalDebito = 0; totalInadimplencia = 0;
            transacoesRecentes.Clear();

            DateTime inicioSemana = agora.Date.AddDays(-(int)agora.DayOfWeek);

            foreach (var os in osList)
            {
                if (os.TryGetProperty("status", out var s) && s.ToString() == "Completed")
                {
                    DateTime dataConclusao = os.TryGetProperty("completionDate", out var d) && d.ValueKind != JsonValueKind.Null ? d.GetDateTime() : DateTime.MinValue;

                    if (dataConclusao.Month == agora.Month && dataConclusao.Year == agora.Year)
                    {
                        decimal pago = os.TryGetProperty("amountPaid", out var ap) ? ap.GetDecimal() : 0;
                        decimal total = os.TryGetProperty("totalAmount", out var ta) ? ta.GetDecimal() : 0;
                        string metodo = os.TryGetProperty("paymentMethod", out var pm) ? pm.ToString().ToUpper() : "N/I";

                        faturamentoTotal += pago;
                        totalInadimplencia += Math.Max(0, total - pago);
                        if (dataConclusao >= inicioSemana) faturamentoSemanal += pago;

                        if (metodo == "PIX") totalPix += pago;
                        else if (metodo.Contains("CREDITO") || metodo.Contains("CRÉDITO")) totalCredito += pago;
                        else if (metodo.Contains("DEBITO") || metodo.Contains("DÉBITO")) totalDebito += pago;

                        // Adiciona às transações recentes do mês
                        transacoesRecentes.Add(MapearTransacao(os, dataConclusao, pago, total, metodo));
                    }
                }
            }

            foreach (var a in ajustes.Where(x => x.Date.Month == agora.Month && x.Date.Year == agora.Year))
            {
                faturamentoTotal += a.Amount;
                if (a.Date >= inicioSemana) faturamentoSemanal += a.Amount;
            }

            transacoesRecentes = transacoesRecentes.OrderByDescending(t => t.DataPagamento).ToList();
        }
        catch { MostrarErro("Falha ao sincronizar financeiro."); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private TransacaoVisao MapearTransacao(JsonElement os, DateTime dt, decimal pago, decimal total, string forma)
    {
        string cliente = "Consumidor";
        if (os.TryGetProperty("vehicle", out var v))
            cliente = v.TryGetProperty("customerName", out var cn) ? cn.ToString() : cliente;

        return new TransacaoVisao
        {
            Id = os.GetProperty("id").GetInt32(),
            Cliente = cliente,
            DataPagamento = dt,
            Forma = forma,
            ValorPago = pago,
            ValorTotal = total,
            FaltaPagar = Math.Max(0, total - pago)
        };
    }

    private string GetBadgeClass(string forma) => forma switch
    {
        "DINHEIRO" => "bg-success",
        "PIX" => "bg-info text-dark",
        "CRÉDITO" or "CREDITO" => "bg-warning text-dark",
        "DÉBITO" or "DEBITO" => "bg-primary",
        _ => "bg-secondary"
    };

    private async Task LancarAjusteSemana() { await ExecutarAjuste($"{ApiUrl}/api/serviceorders/revenue-adjustment", new CashAdjustmentDTO { Amount = valorAjusteSemana, Description = descricaoAjusteSemana }); valorAjusteSemana = 0; editandoSemana = false; }
    private async Task LancarAjusteGaveta() { if (valorAjusteGaveta == 0) return; await ExecutarAjuste($"{ApiUrl}/api/serviceorders/cash-adjustment", new CashAdjustmentDTO { Amount = valorAjusteGaveta, Description = "Ajuste Manual" }); valorAjusteGaveta = 0; editandoGaveta = false; }
    private async Task ZerarGaveta() { if (totalDinheiro <= 0) return; if (await JS.InvokeAsync<bool>("confirm", "Zerar gaveta?")) await ExecutarAjuste($"{ApiUrl}/api/serviceorders/cash-adjustment", new CashAdjustmentDTO { Amount = -totalDinheiro, Description = "Retirada Total" }); }

    private async Task ExecutarAjuste(string url, CashAdjustmentDTO dto)
    {
        var res = await Http.PostAsJsonAsync(url, dto);
        if (res.IsSuccessStatusCode) { await CarregarDados(); MostrarSucesso("Operação realizada!"); }
        else MostrarErro("Erro na API.");
    }

    private void MostrarSucesso(string m) { toastMensagem = m; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged(); Task.Delay(3000).ContinueWith(_ => { mostrarToast = false; InvokeAsync(StateHasChanged); }); }
    private void MostrarErro(string m) { toastMensagem = m; toastTipo = "erro"; mostrarToast = true; StateHasChanged(); Task.Delay(5000).ContinueWith(_ => { mostrarToast = false; InvokeAsync(StateHasChanged); }); }

    public class FinancialSummaryDTO { public decimal FaturamentoTotal { get; set; } public decimal FaturamentoSemanal { get; set; } public decimal Inadimplencia { get; set; } public decimal TotalPix { get; set; } public decimal TotalCredito { get; set; } public decimal TotalDebito { get; set; } }
    public class TransacaoVisao { public int Id { get; set; } public string Cliente { get; set; } = ""; public DateTime DataPagamento { get; set; } public string Forma { get; set; } = ""; public decimal ValorPago { get; set; } public decimal ValorTotal { get; set; } public decimal FaltaPagar { get; set; } public List<PaymentSplitDTO> DivisaoPagamento { get; set; } = new(); }
    public class CashAdjustmentDTO { public decimal Amount { get; set; } public string Description { get; set; } = ""; }
    public class RevenueAdjustmentDTO { public decimal Amount { get; set; } public DateTime Date { get; set; } }
}