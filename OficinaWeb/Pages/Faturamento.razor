@page "/faturamento"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config
@using System.Net.Http.Json
@using System.Text.Json
@using OficinaWeb.Models

<PageTitle>Financeiro e Caixa - FREITAS AUTOCENTER</PageTitle>

<div class="container-fluid py-4 px-4 no-print">
    @if (isPeriodMismatch)
    {
        <div class="alert alert-warning border-warning d-flex align-items-center mb-4 shadow-sm" style="background: rgba(255, 193, 7, 0.1); color: #ffc107;">
            <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
            <div>
                <strong class="d-block text-uppercase">Atenção: Modo de Operação Manual</strong>
                Você está visualizando o período de <strong>@MesNome(activeMonth)/@activeYear</strong>.
            </div>
        </div>
    }

    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("/")'>
                <i class="bi bi-arrow-left me-2"></i>Voltar
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #28a745;">
                <i class="bi bi-wallet2 me-2"></i>Fechamento: @MesNome(activeMonth)/@activeYear
            </h2>
        </div>
        <div class="col-md-3 text-end">
            <button class="btn btn-outline-success fw-bold" @onclick="CarregarDados" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>ATUALIZAR
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="text-white-50 mt-2">Sincronizando fluxo do período ativo...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #28a745 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-cash-coin mb-2 d-block text-success fs-1"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Dinheiro na Gaveta</h6>
                        <h2 class="text-white fw-bold mb-3">R$ @totalDinheiro.ToString("N2")</h2>
                        <button class="btn btn-sm btn-outline-danger w-100" @onclick="ZerarGaveta">Retirada Total</button>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #0dcaf0 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-phone-vibrate mb-2 d-block text-info fs-1"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">PIX (@MesNome(activeMonth))</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalPix.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #ffc107 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-credit-card-fill mb-2 d-block text-warning fs-1"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Crédito (@MesNome(activeMonth))</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalCredito.ToString("N2")</h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-top: 4px solid #fd7e14 !important;">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-credit-card-2-front mb-2 d-block text-primary fs-1"></i>
                        <h6 class="text-white-50 text-uppercase small fw-bold">Débito (@MesNome(activeMonth))</h6>
                        <h2 class="text-white fw-bold mb-0">R$ @totalDebito.ToString("N2")</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-secondary shadow-sm" style="background: #0a0a0a;">
                    <div class="card-header border-secondary bg-transparent py-3">
                        <h5 class="mb-0 fw-bold text-white"><i class="bi bi-bar-chart-line-fill me-2"></i>Resumo Competência</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3 pb-3 border-bottom border-secondary">
                            <span class="text-white-50 d-block mb-1">Recebido no Mês:</span>
                            <span class="text-success fw-bold fs-4">R$ @faturamentoTotal.ToString("N2")</span>
                        </div>
                        <div class="mb-1">
                            <span class="text-danger fw-bold d-block small"><i class="bi bi-exclamation-triangle-fill me-1"></i>INADIMPLÊNCIA:</span>
                            <span class="text-danger fw-bold fs-5">R$ @totalInadimplencia.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card border-secondary shadow-sm h-100" style="background: #0a0a0a;">
                    <div class="card-header border-secondary bg-transparent py-3">
                        <h5 class="mb-0 fw-bold text-white"><i class="bi bi-receipt-cutoff me-2"></i>Histórico do Ciclo</h5>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-dark table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>O.S.</th>
                                    <th>Cliente</th>
                                    <th>Data Real</th>
                                    <th class="text-center">Forma</th>
                                    <th class="text-end">Valor Pago</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transacoesRecentes.Any())
                                {
                                    @foreach (var t in transacoesRecentes)
                                    {
                                        <tr @onclick="() => AbrirDetalhes(t)" style="cursor:pointer;">
                                            <td class="text-warning fw-bold">#@t.Id</td>
                                            <td>@t.Cliente</td>
                                            <td class="text-white-50">@t.DataPagamento.ToString("dd/MM HH:mm")</td>
                                            <td class="text-center"><span class="badge @GetBadgeClass(t.Forma)">@t.Forma</span></td>
                                            <td class="text-end fw-bold">R$ @t.ValorPago.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="5" class="text-center py-5 text-white-50">Nenhuma movimentação para @MesNome(activeMonth).</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (mostrarModalDetalhes && transacaoSelecionada != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold text-info"><i class="bi bi-receipt me-2"></i>Detalhes</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharDetalhes"></button>
                </div>
                <div class="modal-body text-center">
                    <h4 class="text-white mb-0">@transacaoSelecionada.Cliente</h4>
                    <p class="text-warning mb-4">Ordem de Serviço #@transacaoSelecionada.Id</p>
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="p-3 bg-black rounded">
                                <small class="text-muted d-block">TOTAL O.S.</small>
                                <strong>R$ @transacaoSelecionada.ValorTotal.ToString("N2")</strong>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-black rounded">
                                <small class="text-success d-block">VALOR PAGO</small>
                                <strong class="text-success">R$ @transacaoSelecionada.ValorPago.ToString("N2")</strong>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-outline-light w-100" @onclick="FecharDetalhes">Fechar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string ApiUrl = "";
    private bool isLoading = true, mostrarToast, mostrarModalDetalhes, isPeriodMismatch;
    private int activeMonth, activeYear;
    private decimal faturamentoTotal, totalDinheiro, totalPix, totalCredito, totalDebito, totalInadimplencia;
    private string toastMensagem = "", toastTipo = "sucesso";
    private List<TransacaoVisao> transacoesRecentes = new();
    private TransacaoVisao? transacaoSelecionada;

    protected override async Task OnInitializedAsync()
    {
        ApiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7082";
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        try
        {
            isLoading = true;
            
            var settings = await Http.GetFromJsonAsync<JsonElement>($"{ApiUrl}/api/settings");
            activeMonth = GetInt(settings, "activeMonth");
            activeYear = GetInt(settings, "activeYear");
            isPeriodMismatch = (activeMonth != DateTime.Now.Month || activeYear != DateTime.Now.Year);

            var summary = await Http.GetFromJsonAsync<FinancialSummaryDTO>($"{ApiUrl}/api/serviceorders/financial-summary");
            if (summary != null)
            {
                faturamentoTotal = summary.FaturamentoTotal;
                totalInadimplencia = summary.Inadimplencia;
                totalPix = summary.TotalPix;
                totalCredito = summary.TotalCredito;
                totalDebito = summary.TotalDebito;
            }

            totalDinheiro = await Http.GetFromJsonAsync<decimal>($"{ApiUrl}/api/serviceorders/cash-balance");

            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders/periodo?mes={activeMonth}&ano={activeYear}") ?? new();
            transacoesRecentes = osList
                .Where(x => GetString(x, "status") == "Completed")
                .Select(os => MapearTransacao(os))
                .OrderByDescending(t => t.DataPagamento)
                .ToList();
        }
        catch { }
        finally { isLoading = false; StateHasChanged(); }
    }

    private TransacaoVisao MapearTransacao(JsonElement os)
    {
        decimal pago = GetDecimal(os, "amountPaid");
        decimal total = GetDecimal(os, "totalAmount");
        string cliente = "Consumidor";

        if (os.TryGetProperty("vehicle", out var vh) && vh.ValueKind != JsonValueKind.Null)
            cliente = GetString(vh, "customerName");

        return new TransacaoVisao
        {
            Id = GetInt(os, "id"),
            Cliente = cliente,
            DataPagamento = DateTime.TryParse(GetString(os, "completionDate"), out var dt) ? dt : DateTime.Now,
            Forma = GetString(os, "paymentMethod").ToUpper(),
            ValorPago = pago,
            ValorTotal = total,
            FaltaPagar = Math.Max(0, total - pago)
        };
    }

    private string GetString(JsonElement el, string name)
    {
        if (el.TryGetProperty(name, out var p)) return p.ToString();
        string pascal = char.ToUpper(name[0]) + name.Substring(1);
        return el.TryGetProperty(pascal, out p) ? p.ToString() : "";
    }

    private int GetInt(JsonElement el, string name)
    {
        if (el.TryGetProperty(name, out var p) && p.ValueKind != JsonValueKind.Null) return p.GetInt32();
        string pascal = char.ToUpper(name[0]) + name.Substring(1);
        return (el.TryGetProperty(pascal, out p) && p.ValueKind != JsonValueKind.Null) ? p.GetInt32() : 0;
    }

    private decimal GetDecimal(JsonElement el, string name)
    {
        if (el.TryGetProperty(name, out var p) && p.ValueKind != JsonValueKind.Null) return p.GetDecimal();
        string pascal = char.ToUpper(name[0]) + name.Substring(1);
        return (el.TryGetProperty(pascal, out p) && p.ValueKind != JsonValueKind.Null) ? p.GetDecimal() : 0;
    }

    private string GetBadgeClass(string forma) => forma switch
    {
        "DINHEIRO" => "bg-success",
        "PIX" => "bg-info text-dark",
        "CRÉDITO" or "CREDITO" => "bg-warning text-dark",
        "DÉBITO" or "DEBITO" => "bg-primary",
        _ => "bg-secondary"
    };

    private void AbrirDetalhes(TransacaoVisao t) { transacaoSelecionada = t; mostrarModalDetalhes = true; }
    private void FecharDetalhes() { mostrarModalDetalhes = false; transacaoSelecionada = null; }
    private string MesNome(int m) => System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m > 0 && m <= 12 ? m : 1).ToUpper();

    private async Task ZerarGaveta()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Confirmar retirada total do dinheiro em espécie?"))
        {
            var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/cash-adjustment", new CashAdjustmentDTO { Amount = -totalDinheiro, Description = "Retirada Total (Zerar Gaveta)" });
            if (res.IsSuccessStatusCode) await CarregarDados();
        }
    }

    public class FinancialSummaryDTO { public decimal FaturamentoTotal { get; set; } public decimal Inadimplencia { get; set; } public decimal TotalPix { get; set; } public decimal TotalCredito { get; set; } public decimal TotalDebito { get; set; } }
    public class TransacaoVisao { public int Id { get; set; } public string Cliente { get; set; } = ""; public DateTime DataPagamento { get; set; } public string Forma { get; set; } = ""; public decimal ValorPago { get; set; } public decimal ValorTotal { get; set; } public decimal FaltaPagar { get; set; } }
    public class CashAdjustmentDTO { public decimal Amount { get; set; } public string Description { get; set; } = ""; }
}