@page "/relatorios"
@inject HttpClient Http
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Estatísticas Avançadas - FREITAS AUTOCENTER</PageTitle>

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h1 class="fw-bold mb-1" style="color: #ff6600; letter-spacing: -1px;">DASHBOARD EXECUTIVO <span class="text-white-50 fw-light">@selectedYear</span></h1>
            <p class="text-white-50 mb-0">Análise de performance por competência mensal</p>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-calendar3"></i></span>
                <select class="form-select bg-dark text-white border-secondary fw-bold" @onchange="OnMonthChanged" style="min-width: 150px;">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i" selected="@(i == selectedMonth)">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(i).ToUpper()</option>
                    }
                </select>
            </div>
            <a href="/" class="btn btn-outline-secondary px-4 fw-bold">SAIR</a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center py-5">
            <div class="spinner-grow text-warning" role="status"></div>
            <span class="text-white-50 mt-3 text-uppercase small ls-2">Processando base de dados...</span>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #198754 !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Receita Bruta</h6>
                        <h2 class="text-white fw-bold mb-1">@faturamentoMensal.ToString("C2")</h2>
                        <small class="text-success"><i class="bi bi-graph-up me-1"></i>Total do período</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #0d6efd !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Volume de Fluxo</h6>
                        <h2 class="text-white fw-bold mb-1">@carrosResolvidos</h2>
                        <small class="text-primary"><i class="bi bi-check2-circle me-1"></i>O.S. Finalizadas</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #ffc107 !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Média Diária</h6>
                        <h2 class="text-white fw-bold mb-1">@((faturamentoMensal / DateTime.DaysInMonth(selectedYear, selectedMonth)).ToString("C2"))</h2>
                        <small class="text-warning"><i class="bi bi-calculator me-1"></i>Projeção p/ dia</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #6c757d !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Conversão PIX</h6>
                        <h2 class="text-white fw-bold mb-1">@totalPix.ToString("C2")</h2>
                        <small class="text-secondary"><i class="bi bi-lightning-charge me-1"></i>Recebimento instantâneo</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-lg-8">
                <div class="card border-0 p-4 shadow-lg h-100" style="background: #0d0d0d; border: 1px solid #222 !important;">
                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <h5 class="text-white mb-0 text-uppercase small fw-bold">Frequência de Faturamento por Dia</h5>
                        <i class="bi bi-info-circle text-white-50" title="Distribuição baseada no dia real de conclusão"></i>
                    </div>
                    <div class="d-flex align-items-end gap-1 pb-2" style="height: 220px; border-bottom: 1px solid #333;">
                        @foreach (var dia in faturamentoDiario)
                        {
                            <div class="flex-grow-1 text-center group-bar" style="min-width: 15px;">
                                <div class="chart-bar" 
                                     style="height: @(CalcularAltura(dia.Valor))px;" 
                                     title="Dia @dia.Dia: @dia.Valor.ToString("C2")">
                                </div>
                            </div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-3 px-1 text-white-50 x-small fw-bold">
                        <span>DIA 01</span>
                        <span>DISTRIBUIÇÃO POR DATA REAL</span>
                        <span>FECHAMENTO</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 p-4 shadow-lg h-100" style="background: #0d0d0d; border: 1px solid #222 !important;">
                    <h5 class="text-white mb-4 text-uppercase small fw-bold">Divisão por Meio</h5>
                    <div class="mt-2">
                        <div class="mb-4">
                            <div class="d-flex justify-content-between text-white-50 mb-1 small"><span>Cartão de Crédito</span><span>@((faturamentoMensal > 0 ? (totalCredito / faturamentoMensal) : 0).ToString("P0"))</span></div>
                            <div class="progress" style="height: 8px; background: #222;"><div class="progress-bar bg-primary" style="width: @((faturamentoMensal > 0 ? (totalCredito / faturamentoMensal) * 100 : 0).ToString("0"))%"></div></div>
                        </div>
                        <div class="mb-4">
                            <div class="d-flex justify-content-between text-white-50 mb-1 small"><span>Dinheiro Vivo</span><span>@((faturamentoMensal > 0 ? (totalDinheiro / faturamentoMensal) : 0).ToString("P0"))</span></div>
                            <div class="progress" style="height: 8px; background: #222;"><div class="progress-bar bg-success" style="width: @((faturamentoMensal > 0 ? (totalDinheiro / faturamentoMensal) * 100 : 0).ToString("0"))%"></div></div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between text-white-50 mb-1 small"><span>PIX / Outros</span><span>@((faturamentoMensal > 0 ? (totalPix / faturamentoMensal) : 0).ToString("P0"))</span></div>
                            <div class="progress" style="height: 8px; background: #222;"><div class="progress-bar bg-info" style="width: @((faturamentoMensal > 0 ? (totalPix / faturamentoMensal) * 100 : 0).ToString("0"))%"></div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 p-4 shadow-lg mb-5" style="background: #0d0d0d; border: 1px solid #222 !important;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-white mb-0 text-uppercase small fw-bold">Histórico Geral de Encerramentos</h5>
                <span class="badge bg-dark border border-secondary text-white-50 px-3 py-2">@ordensNoMes.Count Registros na Competência</span>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="text-white-50 text-uppercase x-small border-secondary">
                        <tr>
                            <th class="py-3">Status</th>
                            <th class="py-3">Data Real</th>
                            <th class="py-3">Proprietário / Cliente</th>
                            <th class="py-3">Veículo</th>
                            <th class="py-3 text-end">Investimento Total</th>
                        </tr>
                    </thead>
                    <tbody class="border-0">
                        @foreach (var os in ordensNoMes)
                        {
                            <tr class="border-secondary">
                                <td><span class="badge rounded-pill bg-success-subtle text-success border border-success" style="font-size: 0.65rem;">CONCLUÍDO</span></td>
                                <td class="small">@os.Data.ToString("dd/MM/yyyy")</td>
                                <td class="fw-bold">@os.Cliente</td>
                                <td class="text-white-50">@os.Veiculo</td>
                                <td class="text-end fw-bold">@os.Total.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!ordensNoMes.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-folder2-open display-1 text-white-50 opacity-25"></i>
                        <p class="text-white-50 mt-3">Nenhum dado financeiro encontrado para o mês de @System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(selectedMonth).</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .x-small { font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; }
    .chart-bar { 
        background: linear-gradient(180deg, #ffc107 0%, #ff6600 100%); 
        border-radius: 4px 4px 0 0; 
        width: 100%;
        opacity: 0.8;
        transition: all 0.3s;
    }
    .chart-bar:hover { opacity: 1; transform: scaleX(1.1); cursor: crosshair; filter: brightness(1.2); }
    .table-hover tbody tr:hover { background-color: #151515 !important; }
    .ls-2 { letter-spacing: 2px; }
</style>

@code {
    private bool isLoading = true;
    private int selectedMonth, selectedYear;
    private decimal faturamentoMensal, totalPix, totalCredito, totalDinheiro;
    private int carrosResolvidos;
    private List<DiaValor> faturamentoDiario = new();
    private List<OSSimple> ordensNoMes = new();
    private string ApiUrl = "https://localhost:7082";

    protected override async Task OnInitializedAsync() 
    {
        await CarregarPeriodoAtivo();
        await LoadData();
    }

    private async Task CarregarPeriodoAtivo()
    {
        try 
        {
            var settings = await Http.GetFromJsonAsync<JsonElement>($"{ApiUrl}/api/settings");
            selectedMonth = settings.GetProperty("activeMonth").GetInt32();
            selectedYear = settings.GetProperty("activeYear").GetInt32();
        }
        catch 
        {
            selectedMonth = DateTime.Now.Month;
            selectedYear = DateTime.Now.Year;
        }
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        selectedMonth = int.Parse(e.Value?.ToString() ?? "1");
        await LoadData();
    }

    private async Task LoadData()
    {
        try 
        {
            isLoading = true;
            var osList = await Http.GetFromJsonAsync<List<JsonElement>>($"{ApiUrl}/api/serviceorders") ?? new();
            
            faturamentoMensal = 0; totalPix = 0; totalCredito = 0; totalDinheiro = 0;
            ordensNoMes.Clear();

            // FILTRO INTELIGENTE: Prioriza o novo campo contábil
            var filtradas = osList.Where(x => 
            {
                if (x.TryGetProperty("status", out var s) && s.ToString() == "Completed")
                {
                    // Tenta filtrar por accountingMonth/Year (Competência Contábil)
                    if (x.TryGetProperty("accountingMonth", out var am) && am.ValueKind != JsonValueKind.Null &&
                        x.TryGetProperty("accountingYear", out var ay) && ay.ValueKind != JsonValueKind.Null)
                    {
                        return am.GetInt32() == selectedMonth && ay.GetInt32() == selectedYear;
                    }
                    
                    // Fallback para O.S. antigas que não têm o campo novo
                    if (x.TryGetProperty("completionDate", out var d) && d.ValueKind != JsonValueKind.Null)
                    {
                        var dt = d.GetDateTime();
                        return dt.Month == selectedMonth && dt.Year == selectedYear;
                    }
                }
                return false;
            }).ToList();

            carrosResolvidos = filtradas.Count;

            foreach (var os in filtradas)
            {
                decimal valor = os.TryGetProperty("amountPaid", out var v) ? v.GetDecimal() : 0;
                string metodo = os.TryGetProperty("paymentMethod", out var p) ? p.ToString().ToUpper() : "";

                faturamentoMensal += valor;
                if (metodo == "PIX") totalPix += valor;
                else if (metodo.Contains("CREDITO") || metodo.Contains("CRÉDITO")) totalCredito += valor;
                else if (metodo == "DINHEIRO") totalDinheiro += valor;

                string cliente = "Consumidor";
                string veiculo = "Geral";
                if (os.TryGetProperty("vehicle", out var vh))
                {
                    cliente = vh.TryGetProperty("customerName", out var cn) ? cn.ToString() : "Sem Nome";
                    veiculo = vh.TryGetProperty("model", out var mod) ? mod.ToString() : "Sem Modelo";
                }

                ordensNoMes.Add(new OSSimple {
                    Data = os.GetProperty("completionDate").GetDateTime(),
                    Cliente = cliente,
                    Veiculo = veiculo,
                    Total = valor
                });
            }

            faturamentoDiario = Enumerable.Range(1, DateTime.DaysInMonth(selectedYear, selectedMonth))
                .Select(dia => new DiaValor { 
                    Dia = dia, 
                    Valor = filtradas.Where(f => f.GetProperty("completionDate").GetDateTime().Day == dia)
                                     .Sum(f => f.TryGetProperty("amountPaid", out var ap) ? ap.GetDecimal() : 0) 
                }).ToList();
        }
        catch { } 
        finally { isLoading = false; StateHasChanged(); }
    }

    private int CalcularAltura(decimal valor) 
    {
        var max = faturamentoDiario.Any() ? faturamentoDiario.Max(d => d.Valor) : 0;
        return max == 0 ? 0 : (int)((valor / max) * 180);
    }

    public class DiaValor { public int Dia { get; set; } public decimal Valor { get; set; } }
    public class OSSimple { public DateTime Data { get; set; } public string Cliente { get; set; } = ""; public string Veiculo { get; set; } = ""; public decimal Total { get; set; } }
}