@page "/relatorios"
@inject HttpClient Http
@inject IConfiguration Config
@using System.Net.Http.Json
@using System.Text.Json
@using OficinaWeb.Models

<PageTitle>Estatísticas Avançadas - FREITAS AUTOCENTER</PageTitle>

<div class="container-fluid py-4 px-lg-5">
    @* Header *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h1 class="fw-bold mb-1" style="color: #ff6600; letter-spacing: -1px;">DASHBOARD EXECUTIVO <span class="text-white-50 fw-light">@selectedYear</span></h1>
            <p class="text-white-50 mb-0">Performance por Ciclo de Trabalho (Competência)</p>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-calendar3"></i></span>
                <select class="form-select bg-dark text-white border-secondary fw-bold" @onchange="OnMonthChanged" style="min-width: 150px;">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i" selected="@(i == selectedMonth)">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(i).ToUpper()</option>
                    }
                </select>
            </div>
            <a href="/" class="btn btn-outline-secondary px-4 fw-bold">SAIR</a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center py-5">
            <div class="spinner-grow text-warning" role="status"></div>
            <span class="text-white-50 mt-3 text-uppercase small ls-2">Sincronizando cronologia financeira...</span>
        </div>
    }
    else
    {
        @* Cards de Resumo *@
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #198754 !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Receita do Ciclo</h6>
                        <h2 class="text-white fw-bold mb-1">@faturamentoMensal.ToString("C2")</h2>
                        <small class="text-success"><i class="bi bi-graph-up me-1"></i>Total apurado</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #0d6efd !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Volume de Fluxo</h6>
                        <h2 class="text-white fw-bold mb-1">@carrosResolvidos</h2>
                        <small class="text-primary"><i class="bi bi-check2-circle me-1"></i>O.S. Finalizadas</small>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm card-clickable" @onclick="() => showProductModal = true" style="background: #111; border-bottom: 3px solid #ffc107 !important; cursor: pointer;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="text-white-50 text-uppercase x-small mb-3">Total Saídas (O.S.)</h6>
                                <h2 class="text-white fw-bold mb-1">@totalSaidasEstoque.ToString("C2")</h2>
                            </div>
                            <i class="bi bi-search text-warning opacity-50"></i>
                        </div>
                        <small class="text-warning"><i class="bi bi-box-seam me-1"></i>Produtos com código</small>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm" style="background: #111; border-bottom: 3px solid #6c757d !important;">
                    <div class="card-body p-4">
                        <h6 class="text-white-50 text-uppercase x-small mb-3">Conversão PIX</h6>
                        <h2 class="text-white fw-bold mb-1">@totalPix.ToString("C2")</h2>
                        <small class="text-secondary"><i class="bi bi-lightning-charge me-1"></i>Recebimento instantâneo</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-lg-8">
                <div class="card border-0 p-4 shadow-lg h-100" style="background: #0d0d0d; border: 1px solid #222 !important;">
                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <h5 class="text-white mb-0 text-uppercase small fw-bold">Faturamento por Sequência Cronológica</h5>
                        <i class="bi bi-info-circle text-white-50" title="Ordenado pela data real de conclusão dentro deste ciclo"></i>
                    </div>
                    <div class="d-flex align-items-end gap-1 pb-2" style="height: 220px; border-bottom: 1px solid #333; overflow-x: auto;">
                        @if (faturamentoDiario.Any())
                        {
                            @foreach (var ponto in faturamentoDiario)
                            {
                                <div class="flex-grow-1 text-center group-bar" style="min-width: 35px;">
                                    <div class="chart-bar" 
                                         style="height: @(CalcularAltura(ponto.Valor))px;" 
                                         title="Data @ponto.DataRotulo: @ponto.Valor.ToString("C2")">
                                    </div>
                                    <small class="text-white-50 d-block mt-2" style="font-size: 0.6rem; white-space: nowrap;">@ponto.DataRotulo</small>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="w-100 text-center text-white-50 mb-5 py-5">Nenhum lançamento registrado para este período.</div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-3 px-1 text-white-50 x-small fw-bold">
                        <span>INÍCIO (@(faturamentoDiario.FirstOrDefault()?.DataRotulo ?? "--/--"))</span>
                        <span class="text-warning">ORDEM DE LANÇAMENTO</span>
                        <span>FIM (@(faturamentoDiario.LastOrDefault()?.DataRotulo ?? "--/--"))</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 p-4 shadow-lg h-100" style="background: #0d0d0d; border: 1px solid #222 !important;">
                    <h5 class="text-white mb-4 text-uppercase small fw-bold">Divisão por Meio</h5>
                    <div class="mt-2">
                        <div class="mb-4">
                            <div class="d-flex justify-content-between text-white-50 mb-1 small"><span>Cartão de Crédito</span><span>@((faturamentoMensal > 0 ? (totalCredito / faturamentoMensal) : 0).ToString("P0"))</span></div>
                            <div class="progress" style="height: 8px; background: #222;"><div class="progress-bar bg-primary" style="width: @((faturamentoMensal > 0 ? (totalCredito / faturamentoMensal) * 100 : 0).ToString("0"))%"></div></div>
                        </div>
                        <div class="mb-4">
                            <div class="d-flex justify-content-between text-white-50 mb-1 small"><span>Dinheiro Vivo</span><span>@((faturamentoMensal > 0 ? (totalDinheiro / faturamentoMensal) : 0).ToString("P0"))</span></div>
                            <div class="progress" style="height: 8px; background: #222;"><div class="progress-bar bg-success" style="width: @((faturamentoMensal > 0 ? (totalDinheiro / faturamentoMensal) * 100 : 0).ToString("0"))%"></div></div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between text-white-50 mb-1 small"><span>PIX / Outros</span><span>@((faturamentoMensal > 0 ? (totalPix / faturamentoMensal) : 0).ToString("P0"))</span></div>
                            <div class="progress" style="height: 8px; background: #222;"><div class="progress-bar bg-info" style="width: @((faturamentoMensal > 0 ? (totalPix / faturamentoMensal) * 100 : 0).ToString("0"))%"></div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 p-4 shadow-lg mb-5" style="background: #0d0d0d; border: 1px solid #222 !important;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-white mb-0 text-uppercase small fw-bold">Histórico Geral do Ciclo</h5>
                <span class="badge bg-dark border border-secondary text-white-50 px-3 py-2">@ordensNoMes.Count Registros</span>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="text-white-50 text-uppercase x-small border-secondary">
                        <tr>
                            <th class="py-3">Status</th>
                            <th class="py-3">Data Real</th>
                            <th class="py-3">Proprietário / Cliente</th>
                            <th class="py-3">Veículo</th>
                            <th class="py-3 text-end">Investimento Total</th>
                        </tr>
                    </thead>
                    <tbody class="border-0">
                        @foreach (var os in ordensNoMes)
                        {
                            <tr class="border-secondary">
                                <td><span class="badge rounded-pill bg-success-subtle text-success border border-success" style="font-size: 0.65rem;">CONCLUÍDO</span></td>
                                <td class="small">@(os.CompletionDate?.ToString("dd/MM/yyyy HH:mm") ?? "--")</td>
                                <td class="fw-bold">@(os.Vehicle?.CustomerName ?? "Consumidor")</td>
                                <td class="text-white-50">@(os.Vehicle?.Model ?? "Geral")</td>
                                <td class="text-end fw-bold">@os.TotalAmount.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (showProductModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary shadow-lg">
                <div class="modal-header border-secondary p-4">
                    <h5 class="modal-title fw-bold text-warning d-flex align-items-center">
                        <i class="bi bi-box-seam me-2"></i> DETALHAMENTO DE SAÍDAS DE ESTOQUE
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showProductModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="table-responsive" style="max-height: 500px;">
                        <table class="table table-dark table-hover mb-0">
                            <thead class="sticky-top bg-dark text-white-50 x-small text-uppercase border-secondary">
                                <tr>
                                    <th class="p-3">Data</th>
                                    <th class="p-3">Produto</th>
                                    <th class="p-3">Cliente</th>
                                    <th class="p-3 text-center">Qtd</th>
                                    <th class="p-3 text-end">Valor Saída</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (produtosSaidaList.Any())
                                {
                                    @foreach (var item in produtosSaidaList.OrderByDescending(i => i.Data))
                                    {
                                        <tr class="border-secondary">
                                            <td class="p-3 small text-white-50">@item.Data.ToString("dd/MM/yy")</td>
                                            <td class="p-3 fw-bold">@item.Descricao</td>
                                            <td class="p-3 small">@item.Cliente</td>
                                            <td class="p-3 text-center"><span class="badge bg-secondary">@item.Quantidade</span></td>
                                            <td class="p-3 text-end fw-bold text-warning">@item.ValorTotal.ToString("C2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-white-50">Nenhum produto com código registrado neste ciclo.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer border-secondary p-3 bg-black">
                    <div class="w-100 d-flex justify-content-between align-items-center">
                        <span class="text-white-50 small">Total acumulado em peças:</span>
                        <h4 class="text-warning fw-bold mb-0">@totalSaidasEstoque.ToString("C2")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .x-small { font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; }
    .chart-bar { 
        background: linear-gradient(180deg, #ffc107 0%, #ff6600 100%); 
        border-radius: 4px 4px 0 0; 
        width: 100%;
        opacity: 0.8;
        transition: all 0.3s;
    }
    .chart-bar:hover { opacity: 1; transform: scaleX(1.1); cursor: crosshair; filter: brightness(1.2); }
    .table-hover tbody tr:hover { background-color: #151515 !important; }
    .ls-2 { letter-spacing: 2px; }
    .card-clickable:hover { transform: translateY(-3px); transition: 0.2s; filter: brightness(1.2); }
</style>

@code {
    private bool isLoading = true, showProductModal = false;
    private int selectedMonth, selectedYear, carrosResolvidos;
    private decimal faturamentoMensal, totalPix, totalCredito, totalDinheiro, totalSaidasEstoque;
    private List<PontoGrafico> faturamentoDiario = new();
    private List<ServiceOrderDTO> ordensNoMes = new();
    private List<ProductExit> produtosSaidaList = new();
    private string ApiUrl = "";

    protected override async Task OnInitializedAsync()
    {
        ApiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7082";
        await InitialLoad();
    }

    private async Task InitialLoad()
    {
        try {
            var settings = await Http.GetFromJsonAsync<SystemSettingsDTO>($"{ApiUrl}/api/settings");
            if (settings != null) { selectedMonth = settings.ActiveMonth; selectedYear = settings.ActiveYear; }
        } catch { selectedMonth = DateTime.Now.Month; selectedYear = DateTime.Now.Year; }
        await LoadData();
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int m)) { selectedMonth = m; await LoadData(); }
    }

    private async Task LoadData()
    {
        try 
        {
            isLoading = true;
            var osList = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/periodo?mes={selectedMonth}&ano={selectedYear}") ?? new();
            
            faturamentoMensal = 0; totalPix = 0; totalCredito = 0; totalDinheiro = 0; totalSaidasEstoque = 0;
            ordensNoMes.Clear(); produtosSaidaList.Clear();

            var filtradas = osList.Where(x => x.Status == "Completed").ToList();
            carrosResolvidos = filtradas.Count;

            foreach (var os in filtradas)
            {
                decimal valor = os.AmountPaid;
                string metodo = (os.PaymentMethod ?? "").ToUpper();
                DateTime dataConclusao = os.CompletionDate ?? DateTime.Now;

                faturamentoMensal += valor;
                if (metodo == "PIX") totalPix += valor;
                else if (metodo.Contains("CREDITO") || metodo.Contains("CRÉDITO")) totalCredito += valor;
                else if (metodo == "DINHEIRO") totalDinheiro += valor;

                if (os.Items != null)
                {
                    foreach (var item in os.Items.Where(i => i.ProductId != null))
                    {
                        totalSaidasEstoque += item.Price;
                        produtosSaidaList.Add(new ProductExit {
                            Data = dataConclusao,
                            Descricao = item.Description,
                            Cliente = os.Vehicle?.CustomerName ?? "Consumidor",
                            Quantidade = item.Quantity,
                            ValorTotal = item.Price
                        });
                    }
                }
                ordensNoMes.Add(os);
            }

            faturamentoDiario = ordensNoMes
                .GroupBy(o => (o.CompletionDate ?? DateTime.Now).Date)
                .Select(g => new PontoGrafico {
                    DataOriginal = g.Key,
                    DataRotulo = g.Key.ToString("dd/MM"),
                    Valor = g.Sum(o => o.AmountPaid)
                })
                .OrderBy(p => p.DataOriginal).ToList();
        }
        catch { } finally { isLoading = false; StateHasChanged(); }
    }

    private int CalcularAltura(decimal valor) {
        var max = faturamentoDiario.Any() ? faturamentoDiario.Max(d => d.Valor) : 0;
        return max == 0 ? 0 : (int)((valor / max) * 180);
    }

    public class ProductExit { public DateTime Data { get; set; } public string Descricao { get; set; } = ""; public string Cliente { get; set; } = ""; public int Quantidade { get; set; } public decimal ValorTotal { get; set; } }
    public class PontoGrafico { public DateTime DataOriginal { get; set; } public string DataRotulo { get; set; } = ""; public decimal Valor { get; set; } }
}