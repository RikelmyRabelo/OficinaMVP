@page "/relatorios"
@inject HttpClient Http
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Relatórios Detalhados - FREITAS AUTOCENTER</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #ff6600;">DASHBOARD E ESTATÍSTICAS</h2>
        <a href="/" class="btn btn-outline-light btn-sm">Voltar</a>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-warning"></div></div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="p-4 rounded-3 border-top border-4 border-success" style="background: #111;">
                    <h6 class="text-white-50 text-uppercase small">Faturamento Histórico (Total)</h6>
                    <h2 class="text-white fw-bold">@faturamentoHistorico.ToString("C2")</h2>
                    <p class="text-success small mb-0"><i class="bi bi-clock-history me-1"></i>Desde o início do sistema</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-4 rounded-3 border-top border-4 border-primary" style="background: #111;">
                    <h6 class="text-white-50 text-uppercase small">Ticket Médio por O.S.</h6>
                    <h2 class="text-white fw-bold">@ticketMedio.ToString("C2")</h2>
                    <p class="text-primary small mb-0"><i class="bi bi-calculator me-1"></i>Baseado em @totalOSFinalizadas ordens</p>
                </div>
            </div>
        </div>

        <div class="card border-0 p-4 mb-4" style="background: #111;">
            <h5 class="text-white mb-4">Faturamento Mensal (Comparativo)</h5>
            <div class="d-flex align-items-end gap-3" style="height: 200px;">
                @foreach (var mes in faturamentoPorMes)
                {
                    <div class="flex-grow-1 text-center">
                        <div class="bg-warning rounded-top" style="height: @(CalcularAlturaBarra(mes.Valor))%; transition: height 1s;"></div>
                        <small class="text-white-50 d-block mt-2">@mes.Nome</small>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private decimal faturamentoHistorico;
    private decimal ticketMedio;
    private int totalOSFinalizadas;
    private List<MesFaturamento> faturamentoPorMes = new();
    private string ApiUrl = "https://localhost:7082/api/serviceorders";

    protected override async Task OnInitializedAsync() => await CarregarRelatorios();

    private async Task CarregarRelatorios()
    {
        try
        {
            isLoading = true;
            var osList = await Http.GetFromJsonAsync<List<JsonElement>>(ApiUrl) ?? new();
            
            var finalizadas = osList.Where(x => x.TryGetProperty("status", out var s) && s.ToString() == "Completed").ToList();
            
            totalOSFinalizadas = finalizadas.Count;
            faturamentoHistorico = finalizadas.Sum(x => x.TryGetProperty("amountPaid", out var t) ? t.GetDecimal() : 0);
            ticketMedio = totalOSFinalizadas > 0 ? faturamentoHistorico / totalOSFinalizadas : 0;

            faturamentoPorMes = finalizadas
                .GroupBy(x => x.TryGetProperty("completionDate", out var d) ? d.GetDateTime().ToString("MMM") : "S/D")
                .Select(g => new MesFaturamento { Nome = g.Key, Valor = g.Sum(x => x.TryGetProperty("amountPaid", out var v) ? v.GetDecimal() : 0) })
                .ToList();

        }
        catch { }
        finally { isLoading = false; }
    }

    private int CalcularAlturaBarra(decimal valor)
    {
        if (faturamentoHistorico == 0) return 0;
        return (int)((valor / faturamentoHistorico) * 100) + 10;
    }

    public class MesFaturamento { public string Nome { get; set; } = ""; public decimal Valor { get; set; } }
}