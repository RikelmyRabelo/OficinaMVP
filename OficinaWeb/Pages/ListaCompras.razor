@page "/lista-compras"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="container mt-4 no-print">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase" style="color: #ff6600;">
            <i class="bi bi-cart-check me-2"></i>Lista de Compras
        </h2>
        <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("estoque")'>
            <i class="bi bi-arrow-left me-2"></i>Voltar ao Estoque
        </button>
    </div>

    <div class="row g-4">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Peças do Sistema</h5>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-dark border-secondary text-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Pesquisar peça..." @bind-value="searchTerm" @bind-value:event="oninput" />
                    </div>

                    <div style="max-height: 500px; overflow-y: auto;">
                        <table class="table table-dark table-hover align-middle">
                            <thead>
                                <tr class="text-secondary">
                                    <th>Peça</th>
                                    <th class="text-center">Qtd Atual</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (allProducts != null)
                                {
                                    @foreach (var p in filteredProducts)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-white">@p.name</div>
                                                <small class="text-muted">Cód: @p.code</small>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @(p.stockQuantity <= 0 ? "bg-danger" : (p.stockQuantity <= 3 ? "bg-warning text-dark" : "bg-success"))">
                                                    @p.stockQuantity
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-warning fw-bold" @onclick="() => AddToList(p.name)">
                                                    <i class="bi bi-plus-lg"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm mb-4" style="background-color: #111; border-top: 4px solid #00ffff !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #00ffff;">Item não cadastrado</h5>
                    <div class="input-group">
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Ex: Estopa..." @bind="newItemName" @onkeyup="HandleKeyUp" />
                        <button class="btn btn-info fw-bold" @onclick="AddManualItem">ADD</button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm" style="background-color: #111; border-top: 4px solid #ff6600 !important;">
                <div class="card-header bg-transparent border-secondary d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0 fw-bold text-white">Sua Lista</h5>
                    <button class="btn btn-light btn-sm fw-bold" @onclick="ImprimirLista" disabled="@(!listaParaComprar.Any())">
                        <i class="bi bi-printer-fill me-1"></i>PDF / IMPRIMIR
                    </button>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush bg-transparent">
                        @if (!listaParaComprar.Any())
                        {
                            <li class="list-group-item bg-transparent text-muted text-center py-4">Nenhum item selecionado.</li>
                        }
                        @foreach (var item in listaParaComprar)
                        {
                            <li class="list-group-item bg-transparent text-white d-flex justify-content-between align-items-center border-secondary">
                                <div><i class="bi bi-dot text-warning me-1"></i>@item</div>
                                <button class="btn btn-sm text-danger" @onclick="() => RemoverDaLista(item)">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@* AREA DE IMPRESSAO *@
<div id="print-area" class="d-none d-print-block p-4" style="color: black !important; background: white !important;">
    <div class="text-center mb-4">
        <h2>FREITAS AUTOCENTER</h2>
        <h4>RELATÓRIO DE COMPRAS E REPOSIÇÃO</h4>
        <hr style="border: 1px solid black;" />
    </div>
    <table class="table table-bordered border-dark">
        <thead>
            <tr>
                <th style="width: 50px; text-align: center;">[ ]</th>
                <th>DESCRIÇÃO DO ITEM</th>
                <th style="width: 150px; text-align: center;">QTD / OBS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in listaParaComprar)
            {
                <tr>
                    <td style="text-align: center;">☐</td>
                    <td style="padding: 10px;">@item</td>
                    <td></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    public class LocalProduct
    {
        public string code { get; set; } = "";
        public string name { get; set; } = "";
        public int stockQuantity { get; set; }
    }

    private List<LocalProduct> allProducts = new();
    private List<string> listaParaComprar = new();
    private string searchTerm = "";
    private string newItemName = "";

    private List<LocalProduct> filteredProducts => allProducts?
        .Where(p => string.IsNullOrEmpty(searchTerm) ||
               (p.name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (p.code?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allProducts = await Http.GetFromJsonAsync<List<LocalProduct>>("https://localhost:7082/api/products") ?? new();
        }
        catch { }
    }

    private void AddToList(string name) { if (!string.IsNullOrEmpty(name) && !listaParaComprar.Contains(name)) listaParaComprar.Add(name); }
    private void AddManualItem() { if (!string.IsNullOrWhiteSpace(newItemName)) { listaParaComprar.Add(newItemName.ToUpper()); newItemName = ""; } }
    private void HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") AddManualItem(); }
    private void RemoverDaLista(string item) => listaParaComprar.Remove(item);
    private async Task ImprimirLista() => await JS.InvokeVoidAsync("window.print");
}