@page "/lista-compras"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="container mt-4 no-print">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase" style="color: #ff6600;">
            <i class="bi bi-cart-check me-2"></i>Lista de Compras
        </h2>
        <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("estoque")'>
            <i class="bi bi-arrow-left me-2"></i>Voltar ao Estoque
        </button>
    </div>

    <div class="row g-4">
        @* Coluna da Esquerda: Catálogo *@
        <div class="col-md-7">
            <div class="card border-0 shadow-lg" style="background: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Peças do Sistema</h5>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-dark border-secondary text-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Pesquisar peça..." @bind-value="searchTerm" @bind-value:event="oninput" />
                    </div>

                    <div style="max-height: 500px; overflow-y: auto;">
                        <table class="table table-dark table-hover align-middle mb-0">
                            <thead>
                                <tr class="text-white-50 border-secondary">
                                    <th>Peça</th>
                                    <th class="text-center">Qtd Atual</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (allProducts != null)
                                {
                                    @foreach (var p in filteredProducts)
                                    {
                                        <tr class="border-secondary">
                                            <td>
                                                <div class="fw-bold text-white">@p.name</div>
                                                <small class="text-white-50">Cód: @p.code</small>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @(p.stockQuantity <= 0 ? "bg-danger" : (p.stockQuantity <= 3 ? "bg-warning text-dark" : "bg-success text-white"))">
                                                    @p.stockQuantity
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-warning fw-bold" @onclick="() => AddToList(p.name)">
                                                    <i class="bi bi-plus-lg"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* Coluna da Direita *@
        <div class="col-md-5">
            <div class="card border-0 shadow-lg mb-4" style="background: #111; border-top: 4px solid #00ffff !important;">
                <div class="card-body p-4 text-white">
                    <h5 class="mb-3 fw-bold" style="color: #00ffff;">Item não cadastrado</h5>
                    <div class="input-group">
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Ex: Estopa..." @bind="newItemName" @onkeyup="HandleKeyUp" />
                        <button class="btn btn-info fw-bold" @onclick="AddManualItem">ADD</button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-lg" style="background: #111; border-top: 4px solid #ff6600 !important;">
                <div class="card-header bg-transparent border-secondary d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0 fw-bold text-white">Sua Lista</h5>
                    <button class="btn btn-light btn-sm fw-bold shadow-sm" @onclick="ImprimirLista" disabled="@(!listaParaComprar.Any())">
                        <i class="bi bi-printer-fill me-1 text-danger"></i>GERAR PDF
                    </button>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush bg-transparent">
                        @if (!listaParaComprar.Any())
                        {
                            <li class="list-group-item bg-transparent text-white-50 text-center py-4 border-secondary">
                                NENHUM ITEM SELECIONADO
                            </li>
                        }
                        @foreach (var item in listaParaComprar)
                        {
                            <li class="list-group-item bg-transparent text-white d-flex justify-content-between align-items-center border-secondary py-3">
                                <div><i class="bi bi-dot text-warning fs-4 me-1"></i>@item</div>
                                <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => RemoverDaLista(item)">
                                    <i class="bi bi-trash3-fill"></i>
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="print-section" class="d-none d-print-block" style="position: relative; width: 210mm; min-height: 297mm; background-color: white; color: black !important; padding: 20mm; font-family: Arial, sans-serif;">

    @* Cabeçalho Estilizado *@
    <div style="border-bottom: 2px solid black; padding-bottom: 10px; margin-bottom: 20px; text-align: center;">
        <h1 style="margin: 0; font-size: 22pt;">FREITAS AUTOCENTER</h1>
        <h3 style="margin: 5px 0; color: #444;">LISTA DE COMPRAS E REPOSIÇÃO</h3>
        <p style="font-size: 10pt; margin: 0;">Gerado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    @* Corpo da Lista *@
    <div style="width: 100%;">
        <table style="width: 100%; border-collapse: collapse; color: black !important;">
            <thead>
                <tr style="background-color: #eee;">
                    <th style="border: 1px solid black; padding: 10px; width: 60px; text-align: center;">[ OK ]</th>
                    <th style="border: 1px solid black; padding: 10px; text-align: left;">DESCRIÇÃO DO ITEM</th>
                    <th style="border: 1px solid black; padding: 10px; width: 150px; text-align: center;">QTD / OBS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in listaParaComprar)
                {
                    <tr>
                        <td style="border: 1px solid black; padding: 12px; text-align: center; font-size: 14pt;">☐</td>
                        <td style="border: 1px solid black; padding: 12px; font-weight: bold; font-size: 12pt;">@item</td>
                        <td style="border: 1px solid black; padding: 12px;"></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Rodapé de Controle *@
    <div style="position: absolute; bottom: 20mm; left: 20mm; right: 20mm; text-align: center; font-size: 9pt; border-top: 1px solid #ccc; padding-top: 10px; color: #666;">
        Documento de conferência interna - Freitas Autocenter
    </div>
</div>

<style>
    @@media print {
        body {
            background-color: white !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .no-print {
            display: none !important;
        }

        .d-print-block {
            display: block !important;
        }
        table, th, td {
            color: black !important;
            border-color: black !important;
        }
    }
</style>

@code {
    public class LocalProduct
    {
        public string code { get; set; } = "";
        public string name { get; set; } = "";
        public int stockQuantity { get; set; }
    }

    private List<LocalProduct> allProducts = new();
    private List<string> listaParaComprar = new();
    private string searchTerm = "";
    private string newItemName = "";

    private List<LocalProduct> filteredProducts => allProducts?
        .Where(p => string.IsNullOrEmpty(searchTerm) ||
               (p.name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (p.code?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        try { allProducts = await Http.GetFromJsonAsync<List<LocalProduct>>("https://localhost:7082/api/products") ?? new(); }
        catch { }
    }

    private void AddToList(string name) { if (!string.IsNullOrEmpty(name) && !listaParaComprar.Contains(name)) listaParaComprar.Add(name); }
    private void AddManualItem() { if (!string.IsNullOrWhiteSpace(newItemName)) { listaParaComprar.Add(newItemName.ToUpper()); newItemName = ""; } }
    private void HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") AddManualItem(); }
    private void RemoverDaLista(string item) => listaParaComprar.Remove(item);
    private async Task ImprimirLista() => await JS.InvokeVoidAsync("window.print");
}