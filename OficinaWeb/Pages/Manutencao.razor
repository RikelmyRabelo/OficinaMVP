@page "/manutencao"
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Oficina - FJ Centro Automotivo</PageTitle>

<div class="container-fluid py-4 px-4 no-print">
    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <a href="/" class="btn btn-outline-secondary border-0 text-white">
                <i class="bi bi-arrow-left me-2"></i>Voltar para o painel
            </a>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;">
                <i class="bi bi-wrench-adjustable me-2"></i>Gestão de Oficina
            </h2>
        </div>
        <div class="col-md-3"></div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-4" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Nova Ordem de Serviço</h5>
                    <div class="d-flex flex-column gap-3">
                        <input class="form-control bg-dark text-white border-secondary"
                               @bind="novaOsRequest.ClientName" placeholder="Nome do Cliente" />
                        <input class="form-control bg-dark text-white border-secondary"
                               @bind="novaOsRequest.VehicleModel" placeholder="Veículo (Modelo)" />
                        <button class="btn fw-bold w-100"
                                style="background-color: #ffeb3b; color: #000;"
                                @onclick="AbrirOS">
                            ABRIR OS <i class="bi bi-file-earmark-plus ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="d-flex mb-3 gap-2">
                <button class="btn btn-sm flex-grow-1 fw-bold @(mostrarFinalizadas ? "btn-outline-secondary text-white" : "btn-primary")"
                        @onclick="() => mostrarFinalizadas = false">
                    EM ANDAMENTO
                </button>
                <button class="btn btn-sm flex-grow-1 fw-bold @(mostrarFinalizadas ? "btn-primary" : "btn-outline-secondary text-white")"
                        @onclick="() => mostrarFinalizadas = true">
                    FINALIZADAS
                </button>
            </div>

            <div class="list-group shadow-sm" style="max-height: 60vh; overflow-y: auto;">
                @if (listaFiltrada != null)
                {
                    foreach (var os in listaFiltrada)
                    {
                        var isActive = sel?.Id == os.Id;
                        var bgStyle = isActive ? "background-color: #222; border-left: 4px solid #ff6600;" : "background-color: #111; border-left: 4px solid transparent;";

                        <button class="list-group-item list-group-item-action border-secondary text-white mb-2 rounded-0"
                                style="@bgStyle transition: 0.2s;" @onclick="() => Selecionar(os)">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold">@(os.Vehicle?.CustomerName ?? "Cliente N/A")</h6>
                                    <small class="text-warning">@(os.Vehicle?.Model ?? "Veículo N/A")</small>
                                </div>
                                <span class="badge bg-dark border border-secondary">#@os.Id</span>
                            </div>
                        </button>
                    }
                }
            </div>
        </div>

        <div class="col-md-8">
            @if (sel != null)
            {
                <div class="card border-0 shadow-sm h-100" style="background-color: #111; border-top: 4px solid #ff6600 !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-4 border-bottom border-secondary pb-3">
                            <div>
                                <small class="text-white-50">Veículo</small>
                                <h2 class="fw-bold text-white mb-0">@(sel.Vehicle?.Model ?? "-")</h2>
                                <span class="text-warning">Cliente: @(sel.Vehicle?.CustomerName ?? "-")</span>
                            </div>
                            <div class="text-end">
                                <button class="btn btn-light btn-sm fw-bold mb-3" @onclick="ImprimirNota">
                                    <i class="bi bi-printer-fill me-2"></i>IMPRIMIR NOTA / PDF
                                </button>
                                <h1 class="text-success fw-bold mb-0">R$ @sel.TotalAmount.ToString("N2")</h1>
                                <span class="badge @(sel.Status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                    @(sel.Status == "Completed" ? "FINALIZADO" : "EM ANDAMENTO")
                                </span>
                            </div>
                        </div>

                        @if (sel.Status != "Completed")
                        {
                            <div class="p-3 rounded-3 mb-4" style="background-color: #0a0a0a; border: 1px solid #333;">
                                <ul class="nav nav-pills mb-3 gap-2">
                                    <li class="nav-item">
                                        <button class="nav-link btn-sm fw-bold @(tipoItem == "peca" ? "active bg-warning text-dark" : "text-white border border-secondary")"
                                                @onclick='() => tipoItem = "peca"'>
                                            <i class="bi bi-box-seam me-2"></i>PEÇA
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link btn-sm fw-bold @(tipoItem == "servico" ? "active bg-warning text-dark" : "text-white border border-secondary")"
                                                @onclick='() => tipoItem = "servico"'>
                                            <i class="bi bi-tools me-2"></i>MÃO DE OBRA
                                        </button>
                                    </li>
                                </ul>

                                <div class="row g-2 align-items-end">
                                    @if (tipoItem == "peca")
                                    {
                                        <div class="col-md-6">
                                            <label class="text-white-50 small mb-1">Produto do Estoque</label>
                                            <select class="form-select bg-dark text-white border-secondary" @bind="novoItem.ProductId">
                                                <option value="0" selected>Selecione...</option>
                                                @if (produtos != null)
                                                {
                                                    foreach (var p in produtos)
                                                    {
                                                        <option value="@p.id">@p.name (R$ @p.salePrice)</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="text-white-50 small mb-1">Qtd</label>
                                            <input type="number" class="form-control bg-dark text-white border-secondary" @bind="novoItem.Quantity" min="1" />
                                        </div>
                                        <div class="col-md-3">
                                            <button class="btn w-100 fw-bold" style="background-color: #ffeb3b; color: #000;" @onclick="AdicionarItem">ADD PEÇA</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-md-4">
                                            <label class="text-white-50 small mb-1">Descrição do Serviço</label>
                                            <input type="text" class="form-control bg-dark text-white border-secondary"
                                                   @bind="novoServico.Description" placeholder="Ex: Troca de Óleo" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="text-white-50 small mb-1">Mecânico</label>
                                            <select class="form-select bg-dark text-white border-secondary" @bind="novoServico.MechanicId">
                                                <option value="0">Selecione...</option>
                                                @if (mecanicos != null)
                                                {
                                                    foreach (var m in mecanicos)
                                                    {
                                                        <option value="@m.id">@m.name</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-2">
                                            <label class="text-white-50 small mb-1">Valor (R$)</label>
                                            <input type="number" step="0.01" min="0" class="form-control bg-dark text-white border-secondary" @bind="novoServico.Price" />
                                        </div>
                                        <div class="col-md-3">
                                            <button class="btn w-100 fw-bold" style="background-color: #ffeb3b; color: #000;" @onclick="AdicionarServico">ADD SERVIÇO</button>
                                        </div>
                                    }
                                </div>
                                <div class="mt-3 text-end">
                                    <button class="btn btn-outline-success btn-sm fw-bold" @onclick="FinalizarOS">
                                        <i class="bi bi-check-lg me-1"></i> FINALIZAR ORDEM DE SERVIÇO
                                    </button>
                                </div>
                            </div>
                        }

                        <div class="table-responsive">
                            <table class="table table-dark table-hover mb-0" style="background-color: #000;">
                                <thead style="border-bottom: 2px solid #ff6600;">
                                    <tr>
                                        <th style="color: #ff6600;">Tipo</th>
                                        <th style="color: #ff6600;">Descrição / Peça</th>
                                        <th style="color: #ff6600;" class="text-end">Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (sel.Items != null && sel.Items.Any())
                                    {
                                        foreach (var item in sel.Items)
                                        {
                                            <tr>
                                                <td><span class="badge @(item.ProductId != null ? "bg-secondary" : "bg-warning text-dark")">@(item.ProductId != null ? "PEÇA" : "SERVIÇO")</span></td>
                                                <td class="text-white">@item.Description</td>
                                                <td class="text-end text-white fw-bold">R$ @item.Price.ToString("N2")</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (sel != null)
{
    <div id="print-section" class="d-none d-print-block"
         style="background-image: url('images/OrdemServico.png'); background-size: 184mm 267mm; background-repeat: no-repeat;">

        @* CABEÇALHO *@
        <div class="print-data" style="top: 17%; left: 81.5%; font-size: 14pt;">#@sel.Id</div>
        <div class="print-data" style="top: 21%; left: 19.5%;">@sel.Vehicle?.CustomerName</div>
        <div class="print-data" style="top: 26.6%; left: 22%;">@sel.Vehicle?.Model</div>
        <div class="print-data" style="top: 33.9%; left: 30%;">@DateTime.Now.ToString("dd/MM/yyyy")</div>

        @* 1. SEÇÃO DE PRODUTOS/PEÇAS *@
        <div class="print-data" style="top: 42%; left: 20%; width: 73%;">
            @foreach (var item in sel.Items.Where(i => i.ProductId != null))
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 9px;">
                    <span>@item.Description</span>
                    <span>R$ @item.Price.ToString("N2")</span>
                </div>
            }
        </div>

        @* 2. SEÇÃO DE DESCRIÇÃO DOS SERVIÇOS *@
        <div class="print-data" style="top: 69.6%; left: 6.8%; width: 50%;">
            @foreach (var item in sel.Items.Where(i => i.ProductId == null))
            {
                <div style="margin-bottom: 9px;">- @item.Description</div>
            }
        </div>

        @* VALOR TOTAL *@
        <div class="print-data" style="top: 80%; left: 81%; font-size: 18pt; font-weight: bold;">
            R$ @sel.TotalAmount.ToString("N2")
        </div>

        <div class="print-data" style="top: 92.5%; left: 13.5%; font-size: 10pt; width: 73%; text-align: center;">
            @(sel.Status == "Completed" ? "DOCUMENTO FINALIZADO" : "ORÇAMENTO VÁLIDO POR 7 DIAS")
        </div>
    </div>
}

<style>
    .form-control::placeholder {
        color: #b0b0b0 !important;
        opacity: 1;
    }

    .form-control:focus, .form-select:focus {
        background-color: #222 !important;
        border-color: #ffeb3b !important;
    }

    .table-dark {
        --bs-table-bg: #000;
        background-color: #000;
    }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";
    public class VehicleDTO { public string Model { get; set; } = ""; public string CustomerName { get; set; } = ""; }
    public class ServiceOrderDTO { public int Id { get; set; } public VehicleDTO? Vehicle { get; set; } public string Status { get; set; } = "Pending"; public decimal TotalAmount { get; set; } public List<ServiceItemDTO> Items { get; set; } = new(); }
    public class ServiceItemDTO { public string Description { get; set; } = ""; public decimal Price { get; set; } public int? ProductId { get; set; } public int? MechanicId { get; set; } }
    public class ProductListDTO { public int id { get; set; } public string name { get; set; } = ""; public decimal salePrice { get; set; } }
    public class EmployeeListDTO { public int id { get; set; } public string name { get; set; } = ""; }
    public class CreateOsInput { public string ClientName { get; set; } = ""; public string VehicleModel { get; set; } = ""; }
    public class AddItemInput { public int ProductId { get; set; } public int Quantity { get; set; } = 1; }
    public class AddLaborInput { public string Description { get; set; } = ""; public int MechanicId { get; set; } public decimal Price { get; set; } }

    List<ServiceOrderDTO>? todasOS;
    List<ServiceOrderDTO>? listaFiltrada => mostrarFinalizadas ? todasOS?.Where(o => o.Status == "Completed").OrderByDescending(o => o.Id).ToList() : todasOS?.Where(o => o.Status != "Completed").OrderByDescending(o => o.Id).ToList();
    List<ProductListDTO>? produtos;
    List<EmployeeListDTO>? mecanicos;
    ServiceOrderDTO? sel;
    CreateOsInput novaOsRequest = new();
    AddItemInput novoItem = new();
    AddLaborInput novoServico = new();
    bool mostrarFinalizadas = false;
    string tipoItem = "peca";

    protected override async Task OnInitializedAsync() { await CarregarProdutos(); await CarregarMecanicos(); await CarregarOS(); }
    async Task CarregarOS() { try { todasOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders"); } catch { } }
    async Task CarregarProdutos() { try { produtos = await Http.GetFromJsonAsync<List<ProductListDTO>>($"{ApiUrl}/api/products"); } catch { } }
    async Task CarregarMecanicos() { try { mecanicos = await Http.GetFromJsonAsync<List<EmployeeListDTO>>($"{ApiUrl}/api/employees"); } catch { } }

    void Selecionar(ServiceOrderDTO os)
    {
        sel = os;
        novoItem = new AddItemInput();
        novoServico = new AddLaborInput();
    }

    async Task ImprimirNota() { await JS.InvokeVoidAsync("print"); }

    async Task AbrirOS()
    {
        if (string.IsNullOrEmpty(novaOsRequest.ClientName)) return;
        var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders", novaOsRequest);
        if (res.IsSuccessStatusCode)
        {
            novaOsRequest = new();
            mostrarFinalizadas = false;
            await CarregarOS();
        }
    }

    async Task AdicionarItem()
    {
        if (sel == null || novoItem.ProductId == 0) return;
        var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items", novoItem);
        if (res.IsSuccessStatusCode)
        {
            await AtualizarTela();
            novoItem.Quantity = 1;
        }
    }

    async Task AdicionarServico()
    {
        if (sel == null || string.IsNullOrEmpty(novoServico.Description) || novoServico.MechanicId == 0) return;
        var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/labor", novoServico);
        if (res.IsSuccessStatusCode)
        {
            novoServico = new AddLaborInput();
            await AtualizarTela();
        }
    }

    async Task FinalizarOS()
    {
        if (sel == null) return;
        var res = await Http.PutAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/complete", null);
        if (res.IsSuccessStatusCode)
        {
            mostrarFinalizadas = true;
            await CarregarOS();
            if (sel != null && todasOS != null)
                sel = todasOS.FirstOrDefault(o => o.Id == sel.Id);
        }
    }

    async Task AtualizarTela()
    {
        await CarregarOS();
        if (sel != null && todasOS != null)
            sel = todasOS.FirstOrDefault(o => o.Id == sel.Id);
    }
}