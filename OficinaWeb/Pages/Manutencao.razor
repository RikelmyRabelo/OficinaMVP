@page "/manutencao"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config
@using System.Net.Http.Json
@using OficinaWeb.Models
@using OficinaWeb.Helpers
@using System.Text.Json
@using System.Globalization
@using Microsoft.AspNetCore.Components.Web.Virtualization
@implements IDisposable

<PageTitle>Oficina - FREITAS AUTOCENTER</PageTitle>

@if (imprimindoRelatorioGeral)
{
    <div id="print-relatorio-geral" class="print-overlay" style="color: black !important;">
        <div style="text-align: center; border-bottom: 2px solid black; padding-bottom: 10px; margin-bottom: 20px;">
            <h1 style="margin: 0; font-size: 24pt; color: black !important;"> FREITAS AUTOCENTER</h1>
            <h3 style="margin: 5px 0; color: black !important;">RELATÓRIO CONSOLIDADO DE SAÍDA DE MATERIAIS</h3>
            <p style="font-size: 10pt; color: black !important;">Gerado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

        <table style="width: 100%; border-collapse: collapse; background: white !important; color: black !important;">
            <thead>
                <tr style="background-color: #f2f2f2 !important; border: 1px solid black;">
                    <th style="border: 1px solid black; padding: 8px; text-align: center; width: 60px;">O.S.</th>
                    <th style="border: 1px solid black; padding: 8px; text-align: left;">DESCRIÇÃO DO ITEM</th>
                    <th style="border: 1px solid black; padding: 8px; text-align: center; width: 80px;">QTD</th>
                    <th style="border: 1px solid black; padding: 8px; text-align: right; width: 120px;">VALOR TOTAL</th>
                </tr>
            </thead>
            <tbody>
                @if (osAtivas != null && osFinalizadas != null)
                {
                    var todasGeral = osAtivas.Concat(osFinalizadas).ToList();
                    decimal totalGeralPecas = 0;
                    @foreach (var os in todasGeral)
                    {
                        @foreach (var item in os.Items.Where(i => i.ItemType != "Service" && i.ProductId != null))
                        {
                            totalGeralPecas += item.Price;
                            <tr>
                                <td style="border: 1px solid black; padding: 8px; text-align: center;">#@os.Id</td>
                                <td style="border: 1px solid black; padding: 8px;">@item.Description</td>
                                <td style="border: 1px solid black; padding: 8px; text-align: center;">@item.Quantity</td>
                                <td style="border: 1px solid black; padding: 8px; text-align: right;">R$ @item.Price.ToString("N2")</td>
                            </tr>
                        }
                    }
                    <tr style="background-color: #eee !important; font-weight: bold; font-size: 12pt;">
                        <td colspan="3" style="border: 1px solid black; padding: 12px; text-align: right;">VALOR TOTAL DAS SAÍDAS:</td>
                        <td style="border: 1px solid black; padding: 12px; text-align: right;">R$ @totalGeralPecas.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="toast-container position-fixed bottom-0 end-0 p-3 no-print" style="z-index: 1100;">
    @if (mostrarToast)
    {
        <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                    @toastMensagem
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
            </div>
        </div>
    }
</div>

<ModalExclusao Visivel="mostrarModalExclusao" OsId="sel?.Id ?? 0" ModeloVeiculo="@(sel?.Vehicle?.Model ?? "")" OnConfirmar="ConfirmarExclusao" OnCancelar="() => mostrarModalExclusao = false" />
<ModalEdicaoItem Visivel="mostrarModalEdicaoItem" Request="itemEditRequest" OnSalvar="SalvarEdicaoItem" OnCancelar="FecharEdicaoItem" OnExcluir="ApagarItemEmEdicao" />

<div class="container-fluid py-4 px-4 no-print">
    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick="VoltarInteligente">
                <i class="bi bi-arrow-left me-2"></i>Voltar
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;"><i class="bi bi-wrench-adjustable me-2"></i>Gestão de Oficina</h2>
        </div>
        <div class="col-md-3 text-end d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-danger fw-bold shadow-sm" @onclick='() => Nav.NavigateTo("lixeira")'>
                <i class="bi bi-trash3-fill me-1"></i>LIXEIRA
            </button>
            <button class="btn btn-info fw-bold" @onclick="GerarRelatorioGeralSaidas">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i>RELATÓRIO GERAL
            </button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-4" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Nova Ordem de Serviço</h5>
                    <div class="d-flex flex-column gap-3">
                        <input class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.ClientName" placeholder="Nome do Cliente" />
                        <input class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.VehicleModel" placeholder="Veículo (Modelo / Placa)" />
                        <input class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.CustomerAddress" placeholder="Endereço" />
                        <input type="tel" class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.CustomerPhone" placeholder="Telefone" />
                        <button class="btn fw-bold w-100" style="background-color: #ffeb3b; color: #000;" @onclick="AbrirOS">ABRIR OS</button>
                    </div>
                </div>
            </div>

            <div class="d-flex mb-3 gap-2">
                <button class="btn btn-sm flex-grow-1 fw-bold @(mostrarFinalizadas ? "btn-outline-secondary text-white" : "btn-primary")" @onclick="() => AlternarAba(false)">EM ANDAMENTO</button>
                <button class="btn btn-sm flex-grow-1 fw-bold @(mostrarFinalizadas ? "btn-primary" : "btn-outline-secondary text-white")" @onclick="() => AlternarAba(true)">FINALIZADAS</button>
            </div>

            <div class="list-group shadow-sm" style="max-height: 60vh; overflow-y: auto;">
                @if (listaExibicao != null)
                {
                    <Virtualize Items="listaExibicao" Context="os">
                        @{
                            var isActive = sel?.Id == os.Id;
                        }
                        <div class="list-group-item list-group-item-action border-secondary text-white mb-2 rounded-0" style="@(isActive ? "background-color: #222; border-left: 4px solid #ff6600;" : "background-color: #111;")" @onclick="() => Selecionar(os)">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6>@os.Vehicle?.CustomerName @(os.Status == "Completed" && os.RemainingAmount > 0 ? " (PENDENTE)" : "")</h6>
                                    <small class="text-warning">@os.Vehicle?.Model</small>
                                </div>
                                <span class="badge bg-dark border border-secondary">#@os.Id</span>
                            </div>
                        </div>
                    </Virtualize>
                }
            </div>
        </div>

        <div class="col-md-8">
            @if (sel != null)
            {
                <div class="card border-0 shadow-sm h-100" style="background-color: #111; border-top: 4px solid #ff6600 !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-4 border-bottom border-secondary pb-3">
                            <div class="flex-grow-1">
                                @if (editandoCabecalho)
                                {
                                    <div class="bg-black p-3 rounded border border-secondary">
                                        <input class="form-control form-control-sm bg-dark text-white border-secondary mb-2" @bind="editRequest.VehicleModel" placeholder="Modelo" />
                                        <input class="form-control form-control-sm bg-dark text-white border-secondary mb-2" @bind="editRequest.CustomerName" placeholder="Cliente" />
                                        <button class="btn btn-sm btn-success" @onclick="SalvarEdicao">Salvar</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => editandoCabecalho = false">Cancelar</button>
                                    </div>
                                }
                                else
                                {
                                    <h2 class="fw-bold text-white mb-0">@sel.Vehicle?.Model <button class="btn btn-sm text-secondary" @onclick="IniciarEdicao"><i class="bi bi-pencil"></i></button></h2>
                                    <span class="text-warning">Cliente: @sel.Vehicle?.CustomerName</span>
                                }
                            </div>
                            <div class="text-end">
                                <button class="btn btn-light btn-sm fw-bold mb-2" @onclick="ImprimirNota">IMPRIMIR</button>
                                <div @onclick="IniciarEdicaoTotal" style="cursor:pointer">
                                    <h5 class="text-success fw-bold mb-0">TOTAL: R$ @sel.TotalAmount.ToString("N2")</h5>
                                    <h6 class="text-info">PAGO: R$ @sel.AmountPaid.ToString("N2")</h6>
                                    <h6 class="text-warning">FALTA: R$ @sel.RemainingAmount.ToString("N2")</h6>
                                </div>
                            </div>
                        </div>

                        <div class="p-3 rounded-3 mb-4 bg-black border border-secondary">
                            <ul class="nav nav-pills mb-3 gap-2">
                                <li><button class="btn btn-sm @(tipoItem == "peca" ? "btn-warning" : "btn-outline-light")" @onclick='() => tipoItem = "peca"'>PEÇA</button></li>
                                <li><button class="btn btn-sm @(tipoItem == "servico" ? "btn-warning" : "btn-outline-light")" @onclick='() => tipoItem = "servico"'>SERVIÇO</button></li>
                            </ul>
                            <div class="row g-2">
                                @if (tipoItem == "peca")
                                {
                                    <div class="col-md-5">
                                        <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary mb-1" placeholder="Buscar..." @bind="filtroProduto" @bind:event="oninput" />
                                        <select class="form-select bg-dark text-white border-secondary" @bind="novoItem.ProductId">
                                            <option value="0">Selecionar...</option>
                                            @if (produtos != null)
                                            {
                                                @foreach (var p in produtos.Where(x => string.IsNullOrEmpty(filtroProduto) || x.name.Contains(filtroProduto, StringComparison.OrdinalIgnoreCase) || x.code.Contains(filtroProduto, StringComparison.OrdinalIgnoreCase)))
                                                {
                                                    <option value="@p.id">[@p.code] @p.name (R$ @p.salePrice)</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2"><input type="number" class="form-control bg-dark text-white border-secondary" @bind="novoItem.Quantity" /></div>
                                    <div class="col-md-3"><input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novoItem.Price" /></div>
                                    <div class="col-md-2"><button class="btn btn-warning w-100" @onclick="AdicionarItem">ADD</button></div>
                                }
                            </div>
                        </div>

                        <table class="table table-dark table-hover">
                            <thead>
                                <tr>
                                    <th>Cód</th>
                                    <th>Descrição</th>
                                    <th class="text-center">Qtd</th>
                                    <th class="text-end">V. Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in sel.Items)
                                {
                                    <tr>
                                        <td>@item.ProductCodeDisplay</td>
                                        <td>@item.ProductDescriptionDisplay</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">R$ @item.Price.ToString("N2")</td>
                                        <td class="text-center"><button class="btn btn-sm text-warning" @onclick="() => AbrirEdicaoItem(item)"><i class="bi bi-pencil"></i></button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="mt-4 text-end">
                            @if (sel.Status != "Completed")
                            {
                                <button class="btn btn-success fw-bold px-5" @onclick="FinalizarOS">FINALIZAR O.S.</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string ApiUrl = "";
    private List<ProductListDTO>? produtos;
    private List<LaborServiceDTO>? catalogoServicos;
    private List<ServiceOrderDTO>? osAtivas, osFinalizadas, alertasInadimplencia;
    private ServiceOrderDTO? sel, osParaRelatorio;
    private bool isLoading = true, carregandoLista, mostrarFinalizadas, mostrarToast, mostrarModalExclusao, mostrarModalEdicaoItem, editandoCabecalho, editandoTotal, editandoPagamento, isUploading, imprimindoRelatorioGeral;
    private string toastMensagem = "", toastTipo = "sucesso", tipoItem = "peca", filtroProduto = "", pixCopiaCola = "";
    private decimal novoTotal, novoDesconto, valorPixGerado;
    private DateTime? novaDataPromessa;

    private List<ServiceOrderDTO>? listaExibicao => mostrarFinalizadas ? osFinalizadas : osAtivas;

    private CreateOsInput novaOsRequest = new();
    private AddItemInput novoItem = new();
    private AddCustomItemInput novoItemAvulso = new();
    private AddLaborInput novoServico = new();
    private UpdateVehicleDTO editRequest = new();
    private UpdateServiceItemDTO itemEditRequest = new();
    private ServiceItemDTO? itemParaEditar;
    private List<PaymentSplitDTO> listaPagamentosEmEdicao = new();

    protected override async Task OnInitializedAsync()
    {
        ApiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7082";
        await CarregarDadosIniciais();
    }

    async Task CarregarDadosIniciais()
    {
        try
        {
            await Task.WhenAll(CarregarProdutos(), CarregarCatalogoServicos(), CarregarOSAtivas(), CarregarAlertas());
        }
        catch { MostrarErro("Erro ao carregar dados."); }
        finally { isLoading = false; StateHasChanged(); }
    }

    async Task CarregarOSAtivas()
    {
        try
        {
            var jsonRaw = await Http.GetStringAsync($"{ApiUrl}/api/serviceorders/active");
            osAtivas = JsonSerializer.Deserialize<List<ServiceOrderDTO>>(jsonRaw, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch { MostrarErro("Erro ao carregar O.S ativas."); }
    }

    async Task CarregarProdutos() { try { produtos = await Http.GetFromJsonAsync<List<ProductListDTO>>($"{ApiUrl}/api/products"); } catch { } }
    async Task CarregarCatalogoServicos() { try { catalogoServicos = await Http.GetFromJsonAsync<List<LaborServiceDTO>>($"{ApiUrl}/api/laborservices"); } catch { } }
    async Task CarregarAlertas() { try { alertasInadimplencia = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/alerts"); } catch { } }
    async Task CarregarOSFinalizadas() { try { osFinalizadas = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/completed?take=50"); } catch { } }

    async Task AlternarAba(bool finalizadas)
    {
        mostrarFinalizadas = finalizadas;
        if (finalizadas && osFinalizadas == null) { carregandoLista = true; await CarregarOSFinalizadas(); carregandoLista = false; }
    }

    async Task Selecionar(ServiceOrderDTO os)
    {
        sel = os;
        try { sel.Attachments = await Http.GetFromJsonAsync<List<AttachmentDTO>>($"{ApiUrl}/api/serviceorders/{os.Id}/attachments") ?? new(); }
        catch { if (sel != null) sel.Attachments = new(); }
    }

    async Task AbrirOS()
    {
        if (string.IsNullOrEmpty(novaOsRequest.ClientName)) return;
        var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders", novaOsRequest);
        if (res.IsSuccessStatusCode) { novaOsRequest = new(); await CarregarOSAtivas(); MostrarSucesso("OS Aberta!"); }
    }

    async Task AdicionarItem()
    {
        if (sel == null) return;
        var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items", novoItem);
        if (res.IsSuccessStatusCode) { await AtualizarOSAtual(); novoItem = new(); MostrarSucesso("Item Adicionado!"); }
    }

    async Task FinalizarOS()
    {
        if (sel == null) return;
        var res = await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/complete", new { CompletionDate = DateTime.Now });
        if (res.IsSuccessStatusCode) { await CarregarOSAtivas(); await CarregarOSFinalizadas(); sel = null; MostrarSucesso("OS Finalizada!"); }
    }

    async Task AtualizarOSAtual()
    {
        if (sel == null) return;
        // Correção de conversão implícita de int? para int usando o operador ??
        int mes = sel.AccountingMonth ?? DateTime.Now.Month;
        int ano = sel.AccountingYear ?? DateTime.Now.Year;
        var list = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/periodo?mes={mes}&ano={ano}");
        var match = list?.FirstOrDefault(x => x.Id == sel.Id);
        if (match != null) { match.Attachments = sel.Attachments; sel = match; }
        await CarregarOSAtivas();
    }

    void IniciarEdicao() { if (sel == null) return; editRequest = new UpdateVehicleDTO { CustomerName = sel.Vehicle?.CustomerName ?? "", VehicleModel = sel.Vehicle?.Model ?? "" }; editandoCabecalho = true; }
    async Task SalvarEdicao() { if (sel == null) return; await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/vehicle", editRequest); editandoCabecalho = false; await AtualizarOSAtual(); }

    void IniciarEdicaoTotal() { if (sel == null) return; novoTotal = sel.TotalAmount; editandoTotal = true; }
    async Task SalvarTotal() { if (sel == null) return; await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/total", new UpdateTotalDTO { TotalAmount = novoTotal }); editandoTotal = false; await AtualizarOSAtual(); }

    void AbrirEdicaoItem(ServiceItemDTO item) { itemParaEditar = item; itemEditRequest = new UpdateServiceItemDTO { Description = item.Description, Price = item.Price, Quantity = item.Quantity }; mostrarModalEdicaoItem = true; }
    async Task SalvarEdicaoItem() { if (sel == null || itemParaEditar == null) return; await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items/{itemParaEditar.Id}", itemEditRequest); mostrarModalEdicaoItem = false; await AtualizarOSAtual(); }
    async Task ApagarItemEmEdicao() { if (sel == null || itemParaEditar == null) return; await Http.DeleteAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items/{itemParaEditar.Id}"); mostrarModalEdicaoItem = false; await AtualizarOSAtual(); }
    
    void MostrarSucesso(string m) { toastMensagem = m; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged(); }
    void MostrarErro(string m) { toastMensagem = m; toastTipo = "erro"; mostrarToast = true; StateHasChanged(); }
    void VoltarInteligente() => Nav.NavigateTo("/");
    void FecharEdicaoItem() => mostrarModalEdicaoItem = false;
    async Task ConfirmarExclusao() { if (sel == null) return; await Http.DeleteAsync($"{ApiUrl}/api/serviceorders/{sel.Id}"); sel = null; mostrarModalExclusao = false; await CarregarOSAtivas(); }
    async Task ImprimirNota() => await JS.InvokeVoidAsync("print");
    void GerarRelatorioGeralSaidas() => Nav.NavigateTo("relatorio-saidas");
    async Task AbrirOsDoAlerta(int id) { /* lógica opcional */ }
    void OnServiceSelected(ChangeEventArgs e) { /* lógica opcional */ }
    async Task AdicionarItemAvulso() { /* lógica opcional */ }
    async Task AdicionarServico() { /* lógica opcional */ }
    public void Dispose() { }
}