@page "/manutencao"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Oficina - FJ Centro Automotivo</PageTitle>

@*SISTEMA DE NOTIFICAÇÕES *@
<div class="toast-container position-fixed bottom-0 end-0 p-3 no-print" style="z-index: 1100;">
    @if (mostrarToast)
    {
        <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                    @toastMensagem
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
            </div>
        </div>
    }
</div>

@*MODAL DE EDIÇÃO DE ITEM E GARANTIA *@
@if (mostrarModalEdicaoItem && itemParaEditar != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold" style="color: #ffeb3b;"><i class="bi bi-pencil-square me-2"></i>Editar Item e Garantia</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharEdicaoItem"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-secondary">Descrição</label>
                        <input class="form-control bg-dark text-white border-secondary" @bind="itemEditRequest.Description" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary">Preço Total (R$)</label>
                            <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="itemEditRequest.Price" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary">Expiração da Garantia</label>
                            <input type="date" class="form-control bg-dark text-white border-secondary" @bind="itemEditRequest.WarrantyExpirationDate" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" @onclick="FecharEdicaoItem">Cancelar</button>
                    <button type="button" class="btn fw-bold" style="background-color: #ffeb3b; color: #000;" @onclick="SalvarEdicaoItem">SALVAR</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="container-fluid py-4 px-4 no-print">
    <div class="row align-items-center mb-5">
        <div class="col-md-3">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("/")'>
                <i class="bi bi-arrow-left me-2"></i>Início
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;"><i class="bi bi-wrench-adjustable me-2"></i>Gestão de Oficina</h2>
        </div>
        <div class="col-md-3 text-end">
            <button class="btn @(verLixeira ? "btn-danger" : "btn-outline-danger") fw-bold" @onclick="AlternarLixeira">
                <i class="bi @(verLixeira ? "bi-arrow-left-circle" : "bi-trash") me-2"></i>@(verLixeira ? "SAIR DA LIXEIRA" : "LIXEIRA")
            </button>
        </div>
    </div>

    @if (alertasInadimplencia != null && alertasInadimplencia.Any() && !verLixeira)
    {
        <div class="alert alert-danger bg-dark border-danger text-white mb-4 shadow-sm">
            <h6 class="alert-heading fw-bold text-danger"><i class="bi bi-exclamation-octagon-fill me-2"></i>Cobranças para Hoje ou Atrasadas:</h6>
            <hr class="border-secondary">
            @foreach (var os in alertasInadimplencia)
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span><strong>@os.Vehicle?.CustomerName</strong> (#@os.Id) - Saldo Devedor: <span class="text-warning font-monospace">R$ @os.RemainingAmount.ToString("N2")</span></span>
                    <button class="btn btn-sm btn-outline-light py-0" @onclick="() => Selecionar(os)">Ver Detalhes</button>
                </div>
            }
        </div>
    }

    <div class="row g-4">
        <div class="col-md-4">
            @if (!verLixeira)
            {
                <div class="card border-0 bg-dark mb-4 shadow" style="border-top: 4px solid #ffeb3b !important;">
                    <div class="card-body">
                        <h6 class="text-warning fw-bold mb-3">Nova Ordem de Serviço</h6>
                        <input class="form-control form-control-sm bg-black text-white border-secondary mb-2" @bind="novaOsRequest.ClientName" placeholder="Cliente" />
                        <input class="form-control form-control-sm bg-black text-white border-secondary mb-3" @bind="novaOsRequest.VehicleModel" placeholder="Veículo / Placa" />
                        <button class="btn btn-warning btn-sm w-100 fw-bold" @onclick="AbrirOS">ABRIR O.S.</button>
                    </div>
                </div>

                <div class="btn-group w-100 mb-3">
                    <button class="btn btn-sm @(!mostrarFinalizadas ? "btn-primary" : "btn-outline-secondary text-white")" @onclick="() => mostrarFinalizadas = false">EM ABERTO</button>
                    <button class="btn btn-sm @(mostrarFinalizadas ? "btn-primary" : "btn-outline-secondary text-white")" @onclick="() => mostrarFinalizadas = true">FINALIZADAS</button>
                </div>
            }

            <div class="list-group" style="max-height: 60vh; overflow-y: auto;">
                @if (listaExibicao != null)
                {
                    foreach (var os in listaExibicao)
                    {
                        <button class="list-group-item list-group-item-action @(sel?.Id == os.Id ? "active-os" : "bg-dark") text-white border-secondary mb-1" @onclick="() => Selecionar(os)">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">@os.Vehicle?.CustomerName</span>
                                <span class="badge bg-black">#@os.Id</span>
                            </div>
                            <div class="d-flex justify-content-between small">
                                <span class="text-warning">@os.Vehicle?.Model</span>
                                @if (os.RemainingAmount > 0 && os.Status == "Completed")
                                {
                                    <span class="badge bg-danger">DÉBITO</span>
                                }
                            </div>
                        </button>
                    }
                }
            </div>
        </div>

        <div class="col-md-8">
            @if (sel != null)
            {
                <div class="card border-0 bg-dark h-100 shadow" style="border-top: 4px solid #ff6600 !important;">
                    <div class="card-body">
                        <div class="row mb-4 border-bottom border-secondary pb-3">
                            <div class="col-md-7">
                                <h3 class="text-white fw-bold mb-0">@sel.Vehicle?.Model</h3>
                                <p class="text-warning mb-0">Cliente: @sel.Vehicle?.CustomerName</p>
                                <small class="text-white-50">Entrada: @sel.EntryDate.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <div class="col-md-5 text-end">
                                <div class="mb-2">
                                    <h4 class="text-success fw-bold mb-1">Total: R$ @sel.TotalAmount.ToString("N2")</h4>
                                    <h6 class="text-info mb-1">Pago: R$ @sel.AmountPaid.ToString("N2")</h6>

                                    @if (sel.RemainingAmount > 0)
                                    {
                                        <h5 class="text-danger fw-bold mt-1 shadow-sm">FALTA: R$ @sel.RemainingAmount.ToString("N2")</h5>
                                    }
                                    @if (sel.OverpaidAmount > 0)
                                    {
                                        <h5 class="text-success fw-bold mt-1">EXTRA CAIXA: R$ @sel.OverpaidAmount.ToString("N2")</h5>
                                    }
                                </div>
                                <div class="d-flex gap-2 justify-content-end no-print">
                                    <button class="btn btn-sm btn-light fw-bold" @onclick="ImprimirNota"><i class="bi bi-printer me-1"></i>IMPRIMIR</button>
                                </div>
                            </div>
                        </div>

                        @if (sel.Status != "Completed" && !verLixeira)
                        {
                            <div class="bg-black p-3 rounded mb-4 border border-secondary">
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-6">
                                        <label class="small text-white-50">Descrição do Serviço/Peça</label>
                                        <input class="form-control form-control-sm bg-dark text-white border-secondary" @bind="novoItemAvulso.Description" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small text-white-50">Valor Unitário</label>
                                        <input type="number" step="0.01" class="form-control form-control-sm bg-dark text-white border-secondary" @bind="novoItemAvulso.Price" />
                                    </div>
                                    <div class="col-md-3">
                                        <button class="btn btn-sm btn-warning w-100 fw-bold" @onclick="AdicionarItemAvulso">ADICIONAR ITEM</button>
                                    </div>
                                </div>
                            </div>
                        }

                        <table class="table table-dark table-hover border-secondary">
                            <thead>
                                <tr class="small text-white-50">
                                    <th>Descrição do Item</th>
                                    <th>Status de Garantia</th>
                                    <th class="text-end">Valor</th>
                                    <th class="no-print"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in sel.Items)
                                {
                                    <tr>
                                        <td>@item.Description</td>
                                        <td>
                                            @if (item.WarrantyExpirationDate.HasValue)
                                            {
                                                var dias = (item.WarrantyExpirationDate.Value - DateTime.Today).Days;
                                                @if (dias >= 0)
                                                {
                                                    <span class="badge bg-success">VÁLIDA (@dias dias)</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-danger">EXPIRADA (@Math.Abs(dias) d atrás)</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-white-50 small">-</span>
                                            }
                                        </td>
                                        <td class="text-end fw-bold">R$ @item.Price.ToString("N2")</td>
                                        <td class="text-end no-print">
                                            <button class="btn btn-sm btn-link text-warning p-0" @onclick="() => AbrirEdicaoItem(item)" title="Editar Garantia/Preço"><i class="bi bi-pencil-square"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        @if (sel.Status != "Completed" && !verLixeira)
                        {
                            <div class="border-top border-secondary pt-4 mt-4">
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-3">
                                        <label class="small text-white-50">Valor Recebido (R$)</label>
                                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary fw-bold text-success" @bind="novoValorPago" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small text-white-50">Forma de Pagto</label>
                                        <select class="form-select bg-dark text-white border-secondary" @bind="novoMetodoPagamento">
                                            <option value="Dinheiro">Dinheiro</option>
                                            <option value="PIX">PIX</option>
                                            <option value="Crédito">Crédito</option>
                                            <option value="Débito">Débito</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="small text-white-50">Data de Promessa</label>
                                        <input type="date" class="form-control bg-dark text-white border-secondary" @bind="novaDataPromessa" />
                                    </div>
                                    <div class="col-md-3">
                                        <button class="btn btn-success w-100 fw-bold shadow" @onclick="FinalizarOS">FINALIZAR E ENTREGAR</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .active-os {
        background-color: #ff6600 !important;
        border-color: #ff6600 !important;
    }

    .bg-black {
        background-color: #000 !important;
    }

    .bg-dark {
        background-color: #111 !important;
    }

    .text-success {
        color: #28a745 !important;
    }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";

    //CLASSES DTO
    public class ServiceOrderDTO
    {
        public int Id { get; set; }
        public VehicleDTO? Vehicle { get; set; }
        public string Status { get; set; } = "Pending";
        public decimal TotalAmount { get; set; }
        public decimal AmountPaid { get; set; }
        public string? PaymentMethod { get; set; }
        public DateTime? PromisedPaymentDate { get; set; }
        public decimal RemainingAmount => Math.Max(0, TotalAmount - AmountPaid);
        public decimal OverpaidAmount => Math.Max(0, AmountPaid - TotalAmount);
        public DateTime EntryDate { get; set; }
        public List<ServiceItemDTO> Items { get; set; } = new();
    }

    public class ServiceItemDTO
    {
        public int Id { get; set; }
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public string? WarrantyPeriod { get; set; }
        public DateTime? WarrantyExpirationDate { get; set; }
        public int Quantity { get; set; } = 1;
    }

    public class VehicleDTO { public string Model { get; set; } = ""; public string CustomerName { get; set; } = ""; }

    //CLASSES DE REQUEST
    public class CreateOsRequest { public string ClientName { get; set; } = ""; public string VehicleModel { get; set; } = ""; }
    public class AddItemRequest { public string Description { get; set; } = ""; public decimal Price { get; set; } }
    public class UpdatePaymentRequest { public decimal AmountPaid { get; set; } public string? PaymentMethod { get; set; } public DateTime? PromisedPaymentDate { get; set; } }
    public class UpdateItemRequest { public string Description { get; set; } = ""; public decimal Price { get; set; } public DateTime? WarrantyExpirationDate { get; set; } }

    //VARIÁVEIS DE ESTADO
    private List<ServiceOrderDTO>? todasOS;
    private List<ServiceOrderDTO>? lixeiraOS;
    private ServiceOrderDTO? sel;
    private bool mostrarFinalizadas = false;
    private bool verLixeira = false;
    private bool mostrarToast = false;
    private string toastMensagem = "";
    private string toastTipo = "sucesso";
    private bool mostrarModalEdicaoItem = false;

    // Objetos de Manipulação
    private ServiceItemDTO? itemParaEditar;
    private UpdateItemRequest itemEditRequest = new UpdateItemRequest();
    private decimal novoValorPago;
    private string novoMetodoPagamento = "Dinheiro";
    private DateTime? novaDataPromessa;
    private CreateOsRequest novaOsRequest = new CreateOsRequest();
    private AddItemRequest novoItemAvulso = new AddItemRequest();

    // Filtros de Lista
    private List<ServiceOrderDTO>? listaExibicao => verLixeira ? lixeiraOS : (mostrarFinalizadas ? todasOS?.Where(o => o.Status == "Completed").OrderByDescending(o => o.Id).ToList() : todasOS?.Where(o => o.Status != "Completed").OrderByDescending(o => o.Id).ToList());
    private List<ServiceOrderDTO>? alertasInadimplencia => todasOS?.Where(o => o.Status == "Completed" && o.RemainingAmount > 0 && o.PromisedPaymentDate.HasValue && o.PromisedPaymentDate.Value.Date <= DateTime.Today).ToList();

    protected override async Task OnInitializedAsync() => await CarregarOS();

    private async Task CarregarOS()
    {
        try
        {
            todasOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders");
        }
        catch { }
    }

    private void Selecionar(ServiceOrderDTO os)
    {
        sel = os;
        novoValorPago = os.AmountPaid;
        novoMetodoPagamento = os.PaymentMethod ?? "Dinheiro";
        novaDataPromessa = os.PromisedPaymentDate;
    }

    private async Task AbrirOS()
    {
        if (string.IsNullOrWhiteSpace(novaOsRequest.ClientName)) return;
        await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders", novaOsRequest);
        novaOsRequest = new CreateOsRequest();
        await CarregarOS();
        MostrarSucesso("Ordem de Serviço Aberta!");
    }

    private async Task AdicionarItemAvulso()
    {
        if (sel == null || string.IsNullOrWhiteSpace(novoItemAvulso.Description)) return;
        await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/labor", novoItemAvulso);
        novoItemAvulso = new AddItemRequest();
        await AtualizarTela();
    }

    private async Task FinalizarOS()
    {
        if (sel == null) return;
        // Salva o Pagamento
        await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/payment", new UpdatePaymentRequest
        {
            AmountPaid = novoValorPago,
            PaymentMethod = novoMetodoPagamento,
            PromisedPaymentDate = novaDataPromessa
        });
        // Completa a O.S.
        await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/complete", new { CompletionDate = DateTime.Now });
        await CarregarOS();
        mostrarFinalizadas = true;
        MostrarSucesso("O.S. Finalizada e Arquivada!");
    }

    private void AbrirEdicaoItem(ServiceItemDTO item)
    {
        itemParaEditar = item;
        itemEditRequest = new UpdateItemRequest
        {
            Description = item.Description,
            Price = item.Price,
            WarrantyExpirationDate = item.WarrantyExpirationDate
        };
        mostrarModalEdicaoItem = true;
    }

    private async Task SalvarEdicaoItem()
    {
        if (sel == null || itemParaEditar == null) return;
        await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items/{itemParaEditar.Id}", itemEditRequest);
        mostrarModalEdicaoItem = false;
        await AtualizarTela();
        MostrarSucesso("Garantia e Preço Atualizados!");
    }

    private async Task AtualizarTela()
    {
        await CarregarOS();
        if (sel != null) sel = todasOS?.FirstOrDefault(o => o.Id == sel.Id);
    }

    private void MostrarSucesso(string msg)
    {
        toastMensagem = msg; toastTipo = "sucesso"; mostrarToast = true;
        StateHasChanged();
    }

    private void FecharEdicaoItem() => mostrarModalEdicaoItem = false;

    private async Task ImprimirNota() => await JS.InvokeVoidAsync("print");

    private async Task AlternarLixeira()
    {
        verLixeira = !verLixeira;
        if (verLixeira) lixeiraOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/trash");
    }

    private void SolicitarExclusao() { /* Lógica de Delete soft implementada na API */ }
}