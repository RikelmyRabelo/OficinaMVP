@page "/manutencao"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config
@using System.Net.Http.Json
@using OficinaWeb.Models
@using System.Text.Json
@using System.Globalization
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.Extensions.Configuration
@implements IDisposable

<PageTitle>Oficina - FREITAS AUTOCENTER</PageTitle>

@if (imprimindoRelatorioGeral)
{
    <div id="print-relatorio-geral" class="print-overlay" style="color: black !important;">
        <div style="text-align: center; border-bottom: 2px solid black; padding-bottom: 10px; margin-bottom: 20px;">
            <h1 style="margin: 0; font-size: 24pt; color: black !important;"> FREITAS AUTOCENTER</h1>
            <h3 style="margin: 5px 0; color: black !important;">RELATÓRIO CONSOLIDADO DE SAÍDA DE MATERIAIS</h3>
            <p style="font-size: 10pt; color: black !important;">Gerado em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

        <table style="width: 100%; border-collapse: collapse; background: white !important; color: black !important;">
            <thead>
                <tr style="background-color: #f2f2f2 !important; border: 1px solid black;">
                    <th style="border: 1px solid black; padding: 8px; text-align: center; width: 60px;">O.S.</th>
                    <th style="border: 1px solid black; padding: 8px; text-align: left;">DESCRIÇÃO DO ITEM</th>
                    <th style="border: 1px solid black; padding: 8px; text-align: center; width: 80px;">QTD</th>
                    <th style="border: 1px solid black; padding: 8px; text-align: right; width: 120px;">VALOR TOTAL</th>
                </tr>
            </thead>
            <tbody>
                @if (osAtivas != null && osFinalizadas != null)
                {
                    var todasGeral = osAtivas.Concat(osFinalizadas).ToList();
                    decimal totalGeralPecas = 0;
                    @foreach (var os in todasGeral)
                    {
                        @foreach (var item in os.Items.Where(i => i.ItemType != "Service" && (i.ProductId != null || (i.ProductId == null && i.MechanicId == null))))
                        {
                            totalGeralPecas += item.Price;
                            <tr>
                                <td style="border: 1px solid black; padding: 8px; text-align: center;">#@os.Id</td>
                                <td style="border: 1px solid black; padding: 8px;">@item.Description</td>
                                <td style="border: 1px solid black; padding: 8px; text-align: center;">@item.Quantity</td>
                                <td style="border: 1px solid black; padding: 8px; text-align: right;">R$ @item.Price.ToString("N2")</td>
                            </tr>
                        }
                    }
                    <tr style="background-color: #eee !important; font-weight: bold; font-size: 12pt;">
                        <td colspan="3" style="border: 1px solid black; padding: 12px; text-align: right;">VALOR TOTAL DAS SAÍDAS:</td>
                        <td style="border: 1px solid black; padding: 12px; text-align: right;">R$ @totalGeralPecas.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="toast-container position-fixed bottom-0 end-0 p-3 no-print" style="z-index: 1100;">
    @if (mostrarToast)
    {
        <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                    @toastMensagem
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
            </div>
        </div>
    }
</div>

<ModalExclusao Visivel="mostrarModalExclusao" OsId="sel?.Id ?? 0" ModeloVeiculo="@(sel?.Vehicle?.Model ?? "")" OnConfirmar="ConfirmarExclusao" OnCancelar="() => mostrarModalExclusao = false" />

<ModalEdicaoItem Visivel="mostrarModalEdicaoItem" Request="itemEditRequest" OnSalvar="SalvarEdicaoItem" OnCancelar="FecharEdicaoItem" OnExcluir="ApagarItemEmEdicao" />

<div class="container-fluid py-4 px-4 no-print">
    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick="VoltarInteligente">
                <i class="bi bi-arrow-left me-2"></i>Voltar
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;"><i class="bi bi-wrench-adjustable me-2"></i>Gestão de Oficina</h2>
        </div>
        <div class="col-md-3 text-end d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-danger fw-bold shadow-sm" @onclick='() => Nav.NavigateTo("lixeira")'>
                <i class="bi bi-trash3-fill me-1"></i>LIXEIRA
            </button>
            <button class="btn btn-info fw-bold" @onclick="GerarRelatorioGeralSaidas">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i>RELATÓRIO GERAL
            </button>
        </div>
    </div>

    @if (alertasInadimplencia != null && alertasInadimplencia.Any())
    {
        <div class="alert alert-danger bg-dark border-danger text-white d-flex align-items-center mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-2 me-3 text-danger"></i>
            <div>
                <h5 class="alert-heading text-danger fw-bold mb-1">Avisos de Cobrança (Vencimento Hoje ou Atrasados)</h5>
                <ul class="mb-0 ps-3">
                    @foreach (var div in alertasInadimplencia)
                    {
                        decimal faltaPagar = div.TotalAmount - div.AmountPaid;
                        <li>
                            <strong class="text-warning">@div.Vehicle?.CustomerName</strong> - O.S. #@div.Id - Falta pagar: <strong>R$ @faltaPagar.ToString("N2")</strong>
                            <span class="text-white-50 ms-1">(Promessa: @div.PromisedPaymentDate?.ToString("dd/MM/yyyy"))</span>
                            <button class="btn btn-sm btn-link text-info p-0 ms-2" @onclick="() => AbrirOsDoAlerta(div.Id)">[Abrir]</button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-4" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Nova Ordem de Serviço</h5>
                    <div class="d-flex flex-column gap-3">
                        <input class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.ClientName" placeholder="Nome do Cliente" />
                        <input class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.VehicleModel" placeholder="Veículo (Modelo / Placa)" />
                        <input class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.CustomerAddress" placeholder="Endereço (Opcional)" />
                        <input type="tel" class="form-control bg-dark text-white border-secondary" @bind="novaOsRequest.CustomerPhone" oninput="this.value = this.value.replace(/[^0-9()-\s]/g, '')" placeholder="Telefone (Opcional)" />
                        <button class="btn fw-bold w-100" style="background-color: #ffeb3b; color: #000;" @onclick="AbrirOS">ABRIR OS</button>
                    </div>
                </div>
            </div>

            <div class="d-flex mb-3 gap-2">
                <button class="btn btn-sm flex-grow-1 fw-bold @(mostrarFinalizadas ? "btn-outline-secondary text-white" : "btn-primary")" @onclick="() => AlternarAba(false)">EM ANDAMENTO</button>
                <button class="btn btn-sm flex-grow-1 fw-bold @(mostrarFinalizadas ? "btn-primary" : "btn-outline-secondary text-white")" @onclick="() => AlternarAba(true)">FINALIZADAS</button>
            </div>

            <div class="list-group shadow-sm" style="max-height: 60vh; overflow-y: auto;">
                @if (listaExibicao != null)
                {
                    <Virtualize Items="listaExibicao" Context="os">
                        @{ var isActive = sel?.Id == os.Id; }
                        <div class="list-group-item list-group-item-action border-secondary text-white mb-2 rounded-0" style="@(isActive ? "background-color: #222; border-left: 4px solid #ff6600;" : "background-color: #111;")" @onclick="() => Selecionar(os)">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6>
                                        @(os.Vehicle?.CustomerName)
                                        @if (os.Status == "Completed" && os.RemainingAmount > 0)
                                        {
                                            <span class="badge bg-danger ms-1" style="font-size: 0.65rem;" title="Débito Pendente">PENDENTE</span>
                                        }
                                    </h6>
                                    <small class="text-warning">@(os.Vehicle?.Model)</small>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <button class="btn btn-sm btn-outline-info border-0" title="Relatório de Saídas" @onclick="() => GerarRelatorioSaida(os)" @onclick:stopPropagation="true">
                                        <i class="bi bi-box-seam-fill"></i>
                                    </button>
                                    <span class="badge bg-dark border border-secondary">#@os.Id</span>
                                </div>
                            </div>
                        </div>
                    </Virtualize>
                }
                else if (carregandoLista)
                {
                    <div class="text-center text-white-50 py-3"><i class="spinner-border spinner-border-sm me-2"></i>Carregando...</div>
                }
            </div>
        </div>

        <div class="col-md-8">
            @if (sel != null)
            {
                <div class="card border-0 shadow-sm h-100" style="background-color: #111; border-top: 4px solid #ff6600 !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-4 border-bottom border-secondary pb-3">

                            <div class="flex-grow-1">
                                @if (editandoCabecalho)
                                {
                                    <div class="d-flex flex-column gap-2 mb-2 bg-black p-3 rounded border border-secondary">
                                        <div class="row g-2">
                                            <div class="col-md-6">
                                                <small class="text-muted">Modelo / Placa</small>
                                                <input class="form-control form-control-sm bg-dark text-white border-secondary" @bind="editRequest.VehicleModel" />
                                            </div>
                                            <div class="col-md-6">
                                                <small class="text-muted">Cliente</small>
                                                <input class="form-control form-control-sm bg-dark text-white border-secondary" @bind="editRequest.CustomerName" />
                                            </div>
                                            <div class="col-md-6">
                                                <small class="text-muted">Telefone</small>
                                                <input type="tel" class="form-control form-control-sm bg-dark text-white border-secondary" @bind="editRequest.CustomerPhone" oninput="this.value = this.value.replace(/[^0-9()-\s]/g, '')" />
                                            </div>
                                            <div class="col-md-6">
                                                <small class="text-muted">Endereço</small>
                                                <input class="form-control form-control-sm bg-dark text-white border-secondary" @bind="editRequest.CustomerAddress" />
                                            </div>
                                        </div>
                                        <div class="d-flex gap-2 mt-2">
                                            <button class="btn btn-sm btn-success fw-bold" @onclick="SalvarEdicao"><i class="bi bi-check-lg me-1"></i>Salvar</button>
                                            <button class="btn btn-sm btn-outline-secondary text-white" @onclick="CancelarEdicao"><i class="bi bi-x-lg me-1"></i>Cancelar</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <h2 class="fw-bold text-white mb-0">@(sel.Vehicle?.Model)</h2>
                                        <button class="btn btn-sm btn-link text-secondary p-0 ms-2" @onclick="IniciarEdicao" title="Editar dados do cabeçalho">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </button>
                                    </div>
                                    <span class="text-warning">Cliente: @(sel.Vehicle?.CustomerName)</span>
                                    @if (!string.IsNullOrEmpty(sel.Vehicle?.CustomerPhone))
                                    {
                                        <div class="text-white small"><i class="bi bi-telephone me-1"></i>@sel.Vehicle?.CustomerPhone</div>
                                    }
                                    @if (!string.IsNullOrEmpty(sel.Vehicle?.CustomerAddress))
                                    {
                                        <div class="text-white small"><i class="bi bi-geo-alt me-1"></i>@sel.Vehicle?.CustomerAddress</div>
                                    }
                                }
                            </div>

                            <div class="text-end ps-3 border-start border-secondary">
                                <div class="d-flex gap-2 justify-content-end mb-3">
                                    <button class="btn btn-light btn-sm fw-bold" @onclick="ImprimirNota">IMPRIMIR</button>
                                    <button class="btn btn-outline-danger btn-sm fw-bold" @onclick="SolicitarExclusao">EXCLUIR</button>
                                </div>

                                <div class="d-flex flex-column align-items-end mt-2" style="min-width: 250px;">
                                    @if (editandoTotal)
                                    {
                                        <div class="d-flex flex-column align-items-end gap-2 mb-1 bg-black p-2 rounded border border-secondary w-100">
                                            <div class="d-flex align-items-center justify-content-between w-100">
                                                <small class="text-secondary fw-bold">SUBTOTAL:</small>
                                                <span class="text-white">R$ @sel.Items.Sum(i => i.Price).ToString("N2")</span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between w-100">
                                                <small class="text-danger fw-bold">DESCONTO:</small>
                                                <input type="number" step="0.01" class="form-control form-control-sm bg-dark text-white border-secondary text-end w-50" @bind="novoDesconto" @bind:after="AtualizarNovoTotal" />
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between w-100 border-top border-secondary pt-1 mt-1">
                                                <small class="text-success fw-bold">NOVO TOTAL:</small>
                                                <input type="number" step="0.01" class="form-control form-control-sm bg-dark text-white border-secondary text-end w-50" @bind="novoTotal" @bind:after="AtualizarNovoDesconto" />
                                            </div>
                                            <div class="d-flex justify-content-end gap-2 w-100 mt-2">
                                                <button class="btn btn-sm btn-success flex-grow-1 fw-bold" @onclick="SalvarTotal"><i class="bi bi-check-lg me-1"></i>Salvar Total</button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => editandoTotal = false">Cancelar</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        var subTotalExibicao = sel.Items.Sum(i => i.Price);
                                        var descontoExibicao = subTotalExibicao - sel.TotalAmount;
                                        <div class="text-end" style="cursor: pointer;" @onclick="IniciarEdicaoTotal" title="Editar Total / Aplicar Desconto">
                                            @if (descontoExibicao > 0)
                                            {
                                                <h5 class="text-white-50 mb-1">
                                                    <small class="text-secondary fw-bold me-1 fs-6">TOTAL:</small> R$ @subTotalExibicao.ToString("N2")
                                                </h5>
                                                <h5 class="text-success fw-bold mb-1">
                                                    <small class="text-secondary fw-bold me-1 fs-6">VALOR COM DESCONTO:</small> R$ @sel.TotalAmount.ToString("N2") <i class="bi bi-pencil fs-6 text-secondary ms-1"></i>
                                                </h5>
                                            }
                                            else
                                            {
                                                <h5 class="text-success fw-bold mb-1">
                                                    <small class="text-secondary fw-bold me-1 fs-6">TOTAL:</small> R$ @sel.TotalAmount.ToString("N2") <i class="bi bi-pencil fs-6 text-secondary ms-1"></i>
                                                </h5>
                                            }
                                        </div>
                                    }

                                    @if (editandoPagamento)
                                    {
                                        <div class="d-flex flex-column align-items-end gap-2 mb-1 p-2 border border-secondary rounded bg-black w-100">
                                            <span class="text-info small fw-bold mb-1"><i class="bi bi-cash-stack me-1"></i> Formas de Pagamento</span>

                                            @foreach (var p in listaPagamentosEmEdicao)
                                            {
                                                <div class="d-flex align-items-center gap-1 w-100">
                                                    <select class="form-select form-select-sm bg-dark text-white border-secondary w-50" @bind="p.PaymentMethod">
                                                        <option value="">Selecione...</option>
                                                        <option value="Dinheiro">Dinheiro</option>
                                                        <option value="PIX">PIX</option>
                                                        <option value="Crédito">Crédito</option>
                                                        <option value="Débito">Débito</option>
                                                    </select>
                                                    <input type="number" step="0.01" class="form-control form-control-sm bg-dark text-white border-secondary text-end w-50" @bind="p.Amount" placeholder="0.00" />
                                                    <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemoverMetodoPagamentoLista(p)" title="Remover forma de pagamento"><i class="bi bi-trash"></i></button>
                                                </div>
                                            }

                                            <button class="btn btn-sm btn-outline-info w-100 py-1 mt-1 mb-2" style="font-size: 0.7rem;" @onclick="AdicionarMetodoPagamentoLista">
                                                <i class="bi bi-plus-lg me-1"></i>Adicionar outra forma
                                            </button>

                                            <div class="d-flex align-items-center gap-2 w-100 justify-content-between border-top border-secondary pt-2" title="Data prevista para pagamento do restante">
                                                <small class="text-danger fw-bold">PAGARÁ O RESTO EM:</small>
                                                <input type="date" class="form-control form-control-sm bg-dark text-white border-secondary w-50" @bind="novaDataPromessa" />
                                            </div>

                                            <div class="d-flex w-100 gap-2 mt-2">
                                                <button class="btn btn-sm btn-info flex-grow-1 fw-bold" @onclick="SalvarPagamento"><i class="bi bi-check-lg text-dark me-1"></i>Salvar</button>
                                                <button class="btn btn-sm btn-success fw-bold" title="Gerar QR Code PIX" @onclick="() => GerarCobrancaPix(sel.RemainingAmount)"><i class="bi bi-qr-code"></i> PIX</button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicaoPagamento">Cancelar</button>
                                            </div>
                                            
                                            @if (mostrarPix)
                                            {
                                                <div class="mt-2 p-3 bg-white rounded text-center w-100 shadow">
                                                    <h6 class="text-dark fw-bold mb-2">QR Code PIX (R$ @valorPixGerado.ToString("N2"))</h6>
                                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@Uri.EscapeDataString(pixCopiaCola)" alt="QR Code PIX" class="mb-2 border border-secondary p-1" />
                                                    <input type="text" class="form-control form-control-sm text-center mb-2" style="font-size: 0.7rem;" value="@pixCopiaCola" readonly />
                                                    <div class="d-flex flex-wrap gap-1 justify-content-center">
                                                        <button class="btn btn-sm btn-outline-dark" @onclick="CopiarPix"><i class="bi bi-clipboard me-1"></i>Copiar</button>
                                                        <button class="btn btn-sm btn-success" @onclick="EnviarPixMeuCelular" title="Enviar para meu WhatsApp"><i class="bi bi-phone"></i> Meu Celular</button>
                                                        @if (!string.IsNullOrEmpty(sel.Vehicle?.CustomerPhone))
                                                        {
                                                            <button class="btn btn-sm btn-outline-success" @onclick="EnviarPixCliente" title="Enviar para o WhatsApp do cliente"><i class="bi bi-whatsapp"></i> Cliente</button>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-end" style="cursor: pointer;" @onclick="IniciarEdicaoPagamento" title="Clique para registrar pagamento">
                                            <h5 class="text-info fw-bold mb-0">
                                                <small class="text-secondary fw-bold me-1 fs-6">PAGO:</small> R$ @sel.AmountPaid.ToString("N2")
                                                <i class="bi bi-pencil fs-6 text-secondary ms-1"></i>
                                            </h5>
                                            @if (sel.Payments != null && sel.Payments.Any())
                                            {
                                                <div class="d-flex flex-wrap justify-content-end gap-1 mt-1">
                                                    @foreach (var p in sel.Payments)
                                                    {
                                                        <span class="badge bg-dark border border-secondary text-white-50" style="font-size: 0.65rem;">@p.PaymentMethod: @p.Amount.ToString("C")</span>
                                                    }
                                                </div>
                                            }
                                            else if (!string.IsNullOrEmpty(sel.PaymentMethod))
                                            {
                                                <span class="badge bg-dark border border-secondary text-white-50" style="font-size: 0.65rem;">@sel.PaymentMethod</span>
                                            }
                                        </div>
                                    }

                                    <div class="text-end w-100">
                                        <h5 class="@(sel.RemainingAmount > 0 ? "text-warning" : "text-muted") fw-bold mb-0 mt-2 pt-2 border-top border-secondary d-inline-block">
                                            <small class="text-secondary fw-bold me-1 fs-6">FALTA:</small> R$ @sel.RemainingAmount.ToString("N2")
                                        </h5>

                                        @if (sel.OverpaidAmount > 0)
                                        {
                                            <br />
                                            <h6 class="text-success fw-bold mb-0 mt-1 d-inline-block">
                                                <small class="text-secondary fw-bold me-1">EXTRA CAIXA:</small> R$ @sel.OverpaidAmount.ToString("N2")
                                            </h6>
                                        }

                                        @if (sel.RemainingAmount > 0 && sel.PromisedPaymentDate.HasValue && !editandoPagamento)
                                        {
                                            var isAtrasado = sel.PromisedPaymentDate.Value.Date < DateTime.Today;
                                            <div class="small fw-bold mt-1 @(isAtrasado ? "text-danger" : "text-info")">
                                                <i class="bi bi-calendar-event me-1"></i> Previsão: @sel.PromisedPaymentDate.Value.ToString("dd/MM/yyyy")
                                                @if (isAtrasado)
                                                {
                                                    <span class="ms-1">(Atrasado)</span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="mt-3 w-100 text-end no-print">
                                        <label class="btn btn-sm btn-outline-secondary fw-bold mb-2" style="cursor: pointer;">
                                            <i class="bi bi-paperclip me-1"></i> Anexar Arquivos
                                            <InputFile OnChange="CarregarComprovantes" multiple style="display: none;" />
                                        </label>

                                        @if (isUploading)
                                        {
                                            <div class="text-warning small mb-2"><i class="spinner-border spinner-border-sm me-1"></i> Enviando anexo(s)...</div>
                                        }

                                        @if (sel.Attachments != null && sel.Attachments.Any())
                                        {
                                            <div class="d-flex flex-column align-items-end gap-1 mt-1">
                                                @foreach (var anexo in sel.Attachments)
                                                {
                                                    <div class="d-flex align-items-center bg-black border border-secondary rounded px-2 py-1">
                                                        <a href="@(anexo.Base64Content.StartsWith("/uploads") ? $"{ApiUrl}{anexo.Base64Content}" : anexo.Base64Content)" 
                                                           target="_blank" 
                                                           class="text-info text-decoration-none small me-3" 
                                                           title="Clique para abrir">
                                                            <i class="bi @(anexo.FileType.Contains("pdf") ? "bi-file-pdf-fill text-danger" : (anexo.FileType.Contains("image") ? "bi-file-image-fill text-success" : "bi-file-earmark-fill")) me-1"></i>
                                                            @(anexo.FileName.Length > 20 ? anexo.FileName.Substring(0, 17) + "..." : anexo.FileName)
                                                        </a>
                                                        <button class="btn btn-sm text-danger p-0 m-0" @onclick="() => RemoverComprovante(anexo.Id)" title="Apagar este arquivo">
                                                            <i class="bi bi-x-circle-fill"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="p-3 rounded-3 mb-4" style="background-color: #0a0a0a; border: 1px solid #333;">
                            <ul class="nav nav-pills mb-3 gap-2">
                                <li><button class="btn btn-sm @(tipoItem == "peca" ? "btn-warning" : "btn-outline-light")" @onclick='() => tipoItem = "peca"'>PEÇA ESTOQUE</button></li>
                                <li><button class="btn btn-sm @(tipoItem == "avulso" ? "btn-warning" : "btn-outline-light")" @onclick='() => tipoItem = "avulso"'>ITEM AVULSO</button></li>
                                <li><button class="btn btn-sm @(tipoItem == "servico" ? "btn-warning" : "btn-outline-light")" @onclick='() => tipoItem = "servico"'>MÃO DE OBRA</button></li>
                            </ul>
                            <div class="row g-2 align-items-end mb-4">
                                @if (tipoItem == "peca")
                                {
                                    <div class="col-md-4">
                                        <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary mb-1" placeholder="🔍 Buscar por código ou nome..." value="@filtroProduto" @oninput="OnFiltroProdutoChanged" />
                                        <select class="form-select bg-dark text-white border-secondary" @bind="novoItem.ProductId">
                                            <option value="0">Selecionar Peça...</option>
                                            @if (produtos != null)
                                            {
                                                var filtrados = produtos.Where(p => string.IsNullOrEmpty(filtroProduto) || p.name.Contains(filtroProduto, StringComparison.OrdinalIgnoreCase) || p.code.Contains(filtroProduto, StringComparison.OrdinalIgnoreCase));
                                                foreach (var p in filtrados)
                                                {
                                                    <option value="@p.id">[@p.code] @p.name (R$ @p.salePrice)</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <input type="number" class="form-control bg-dark text-white border-secondary" @bind="novoItem.Quantity" placeholder="Quantidade" min="1" title="Quantidade" />
                                    </div>
                                    <div class="col-md-2">
                                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novoItem.Price" placeholder="Valor Unitário (R$)" title="Valor Unitário (Se deixar em branco, usará o valor do estoque.)" />
                                    </div>
                                    <div class="col-md-2">
                                        <input type="text" class="form-control bg-dark text-white border-secondary" @bind="novoItem.WarrantyPeriod" placeholder="Garantia" title="Garantia" />
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-warning w-100 fw-bold" @onclick="AdicionarItem">ADD PEÇA</button>
                                    </div>
                                }
                                else if (tipoItem == "avulso")
                                {
                                    <div class="col-md-4">
                                        <input type="text" class="form-control bg-dark text-white border-secondary" @bind="novoItemAvulso.Description" placeholder="Descrição do Item" title="Descrição do Item" />
                                    </div>
                                    <div class="col-md-2">
                                        <input type="number" class="form-control bg-dark text-white border-secondary" @bind="novoItemAvulso.Quantity" placeholder="Quantidade" min="1" title="Quantidade" />
                                    </div>
                                    <div class="col-md-2">
                                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novoItemAvulso.Price" placeholder="Valor Unitário (R$)" title="Valor Unitário (R$)" />
                                    </div>
                                    <div class="col-md-2">
                                        <input type="text" class="form-control bg-dark text-white border-secondary" @bind="novoItemAvulso.WarrantyPeriod" placeholder="Garantia" title="Garantia" />
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-warning w-100 fw-bold" @onclick="AdicionarItemAvulso">ADD AVULSO</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="col-md-4">
                                        <select class="form-select bg-dark text-white border-secondary" @onchange="OnServiceSelected" title="Serviço do Catálogo">
                                            <option value="0">Selecionar no catálogo...</option>
                                            @if (catalogoServicos != null)
                                            {
                                                @foreach (var s in catalogoServicos)
                                                {
                                                    <option value="@s.Id">@s.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <input class="form-control bg-dark text-white border-secondary" @bind="novoServico.Description" placeholder="Descrição na O.S." title="Descrição na O.S." />
                                    </div>
                                    <div class="col-md-3">
                                        <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novoServico.Price" placeholder="Valor (R$)" title="Valor (R$)" />
                                    </div>
                                    <div class="col-md-12 mt-2">
                                        <button class="btn btn-warning w-100 fw-bold" @onclick="AdicionarServico">ADICIONAR MÃO DE OBRA</button>
                                    </div>
                                }
                            </div>
                            <div class="mt-4 pt-3 border-top border-secondary">
                                @if (sel.Status != "Completed")
                                {
                                    <input type="datetime-local" class="form-control bg-dark text-white border-secondary w-50 d-inline-block" @bind="dataEntregaManual" />
                                    <button class="btn btn-success fw-bold" @onclick="FinalizarOS">FINALIZAR E ENTREGAR</button>
                                }
                                else
                                {
                                    <div class="alert alert-warning mb-0 py-2 px-3 d-inline-block w-100 text-center">
                                        <i class="bi bi-unlock-fill me-2"></i>O.S. Finalizada (Modo de Edição Aberto)
                                    </div>
                                }
                            </div>
                        </div>

                        <style>
                            .print-overlay { display: none; }
                            @@media print {
                                .no-print, .container-fluid, .sidebar, .top-row, nav { display: none !important; }
                                .print-overlay { display: block !important; position: relative !important; width: 100% !important; margin: 0 !important; padding: 0 !important; background: white !important; }
                                body { background: white !important; }
                            }
                            .table-fixed { table-layout: fixed; width: 100%; }
                            .table-fixed td, .table-fixed th { white-space: normal; word-wrap: break-word; vertical-align: middle; }
                            .text-nowrap-custom { white-space: nowrap !important; }
                            .badge-service { font-size: 0.6rem; background-color: #007bff; padding: 2px 6px; border-radius: 4px; }
                        </style>

                        <table class="table table-dark table-hover align-middle table-fixed">
                            <thead>
                                <tr class="text-secondary" style="border-bottom: 2px solid #333;">
                                    <th style="width: 10%;">Cód</th>
                                    <th style="width: 43%;">Descrição do Item / Serviço</th>
                                    <th class="text-center" style="width: 10%;">Qtd</th>
                                    <th class="text-end" style="width: 15%;">V. Unitário</th>
                                    <th class="text-end" style="width: 15%;">V. Total</th>
                                    <th style="width: 7%;" class="text-center"></th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (sel.Items != null)
                                {
                                    @foreach (var item in sel.Items)
                                    {
                                        bool existeNoCatalogo = catalogoServicos?.Any(c => string.Equals(c.Name, item.Description, StringComparison.OrdinalIgnoreCase)) == true;
                                        bool isServico = item.ItemType == "Service" || (item.ProductId == null && item.MechanicId != null) || (item.ProductId == null && item.Mechanic != null) || (item.ProductId == null && existeNoCatalogo);
                                        bool isAvulso = !isServico && item.ProductId == null;

                                        <tr>
                                            <td class="text-warning small fw-bold">
                                                @if (isServico) { <span>M.O.</span> }
                                                else if (isAvulso) { <span>AVULSO</span> }
                                                else { @item.ProductCodeDisplay }
                                            </td>

                                            <td>
                                                <span class="text-white fw-bold">@item.ProductDescriptionDisplay</span>
                                                @if (isServico) { <span class="badge-service ms-1">SERVIÇO</span> }
                                                else if (isAvulso) { <span class="badge bg-secondary text-light ms-1" style="font-size: 0.6rem;">AVULSO</span> }

                                                @if (!string.IsNullOrEmpty(item.WarrantyPeriod))
                                                {
                                                    <br />
                                                    <small style="color: #00ffff !important; font-weight: bold !important; font-size: 0.85rem !important; text-shadow: 1px 1px 2px rgba(0,0,0,0.5);">
                                                        <i class="bi bi-shield-check me-1"></i>GARANTIA: @item.WarrantyPeriod
                                                    </small>
                                                }
                                            </td>

                                            <td class="text-center text-nowrap-custom">
                                                @if (isServico) { <span class="text-muted">-</span> }
                                                else { <span class="badge bg-secondary">@item.Quantity</span> }
                                            </td>

                                            <td class="text-end text-nowrap-custom text-white-50 small">
                                                @if (!isServico) { @($"R$ {(item.Price / (item.Quantity > 0 ? item.Quantity : 1)):N2}") }
                                                else { <span class="text-muted">-</span> }
                                            </td>

                                            <td class="text-end text-nowrap-custom">
                                                <span class="text-success fw-bold">R$ @item.Price.ToString("N2")</span>
                                            </td>

                                            <td class="text-center text-nowrap-custom">
                                                <button class="btn btn-sm btn-link text-warning p-0" @onclick="() => AbrirEdicaoItem(item)" title="Editar ou Excluir item">
                                                    <i class="bi bi-pencil-fill"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<ImpressaoOS Os="sel" />

@if (osParaRelatorio != null)
{
    <div id="print-saidas" class="d-none d-print-block" style="width: 210mm; background: white; color: black; padding: 15mm; font-family: Arial;">
        <div style="text-align: center; border-bottom: 2px solid black; margin-bottom: 20px;">
            <h2 style="margin: 0;"> FREITAS AUTOCENTER</h2>
            <h4 style="margin: 5px 0;">COMPROVANTE DE SAÍDA DE MATERIAIS</h4>
            <p style="font-size: 10pt;">Referente à OS: #@osParaRelatorio.Id | Cliente: @osParaRelatorio.Vehicle?.CustomerName</p>
        </div>

        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #eee; border: 1px solid black;">
                    <th style="padding: 10px; text-align: left;">Peça / Insumo</th>
                    <th style="padding: 10px; text-align: center;">Qtd</th>
                    <th style="padding: 10px; text-align: right;">Vlr. Unitário</th>
                    <th style="padding: 10px; text-align: right;">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in osParaRelatorio.Items.Where(i => i.ItemType != "Service"))
                {
                    <tr style="border-bottom: 1px solid #ccc;">
                        <td style="padding: 10px;">
                            <strong>@item.Description</strong>
                            <br /><small>@(item.ProductId == null ? "Item Avulso" : "Item de Estoque")</small>
                        </td>
                        <td style="padding: 10px; text-align: center;">@item.Quantity</td>
                        <td style="padding: 10px; text-align: right;">R$ @item.Price.ToString("N2")</td>
                        <td style="padding: 10px; text-align: right; font-weight: bold;">R$ @((item.Price * item.Quantity).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" style="text-align: right; padding: 20px; font-weight: bold; font-size: 12pt;">TOTAL DE MATERIAIS:</td>
                    <td style="text-align: right; padding: 20px; font-weight: bold; font-size: 12pt;">
                        R$ @osParaRelatorio.Items.Where(i => i.ItemType != "Service").Sum(i => i.Price * i.Quantity).ToString("N2")
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@code {
    private string chavePix = "";
    private string nomeRecebedor = "";
    private string cidadeRecebedor = "";
    private string meuNumeroWhatsApp = "";

    bool mostrarPix = false;
    string pixCopiaCola = "";
    decimal valorPixGerado = 0;

    private System.Timers.Timer? _debounceTimer;

    private ServiceOrderDTO? osParaRelatorio;
    private bool _iniciarImpressao = false;
    private string ApiUrl = "";

    private async Task GerarRelatorioSaida(ServiceOrderDTO os)
    {
        osParaRelatorio = os;
        _iniciarImpressao = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_iniciarImpressao)
        {
            _iniciarImpressao = false;
            await JS.InvokeVoidAsync("window.print");
            osParaRelatorio = null;
            StateHasChanged();
        }
    }

    private void GerarRelatorioGeralSaidas() { Nav.NavigateTo("relatorio-saidas"); }

    List<ProductListDTO>? produtos;
    List<EmployeeListDTO>? mecanicos;
    List<LaborServiceDTO>? catalogoServicos;

    List<ServiceOrderDTO>? osAtivas;
    List<ServiceOrderDTO>? osFinalizadas;
    List<ServiceOrderDTO>? alertasInadimplencia;
    bool carregandoLista = false;

    bool mostrarFinalizadas = false;
    List<ServiceOrderDTO>? listaExibicao => mostrarFinalizadas ? osFinalizadas : osAtivas;

    ServiceOrderDTO? sel;
    CreateOsInput novaOsRequest = new();
    AddItemInput novoItem = new();
    AddCustomItemInput novoItemAvulso = new();
    AddLaborInput novoServico = new();
    DateTime dataEntregaManual = DateTime.Now;
    string tipoItem = "peca";
    string filtroProduto = "";

    bool mostrarToast = false;
    string toastMensagem = "";
    string toastTipo = "sucesso";
    bool mostrarModalExclusao = false;
    bool editandoCabecalho = false;
    UpdateVehicleDTO editRequest = new();
    
    bool editandoTotal = false;
    decimal novoTotal = 0;
    decimal novoDesconto = 0;
    
    bool editandoPagamento = false;
    List<PaymentSplitDTO> listaPagamentosEmEdicao = new();
    DateTime? novaDataPromessa = null;

    bool isUploading = false;
    bool mostrarModalEdicaoItem = false;
    ServiceItemDTO? itemParaEditar;
    UpdateServiceItemDTO itemEditRequest = new();
    bool imprimindoRelatorioGeral = false;

    protected override async Task OnInitializedAsync() 
    { 
        ApiUrl = Config["ApiBaseUrl"] ?? "https://localhost:7082";
        chavePix = Config["PixConfig:Chave"] ?? "";
        nomeRecebedor = Config["PixConfig:NomeRecebedor"] ?? "";
        cidadeRecebedor = Config["PixConfig:CidadeRecebedor"] ?? "";
        meuNumeroWhatsApp = Config["WhatsAppConfig:Numero"] ?? "";
        
        await CarregarDadosIniciais(); 
    }

    private void OnFiltroProdutoChanged(ChangeEventArgs e)
    {
        filtroProduto = e.Value?.ToString() ?? "";
        
        if (_debounceTimer != null)
        {
            _debounceTimer.Stop();
            _debounceTimer.Dispose();
        }
        
        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (sender, args) =>
        {
            _debounceTimer.Dispose();
            _debounceTimer = null;
            await InvokeAsync(StateHasChanged);
        };
        _debounceTimer.Start();
    }

    async Task CarregarDadosIniciais()
    {
        try {
            await CarregarProdutos();
            await CarregarMecanicos();
            await CarregarCatalogoServicos();
            await CarregarOSAtivas();
            await CarregarAlertas();
        }
        catch (Exception ex) { 
            Console.WriteLine(ex.Message);
            MostrarErro("Falha crítica ao conectar com o servidor."); 
        }
    }

    async Task CarregarOSAtivas() { try { osAtivas = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/active"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao carregar O.S ativas."); } }
    async Task CarregarOSFinalizadas() { try { osFinalizadas = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/completed?take=50"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao carregar O.S finalizadas."); } }
    async Task CarregarAlertas() { try { alertasInadimplencia = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/alerts"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao carregar alertas."); } }

    async Task AlternarAba(bool paraFinalizadas)
    {
        mostrarFinalizadas = paraFinalizadas;
        if (paraFinalizadas && osFinalizadas == null)
        {
            carregandoLista = true;
            await CarregarOSFinalizadas();
            carregandoLista = false;
        }
    }

    async Task AtualizarTela()
    {
        await CarregarOSAtivas();
        if (mostrarFinalizadas) await CarregarOSFinalizadas();
        await CarregarAlertas();
        
        if (sel != null) {
            var osAtualizada = osAtivas?.FirstOrDefault(o => o.Id == sel.Id) ?? osFinalizadas?.FirstOrDefault(o => o.Id == sel.Id);
            if (osAtualizada != null) { osAtualizada.Attachments = sel.Attachments; sel = osAtualizada; }
        }
    }

    async Task CarregarCatalogoServicos() { try { catalogoServicos = await Http.GetFromJsonAsync<List<LaborServiceDTO>>($"{ApiUrl}/api/laborservices"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao carregar catálogo."); } }
    async Task CarregarProdutos() { try { produtos = await Http.GetFromJsonAsync<List<ProductListDTO>>($"{ApiUrl}/api/products"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao carregar produtos."); } }
    async Task CarregarMecanicos() { try { mecanicos = await Http.GetFromJsonAsync<List<EmployeeListDTO>>($"{ApiUrl}/api/employees"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao carregar mecânicos."); } }

    private void OnServiceSelected(ChangeEventArgs e)
    {
        int idSelected = int.Parse(e.Value?.ToString() ?? "0");
        var servico = catalogoServicos?.FirstOrDefault(s => s.Id == idSelected);
        if (servico != null) { novoServico.Description = servico.Name; novoServico.Price = servico.DefaultPrice; }
    }

    async void MostrarSucesso(string msg) { toastMensagem = msg; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged(); await Task.Delay(3000); mostrarToast = false; StateHasChanged(); }
    async void MostrarErro(string msg) { toastMensagem = msg; toastTipo = "erro"; mostrarToast = true; StateHasChanged(); await Task.Delay(5000); mostrarToast = false; StateHasChanged(); }

    async Task Selecionar(ServiceOrderDTO os)
    {
        sel = os;
        mostrarPix = false;
        dataEntregaManual = DateTime.Now; editandoCabecalho = false; editandoTotal = false; editandoPagamento = false;
        try { sel.Attachments = await Http.GetFromJsonAsync<List<AttachmentDTO>>($"{ApiUrl}/api/serviceorders/{os.Id}/attachments") ?? new(); }
        catch (Exception ex) { Console.WriteLine(ex.Message); sel.Attachments = new(); }
        StateHasChanged();
    }
    
    async Task AbrirOsDoAlerta(int id)
    {
        AlternarAba(true);
        var osNoAlerta = alertasInadimplencia?.FirstOrDefault(o => o.Id == id);
        if (osNoAlerta != null) await Selecionar(osNoAlerta);
    }

    async Task ImprimirNota() { await JS.InvokeVoidAsync("print"); }
    void SolicitarExclusao() { if (sel != null) mostrarModalExclusao = true; }

    async Task ConfirmarExclusao()
    {
        if (sel == null) return;
        try {
            await Http.DeleteAsync($"{ApiUrl}/api/serviceorders/{sel.Id}");
            sel = null; mostrarModalExclusao = false; await AtualizarTela(); MostrarSucesso("O.S. movida para a lixeira.");
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); mostrarModalExclusao = false; MostrarErro("Erro ao excluir a O.S."); }
    }

    async Task AbrirOS()
    {
        if (string.IsNullOrEmpty(novaOsRequest.ClientName)) { MostrarErro("Nome do cliente é obrigatório."); return; }
        try {
            await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders", novaOsRequest);
            novaOsRequest = new(); await AtualizarTela(); MostrarSucesso("Ordem de Serviço aberta!");
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Falha ao abrir nova O.S."); }
    }

    async Task AdicionarItem()
    {
        if (novoItem.ProductId == 0) { MostrarErro("Selecione um produto."); return; }
        try {
            if (novoItem.Price > 0) novoItem.Price = novoItem.Price * (novoItem.Quantity > 0 ? novoItem.Quantity : 1);
            var response = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items", novoItem);
            if (!response.IsSuccessStatusCode) { MostrarErro("Erro ao adicionar item."); return; }
            await AtualizarTela(); novoItem = new(); filtroProduto = ""; MostrarSucesso("Peça adicionada.");
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro de conexão ao adicionar peça."); }
    }

    async Task AdicionarItemAvulso()
    {
        if (string.IsNullOrEmpty(novoItemAvulso.Description)) { MostrarErro("Descrição obrigatória."); return; }
        try {
            if (novoItemAvulso.Price > 0) novoItemAvulso.Price = novoItemAvulso.Price * (novoItemAvulso.Quantity > 0 ? novoItemAvulso.Quantity : 1);
            await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/custom-items", novoItemAvulso);
            await AtualizarTela(); novoItemAvulso = new(); MostrarSucesso("Produto avulso registrado.");
        } 
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao adicionar item avulso."); }
    }

    async Task AdicionarServico()
    {
        if (string.IsNullOrEmpty(novoServico.Description)) { MostrarErro("Descrição obrigatória."); return; }
        try {
            await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/labor", novoServico);
            await AtualizarTela(); novoServico = new(); MostrarSucesso("Mão de obra registrada.");
        } 
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao adicionar serviço."); }
    }

    async Task ApagarItemEmEdicao()
    {
        if (itemParaEditar == null || sel == null) return;
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Apagar '{itemParaEditar.Description}'?");
        if (!confirm) return;
        try {
            await Http.DeleteAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items/{itemParaEditar.Id}");
            await AtualizarTela(); MostrarSucesso("Item removido!"); FecharEdicaoItem();
        } 
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao apagar item."); }
    }

    async Task FinalizarOS()
    {
        try {
            await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/complete", new { CompletionDate = dataEntregaManual });
            await AlternarAba(true); 
            await AtualizarTela(); MostrarSucesso("O.S. finalizada!");
        } 
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao finalizar O.S."); }
    }

    async Task VoltarInteligente() { Nav.NavigateTo("/"); }
    void IniciarEdicao() { if (sel?.Vehicle == null) return; editRequest = new UpdateVehicleDTO { CustomerName = sel.Vehicle.CustomerName, VehicleModel = sel.Vehicle.Model, CustomerAddress = sel.Vehicle.CustomerAddress, CustomerPhone = sel.Vehicle.CustomerPhone }; editandoCabecalho = true; }
    void CancelarEdicao() { editandoCabecalho = false; }

    async Task SalvarEdicao() { if (sel == null) return; try { await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/vehicle", editRequest); editandoCabecalho = false; await AtualizarTela(); MostrarSucesso("Dados atualizados!"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao atualizar dados."); } }

    void IniciarEdicaoTotal() { if (sel == null) return; novoTotal = sel.TotalAmount; novoDesconto = sel.Items.Sum(i => i.Price) - sel.TotalAmount; if (novoDesconto < 0) novoDesconto = 0; editandoTotal = true; }
    void AtualizarNovoTotal() { if (sel != null) { novoTotal = sel.Items.Sum(i => i.Price) - novoDesconto; if (novoTotal < 0) novoTotal = 0; } }
    void AtualizarNovoDesconto() { if (sel != null) { novoDesconto = sel.Items.Sum(i => i.Price) - novoTotal; if (novoDesconto < 0) novoDesconto = 0; } }
    async Task SalvarTotal() { if (sel == null) return; try { await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/total", new UpdateTotalDTO { TotalAmount = novoTotal }); editandoTotal = false; await AtualizarTela(); MostrarSucesso("Total atualizado!"); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao atualizar total."); } }

    void IniciarEdicaoPagamento()
    {
        if (sel == null) return;
        listaPagamentosEmEdicao.Clear(); mostrarPix = false;
        if (sel.Payments != null && sel.Payments.Any()) { foreach (var p in sel.Payments) listaPagamentosEmEdicao.Add(new PaymentSplitDTO { PaymentMethod = p.PaymentMethod, Amount = p.Amount, PaymentDate = p.PaymentDate }); }
        else if (sel.AmountPaid > 0) listaPagamentosEmEdicao.Add(new PaymentSplitDTO { PaymentMethod = sel.PaymentMethod ?? "", Amount = sel.AmountPaid });
        else listaPagamentosEmEdicao.Add(new PaymentSplitDTO { PaymentMethod = "", Amount = 0 });
        novaDataPromessa = sel.PromisedPaymentDate; editandoPagamento = true;
    }

    void AdicionarMetodoPagamentoLista() { listaPagamentosEmEdicao.Add(new PaymentSplitDTO { PaymentMethod = "", Amount = 0 }); }
    void RemoverMetodoPagamentoLista(PaymentSplitDTO item) { listaPagamentosEmEdicao.Remove(item); }
    void CancelarEdicaoPagamento() { editandoPagamento = false; mostrarPix = false; }

    async Task SalvarPagamento()
    {
        if (sel == null) return;
        var pagamentosReais = listaPagamentosEmEdicao.Where(p => p.Amount > 0).ToList();
        decimal somaPagos = pagamentosReais.Sum(p => p.Amount);
        string metodoPrincipal = pagamentosReais.Count == 1 ? pagamentosReais[0].PaymentMethod : "Misto";
        try {
            var request = new UpdatePaymentDTO { AmountPaid = somaPagos, PaymentMethod = metodoPrincipal, PromisedPaymentDate = novaDataPromessa, Payments = pagamentosReais };
            await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/payment", request);
            editandoPagamento = false; await AtualizarTela(); MostrarSucesso("Pagamento salvo!");
        } 
        catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao salvar pagamento."); }
    }

    void GerarCobrancaPix(decimal valor)
    {
        if (valor <= 0) { MostrarErro("O valor a receber deve ser maior que zero."); return; }
        valorPixGerado = valor; pixCopiaCola = GerarPayloadPix(chavePix, nomeRecebedor, cidadeRecebedor, valor); mostrarPix = true;
    }

    string GerarPayloadPix(string chave, string nome, string cidade, decimal valor)
    {
        string GetValue(string id, string val) => $"{id}{val.Length.ToString("D2")}{val}";
        nome = nome.Length > 25 ? nome.Substring(0, 25) : nome; cidade = cidade.Length > 15 ? cidade.Substring(0, 15) : cidade;
        string payload = GetValue("00", "01") + GetValue("26", GetValue("00", "br.gov.bcb.pix") + GetValue("01", chave)) + GetValue("52", "0000") + GetValue("53", "986") + GetValue("54", valor.ToString("F2", CultureInfo.InvariantCulture)) + GetValue("58", "BR") + GetValue("59", nome) + GetValue("60", cidade) + GetValue("62", GetValue("05", "***"));
        return payload + "6304" + CalcularCRC16(payload + "6304");
    }

    string CalcularCRC16(string payload)
    {
        ushort polinomio = 0x1021; ushort res = 0xFFFF; byte[] data = System.Text.Encoding.UTF8.GetBytes(payload);
        foreach (byte b in data) { res ^= (ushort)(b << 8); for (int i = 0; i < 8; i++) { if ((res & 0x8000) != 0) res = (ushort)((res << 1) ^ polinomio); else res <<= 1; } } return res.ToString("X4");
    }

    async Task CopiarPix() { await JS.InvokeVoidAsync("navigator.clipboard.writeText", pixCopiaCola); MostrarSucesso("Código PIX copiado!"); }
    async Task EnviarPixMeuCelular() { string urlImagem = $"https://api.qrserver.com/v1/create-qr-code/?size=300x300&data={Uri.EscapeDataString(pixCopiaCola)}"; string texto = $"*PIX - FREITAS AUTOCENTER*\nO.S. #{sel?.Id}\nVeículo: {sel?.Vehicle?.Model}\nValor: *R$ {valorPixGerado:N2}*\n\n*QR Code:* {urlImagem}\n\n*Pix Copia e Cola:*\n{pixCopiaCola}"; string url = $"https://wa.me/{meuNumeroWhatsApp}?text={Uri.EscapeDataString(texto)}"; await JS.InvokeVoidAsync("open", url, "_blank"); }
    async Task EnviarPixCliente() { if (sel?.Vehicle == null || string.IsNullOrEmpty(sel.Vehicle.CustomerPhone)) return; string fone = sel.Vehicle.CustomerPhone.Replace("(", "").Replace(")", "").Replace("-", "").Replace(" ", ""); if (!fone.StartsWith("55")) fone = "55" + fone; string urlImagem = $"https://api.qrserver.com/v1/create-qr-code/?size=300x300&data={Uri.EscapeDataString(pixCopiaCola)}"; string texto = $"Olá {sel.Vehicle.CustomerName}, segue o PIX para pagamento da sua O.S. #{sel.Id} na Freitas Autocenter.\n\n*Valor:* R$ {valorPixGerado:N2}\n\n*QR Code:* {urlImagem}\n\n*Pix Copia e Cola:*\n{pixCopiaCola}"; string url = $"https://wa.me/{fone}?text={Uri.EscapeDataString(texto)}"; await JS.InvokeVoidAsync("open", url, "_blank"); }

    void AbrirEdicaoItem(ServiceItemDTO item) { itemParaEditar = item; decimal unitPrice = item.Price; if (item.ItemType != "Service" && item.Quantity > 1) { unitPrice = item.Price / item.Quantity; } itemEditRequest = new UpdateServiceItemDTO { Description = item.Description, Price = unitPrice, WarrantyPeriod = item.WarrantyPeriod, Quantity = item.Quantity > 0 ? item.Quantity : 1, ItemType = item.ItemType, MechanicId = item.MechanicId }; mostrarModalEdicaoItem = true; }
    void FecharEdicaoItem() { mostrarModalEdicaoItem = false; itemParaEditar = null; }

    async Task SalvarEdicaoItem() { if (sel == null || itemParaEditar == null) return; var requestParaSalvar = new UpdateServiceItemDTO { Description = itemEditRequest.Description, Price = itemEditRequest.Price, WarrantyPeriod = itemEditRequest.WarrantyPeriod, Quantity = itemEditRequest.Quantity, ItemType = itemEditRequest.ItemType, MechanicId = itemEditRequest.MechanicId }; if (requestParaSalvar.ItemType != "Service") { requestParaSalvar.Price = requestParaSalvar.Price * (requestParaSalvar.Quantity > 0 ? requestParaSalvar.Quantity : 1); } try { var response = await Http.PutAsJsonAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/items/{itemParaEditar.Id}", requestParaSalvar); if (response.IsSuccessStatusCode) { FecharEdicaoItem(); await AtualizarTela(); MostrarSucesso("Item atualizado!"); } } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao salvar edição do item."); } }

    async Task CarregarComprovantes(InputFileChangeEventArgs e) 
    { 
        if (sel == null) return; 
        var arquivos = e.GetMultipleFiles(10); 
        isUploading = true; 
        StateHasChanged(); 

        foreach (var file in arquivos) 
        { 
            try 
            { 
                using var content = new MultipartFormDataContent();
                
                var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024));
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "file", file.Name);

                var response = await Http.PostAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/attachments", content);
                
                if (!response.IsSuccessStatusCode)
                {
                    MostrarErro($"Erro ao salvar anexo {file.Name}");
                }
            } 
            catch (Exception ex) 
            { 
                Console.WriteLine($"Erro no anexo: {ex.Message}"); 
                MostrarErro("Erro ao enviar o arquivo para o servidor."); 
            } 
        } 
        
        isUploading = false; 
        
        try 
        { 
            sel.Attachments = await Http.GetFromJsonAsync<List<AttachmentDTO>>($"{ApiUrl}/api/serviceorders/{sel.Id}/attachments") ?? new(); 
        } 
        catch (Exception ex) 
        { 
            Console.WriteLine(ex.Message); 
        } 
        
        MostrarSucesso("Upload concluído!"); 
    }

    async Task RemoverComprovante(int attachmentId) { if (sel == null) return; try { await Http.DeleteAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/attachments/{attachmentId}"); sel.Attachments = await Http.GetFromJsonAsync<List<AttachmentDTO>>($"{ApiUrl}/api/serviceorders/{sel.Id}/attachments") ?? new(); StateHasChanged(); MostrarSucesso("Removido."); } catch (Exception ex) { Console.WriteLine(ex.Message); MostrarErro("Erro ao remover comprovante."); } }

