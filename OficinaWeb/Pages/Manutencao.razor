@page "/manutencao"
@inject HttpClient Http
@using System.Net.Http.Json

<h3>🔧 Oficina: Ordens de Serviço</h3>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-dark text-white">🚗 Chegada de Cliente</div>
            <div class="card-body">
                <label>Placa do Veículo</label>
                <input class="form-control mb-2" @bind="novaOS.vehicle.licensePlate" placeholder="ABC-1234" />

                <label>Modelo</label>
                <input class="form-control mb-2" @bind="novaOS.vehicle.model" placeholder="Ex: Civic 2020" />

                <label>Nome do Cliente</label>
                <input class="form-control mb-2" @bind="novaOS.vehicle.customerName" placeholder="Nome" />

                <button class="btn btn-primary w-100 mt-2" @onclick="AbrirOS">Abrir Ordem de Serviço</button>
            </div>
        </div>

        <div class="list-group">
            @if (listaOS != null)
            {
                <div class="list-group-item active">OS em Andamento</div>
                @foreach (var os in listaOS.Where(o => o.status != "Completed"))
                {
                    <button class="list-group-item list-group-item-action @(osSelecionada?.id == os.id ? "bg-light border-primary" : "")"
                            @onclick="() => SelecionarOS(os.id)">
                        <strong>@os.vehicle?.model</strong> (@os.vehicle?.licensePlate)<br />
                        <small>Entrada: @os.entryDate</small>
                    </button>
                }
            }
        </div>
    </div>

    <div class="col-md-8">
        @if (osSelecionada != null)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white d-flex justify-content-between">
                    <span>OS #@osSelecionada.id - @osSelecionada.vehicle?.customerName</span>
                    <span class="badge bg-light text-dark">Status: @osSelecionada.status</span>
                </div>
                <div class="card-body">

                    <div class="p-3 border rounded bg-light mb-3">
                        <h6>➕ Adicionar Serviço/Peça</h6>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <select class="form-select" @bind="novoItem.productId">
                                    <option value="">Selecione Peça (Opcional)</option>
                                    @if (produtos != null)
                                    {
                                        @foreach (var p in produtos)
                                        {
                                            <option value="@p.id">@p.name (Est: @p.stockQuantity)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <select class="form-select" @bind="novoItem.mechanicId">
                                    <option value="">Selecione Mecânico</option>
                                    @if (mecanicos != null)
                                    {
                                        @foreach (var m in mecanicos)
                                        {
                                            <option value="@m.id">@m.name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <input class="form-control" @bind="novoItem.description" placeholder="Descrição (Ex: Mão de Obra)" />
                            </div>
                            <div class="col-md-3">
                                <input type="number" class="form-control" @bind="novoItem.price" placeholder="Preço" />
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-success w-100" @onclick="AdicionarItem">Adicionar</button>
                            </div>
                        </div>
                    </div>

                    <table class="table table-sm">
                        <thead><tr><th>Item</th><th>Mecânico</th><th>Garantia Prevista</th><th>Valor</th></tr></thead>
                        <tbody>
                            @foreach (var item in osSelecionada.items)
                            {
                                <tr>
                                    <td>@item.description @(item.product != null ? $"(Peça: {item.product.name})" : "")</td>
                                    <td>@(item.mechanic != null ? item.mechanic.name : "--")</td>
                                    <td>90 Dias</td>
                                    <td>R$ @item.price</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                <td><strong>R$ @osSelecionada.items.Sum(i => i.price)</strong></td>
                            </tr>
                        </tfoot>
                    </table>

                    @if (osSelecionada.status != "Completed")
                    {
                        <div class="alert alert-warning mt-3">
                            <small>⚠️ Ao finalizar: O estoque será baixado e a garantia de 90 dias será gerada.</small>
                            <button class="btn btn-danger w-100 mt-2" @onclick="FinalizarServico">✅ Finalizar Serviço e Entregar Veículo</button>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info mt-5 text-center">
                ⬅️ Selecione ou abra uma Ordem de Serviço para começar.
            </div>
        }
    </div>
</div>

@code {
    private string ApiUrl = "https://localhost:7082";

    public class ServiceOrderDTO
    {
        public int id { get; set; }
        public VehicleDTO vehicle { get; set; } = new();
        public List<ServiceItemDTO> items { get; set; } = new();
        public string status { get; set; } = "";
        public DateTime entryDate { get; set; }
    }
    public class VehicleDTO
    {
        public string licensePlate { get; set; } = "";
        public string model { get; set; } = "";
        public string customerName { get; set; } = "";
    }
    public class ServiceItemDTO
    {
        public string description { get; set; } = "";
        public decimal price { get; set; }
        public int? productId { get; set; }
        public ProductDTO? product { get; set; }
        public int? mechanicId { get; set; }
        public MechanicDTO? mechanic { get; set; }
    }
    public class ProductDTO { public int id { get; set; } public string name { get; set; } = ""; public int stockQuantity { get; set; } }
    public class MechanicDTO { public int id { get; set; } public string name { get; set; } = ""; }

    private List<ProductDTO>? produtos;
    private List<MechanicDTO>? mecanicos;
    private List<ServiceOrderDTO>? listaOS;

    private ServiceOrderDTO novaOS = new ServiceOrderDTO();
    private ServiceOrderDTO? osSelecionada;
    private ServiceItemDTO novoItem = new ServiceItemDTO();

    protected override async Task OnInitializedAsync()
    {
        await CarregarTudo();
    }

    private async Task CarregarTudo()
    {
        try
        {
            listaOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders");
            produtos = await Http.GetFromJsonAsync<List<ProductDTO>>($"{ApiUrl}/api/products");
            mecanicos = await Http.GetFromJsonAsync<List<MechanicDTO>>($"{ApiUrl}/api/employees");
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task AbrirOS()
    {
        var response = await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders", novaOS);
        if (response.IsSuccessStatusCode)
        {
            novaOS = new ServiceOrderDTO();
            await CarregarTudo();
        }
    }

    private async Task SelecionarOS(int id)
    {
        osSelecionada = await Http.GetFromJsonAsync<ServiceOrderDTO>($"{ApiUrl}/api/serviceorders/{id}");
    }

    private async Task AdicionarItem()
    {
        if (osSelecionada == null) return;

        await Http.PostAsJsonAsync($"{ApiUrl}/api/serviceorders/{osSelecionada.id}/items", novoItem);
        novoItem = new ServiceItemDTO();
        await SelecionarOS(osSelecionada.id);
    }

    private async Task FinalizarServico()
    {
        if (osSelecionada == null) return;

        await Http.PutAsync($"{ApiUrl}/api/serviceorders/{osSelecionada.id}/finish", null);
        await SelecionarOS(osSelecionada.id);
        await CarregarTudo();
    }
}