@page "/rh"
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>RH - FJ Centro Automotivo</PageTitle>

<div class="container py-4">

    <div class="row align-items-center mb-5 position-relative">
        <div class="col-md-3 text-start">
            <a href="/" class="btn btn-outline-secondary border-0 text-white">
                <i class="bi bi-arrow-left me-2"></i>Voltar para o painel
            </a>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ff6600;">
                <i class="bi bi-people-fill me-2"></i>RH e Pagamentos
            </h2>
        </div>
        <div class="col-md-3"></div>
    </div>

    <div class="row g-4">
        <div class="col-md-5">

            <div class="card border-0 shadow-sm mb-4" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="mb-3 fw-bold" style="color: #ffeb3b;">Novo Funcionário</h5>
                    <div class="d-flex flex-column gap-3">
                        <input class="form-control bg-dark text-white border-secondary"
                               @bind="novo.Name" placeholder="Nome Completo" />
                        <input class="form-control bg-dark text-white border-secondary"
                               @bind="novo.Role" placeholder="Cargo (Ex: Mecânico)" />
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-secondary border-secondary">R$</span>
                            <input type="number" class="form-control bg-dark text-white border-secondary"
                                   @bind="novo.BaseSalary" placeholder="Salário Base" />
                        </div>
                        <button class="btn fw-bold w-100"
                                style="background-color: #ffeb3b; color: #000;"
                                @onclick="Contratar">
                            CONTRATAR <i class="bi bi-person-plus-fill ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-3" style="color: #ff6600;">Equipe Ativa</h5>
            <div class="list-group shadow-sm mb-5">
                @if (funcionarios != null)
                {
                    foreach (var f in funcionarios.Where(x => x.Active))
                    {
                        var isActive = sel?.Id == f.Id;
                        var bgClass = isActive ? "border-start border-4 border-warning" : "";
                        var bgStyle = isActive ? "background-color: #222;" : "background-color: #111;";

                        <div class="list-group-item list-group-item-action border-secondary text-white d-flex justify-content-between align-items-center @bgClass"
                             style="@bgStyle transition: 0.2s; cursor: pointer;"
                             @onclick="() => Sel(f)">
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold">@f.Name</h6>
                                <small class="text-white-50">@f.Role</small>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="badge bg-secondary text-dark fw-bold">R$ @f.BaseSalary.ToString("N2")</span>
                                <i class="bi bi-chevron-right text-secondary"></i>
                            </div>
                        </div>
                    }
                }
            </div>

            <h5 class="fw-bold mb-3" style="color: #ff6600;">Antigos Funcionários</h5>
            <div class="list-group shadow-sm opacity-75">
                @if (funcionarios != null)
                {
                    foreach (var f in funcionarios.Where(x => !x.Active))
                    {
                        var isActive = sel?.Id == f.Id;
                        var bgStyle = isActive ? "background-color: #222;" : "background-color: #0a0a0a;";

                        <div class="list-group-item list-group-item-action border-secondary text-white d-flex justify-content-between align-items-center"
                             style="@bgStyle cursor: pointer;"
                             @onclick="() => Sel(f)">
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold text-secondary text-decoration-line-through">@f.Name</h6>
                                <small class="text-muted">Desativado</small>
                            </div>
                            <i class="bi bi-archive text-secondary"></i>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-md-7">
            @if (sel != null)
            {
                <div class="card border-0 shadow-sm h-100" style="background-color: #111; border-top: 4px solid @(sel.Active ? "#ff6600" : "#666") !important;">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
                            <div>
                                <h3 class="fw-bold text-white mb-0">@sel.Name</h3>
                                <span class="@(sel.Active ? "text-warning" : "text-secondary")">@sel.Role @(sel.Active ? "" : "(Inativo)")</span>
                            </div>
                            @if (sel.Active)
                            {
                                <div class="text-end">
                                    <small class="text-white-50 d-block">Salário Base</small>
                                    <h4 class="text-success fw-bold mb-0">R$ @sel.BaseSalary.ToString("N2")</h4>
                                </div>
                            }
                        </div>

                        @if (sel.Active)
                        {
                            <div class="p-3 rounded-3 mb-4" style="background-color: #0a0a0a; border: 1px solid #333;">
                                <h6 class="text-white mb-3">Lançar Novo Pagamento</h6>
                                <div class="row g-2">
                                    <div class="col-md-8">
                                        <div class="input-group">
                                            <span class="input-group-text bg-dark text-secondary border-secondary">R$</span>
                                            <input type="number" class="form-control bg-dark text-white border-secondary"
                                                   @bind="pag.Amount" placeholder="Valor do Pagamento" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <button class="btn w-100 fw-bold"
                                                style="background-color: #ff6600; color: #fff;"
                                                @onclick="Lancar">
                                            LANÇAR <i class="bi bi-cash-stack ms-1"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }

                        <h6 class="fw-bold text-white mb-3">Histórico Financeiro</h6>
                        <div class="table-responsive mb-4">
                            <table class="table table-dark table-hover mb-0" style="background-color: #000;">
                                <thead style="border-bottom: 2px solid #ff6600;">
                                    <tr>
                                        <th style="color: #ff6600;">Data da Baixa</th>
                                        <th style="color: #ff6600;">Valor</th>
                                        <th style="color: #ff6600;">Status</th>
                                        <th style="color: #ff6600;" class="text-end">Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in sel.Payments.OrderByDescending(x => x.Id))
                                    {
                                        <tr>
                                            <td class="text-white">
                                                @(p.PaymentDate.HasValue? p.PaymentDate.Value.ToString("dd/MM/yyyy HH:mm") : "(Aguardando)")
                                            </td>
                                            <td class="text-white fw-bold">R$ @p.Amount.ToString("N2")</td>
                                            <td>
                                                <span class="badge @(p.IsPaid ? "bg-success" : "bg-warning text-dark")">
                                                    @(p.IsPaid ? "PAGO" : "PENDENTE")
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                @if (!p.IsPaid && sel.Active)
                                                {
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => Confirmar(p.Id)">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (sel.Active)
                        {
                            <hr class="border-secondary my-4">
                            <div class="text-center">
                                <button class="btn btn-outline-danger w-100 py-2 fw-bold"
                                        @onclick="() => ExcluirFuncionario(sel)">
                                    <i class="bi bi-trash-fill me-2"></i> DEMITIR / DESATIVAR FUNCIONÁRIO
                                </button>
                                <small class="text-muted mt-2 d-block">O histórico de pagamentos será preservado na área de antigos.</small>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted p-5 rounded-3"
                     style="border: 2px dashed #333;">
                    <i class="bi bi-person-bounding-box display-1 mb-3" style="color: #333;"></i>
                    <p>Selecione um funcionário na lista ao lado.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .form-control::placeholder {
        color: #b0b0b0 !important;
        opacity: 1;
    }

    .form-control:focus {
        background-color: #222 !important;
        color: #fff !important;
        border-color: #ffeb3b !important;
        box-shadow: 0 0 5px rgba(255, 235, 59, 0.5);
    }

    .table-dark {
        --bs-table-bg: #000;
        background-color: #000;
    }
</style>

@code {
    private string ApiUrl = "https://localhost:7082";

    public class Emp
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public bool Active { get; set; }
        public decimal BaseSalary { get; set; }
        public List<Pay> Payments { get; set; } = new();
    }

    public class Pay
    {
        public int Id { get; set; }
        public decimal Amount { get; set; }
        public bool IsPaid { get; set; }
        public DateTime? PaymentDate { get; set; }
    }

    public class NewEmpDTO { public string Name { get; set; } = ""; public string Role { get; set; } = ""; public decimal? BaseSalary { get; set; } }
    public class NewPayDTO { public decimal? Amount { get; set; } }

    List<Emp>? funcionarios;
    Emp? sel;
    NewEmpDTO novo = new();
    NewPayDTO pag = new();

    protected override async Task OnInitializedAsync() { await Load(); }

    async Task Load()
    {
        try
        {
            funcionarios = await Http.GetFromJsonAsync<List<Emp>>($"{ApiUrl}/api/employees");
            if (sel != null && funcionarios != null) sel = funcionarios.FirstOrDefault(f => f.Id == sel.Id);
        }
        catch { }
    }

    async Task Contratar()
    {
        var empToSend = new Emp { Name = novo.Name, Role = novo.Role, BaseSalary = novo.BaseSalary ?? 0, Active = true };
        await Http.PostAsJsonAsync($"{ApiUrl}/api/employees", empToSend);
        novo = new();
        await Load();
    }

    void Sel(Emp f) { sel = f; pag.Amount = f.BaseSalary; }

    async Task Lancar()
    {
        if (pag.Amount == null || pag.Amount == 0) return;
        var payToSend = new Pay { Amount = pag.Amount.Value };
        await Http.PostAsJsonAsync($"{ApiUrl}/api/employees/{sel.Id}/payments", payToSend);
        await Load();
    }

    async Task Confirmar(int id)
    {
        await Http.PutAsync($"{ApiUrl}/api/employees/payments/{id}/confirm", null);
        await Load();
    }

    async Task ExcluirFuncionario(Emp f)
    {
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja realmente desativar '{f.Name}'?\n\nEle será movido para a lista de antigos funcionários.");
        if (confirmado)
        {
            var res = await Http.DeleteAsync($"{ApiUrl}/api/employees/{f.Id}");
            if (res.IsSuccessStatusCode)
            {
                sel = null;
                await Load();
            }
        }
    }
}