@page "/lixeira"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Net.Http.Json
@using OficinaWeb.Models

<PageTitle>Lixeira - FREITAS AUTOCENTER</PageTitle>

<div class="toast-container position-fixed bottom-0 end-0 p-3 no-print" style="z-index: 1100;">
    @if (mostrarToast)
    {
        <div class="toast show align-items-center text-white @(toastTipo == "erro" ? "bg-danger" : "bg-success") border-0 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi @(toastTipo == "erro" ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                    @toastMensagem
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => mostrarToast = false"></button>
            </div>
        </div>
    }
</div>

@* MODAL DE CONFIRMAÇÃO DE EXCLUSÃO PERMANENTE *@
@if (mostrarModalConfirmacao)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.85); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-danger">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold text-danger"><i class="bi bi-exclamation-octagon-fill me-2"></i>Atenção: Exclusão Definitiva</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalConfirmacao = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="fs-5">Deseja apagar permanentemente a O.S. <strong>#@sel?.Id</strong>?</p>
                    <p class="text-secondary small">Esta ação não poderá ser desfeita e os dados serão removidos do banco.</p>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" @onclick="() => mostrarModalConfirmacao = false">Cancelar</button>
                    <button type="button" class="btn btn-danger fw-bold" @onclick="ConfirmarExclusaoPermanente">APAGAR PARA SEMPRE</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="container-fluid py-4 px-4">
    <div class="row align-items-center mb-5">
        <div class="col-md-3">
            <button class="btn btn-outline-secondary border-0 text-white" @onclick='() => Nav.NavigateTo("/manutencao")'>
                <i class="bi bi-arrow-left me-2"></i>Voltar para Oficina
            </button>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #dc3545;"><i class="bi bi-trash me-2"></i>Lixeira de O.S.</h2>
            <small class="text-info fw-bold">Limpeza automática após 30 dias</small>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="list-group shadow-sm" style="max-height: 75vh; overflow-y: auto;">
                @if (lixeiraOS != null && lixeiraOS.Any())
                {
                    foreach (var os in lixeiraOS)
                    {
                        var isActive = sel?.Id == os.Id;
                            <div class="list-group-item list-group-item-action border-secondary text-white mb-2 rounded-0"
                             style="@(isActive ? "background-color: #222; border-left: 4px solid #dc3545;" : "background-color: #111;")"
                             @onclick="() => Selecionar(os)">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">@(os.Vehicle?.CustomerName)</h6>
                                    <small class="text-warning d-block">@(os.Vehicle?.Model)</small>
                                    <small class="text-white-50 fw-bold" style="font-size: 0.8rem; background: #222; padding: 2px 5px; border-radius: 4px;">
                                        Excluído em: <span class="text-info">@os.DeletionDate?.ToString("dd/MM/yyyy")</span>
                                    </small>
                                </div>
                                <span class="badge bg-dark border border-secondary">#@os.Id</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-5 text-muted border border-secondary rounded bg-dark">
                        <i class="bi bi-trash3 fs-1 d-block mb-3"></i>
                        <p>Nenhuma Ordem de Serviço na lixeira.</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-8">
            @if (sel != null)
            {
                <div class="card border-0 shadow-sm h-100" style="background-color: #111; border-top: 4px solid #dc3545 !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-4 border-bottom border-secondary pb-3">
                            <div>
                                <h2 class="fw-bold text-white mb-0">@(sel.Vehicle?.Model)</h2>
                                <span class="text-warning">Cliente: @(sel.Vehicle?.CustomerName)</span>
                                <div class="text-danger small mt-2 fw-bold">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Remoção definitiva em: @(sel.DeletionDate?.AddDays(30).ToString("dd/MM/yyyy"))
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="d-flex gap-2 justify-content-end mb-3">
                                    <button class="btn btn-success fw-bold" @onclick="RestaurarOS">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> RESTAURAR
                                    </button>
                                    <button class="btn btn-outline-danger fw-bold" @onclick="() => mostrarModalConfirmacao = true">
                                        <i class="bi bi-x-circle me-1"></i> APAGAR DEFINITIVO
                                    </button>
                                </div>
                                <h5 class="text-white fw-bold mb-0">
                                    <small class="text-secondary fw-bold me-1 fs-6">TOTAL:</small> R$ @sel.TotalAmount.ToString("N2")
                                </h5>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle">
                                <thead>
                                    <tr class="text-secondary">
                                        <th>Tipo</th>
                                        <th>Descrição</th>
                                        <th class="text-center">Qtd</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in sel.Items)
                                    {
                                        <tr>
                                            <td class="text-warning small">@(item.ItemType == "Service" ? "M.O." : "PEÇA")</td>
                                            <td>@item.Description</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end text-success">R$ @item.Price.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="h-100 d-flex align-items-center justify-content-center border border-secondary rounded bg-black text-secondary">
                    <p><i class="bi bi-arrow-left-circle me-2"></i>Selecione uma O.S. para visualizar detalhes</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string ApiUrl = "https://localhost:7082";
    private List<ServiceOrderDTO>? lixeiraOS;
    private ServiceOrderDTO? sel;
    
    bool mostrarToast = false;
    string toastMensagem = "";
    string toastTipo = "sucesso";
    bool mostrarModalConfirmacao = false;

    protected override async Task OnInitializedAsync() => await CarregarLixeira();

    private async Task CarregarLixeira()
    {
        try { lixeiraOS = await Http.GetFromJsonAsync<List<ServiceOrderDTO>>($"{ApiUrl}/api/serviceorders/trash"); }
        catch { MostrarErro("Erro ao conectar com a lixeira."); }
    }

    private void Selecionar(ServiceOrderDTO os) => sel = os;

    private async Task RestaurarOS()
    {
        if (sel == null) return;
        var res = await Http.PutAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/restore", null);
        if (res.IsSuccessStatusCode) { MostrarSucesso("Ordem de Serviço restaurada!"); sel = null; await CarregarLixeira(); }
    }

    private async Task ConfirmarExclusaoPermanente()
    {
        if (sel == null) return;
        var res = await Http.DeleteAsync($"{ApiUrl}/api/serviceorders/{sel.Id}/permanent");
        if (res.IsSuccessStatusCode)
        {
            mostrarModalConfirmacao = false;
            MostrarSucesso("O.S. removida definitivamente.");
            sel = null;
            await CarregarLixeira();
        }
        else { MostrarErro("Erro ao processar exclusão."); }
    }

    private async void MostrarSucesso(string msg)
    {
        toastMensagem = msg; toastTipo = "sucesso"; mostrarToast = true; StateHasChanged();
        await Task.Delay(3000); mostrarToast = false; StateHasChanged();
    }

    private async void MostrarErro(string msg)
    {
        toastMensagem = msg; toastTipo = "erro"; mostrarToast = true; StateHasChanged();
        await Task.Delay(5000); mostrarToast = false; StateHasChanged();
    }
}