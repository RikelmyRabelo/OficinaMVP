@page "/venda-avulsa"
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json

<PageTitle>Venda Avulsa - FREITAS AUTOCENTER</PageTitle>

<div class="container py-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-3 text-start">
            <a href="/" class="btn btn-outline-secondary border-0 text-white">
                <i class="bi bi-arrow-left me-2"></i>Voltar
            </a>
        </div>
        <div class="col-md-6 text-center">
            <h2 class="fw-bold text-uppercase mb-0" style="color: #ffeb3b;">
                <i class="bi bi-cart-plus-fill me-2"></i>Venda Avulsa
            </h2>
        </div>
        <div class="col-md-3"></div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm" style="background-color: #111; border-top: 4px solid #ffeb3b !important;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-white">Registrar Nova Venda</h5>

                    <div class="mb-3">
                        <label class="form-label text-secondary">Produto / Serviço</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" @bind="novaVenda.Description" placeholder="Ex: Óleo de Motor, Lâmpada..." />
                    </div>

                    <div class="mb-3 row g-2">
                        <div class="col-5">
                            <label class="form-label text-secondary">Qtd (Opcional)</label>
                            <input type="number" class="form-control bg-dark text-white border-secondary" @bind="novaVenda.Quantity" min="1" />
                        </div>
                        <div class="col-7">
                            <label class="form-label text-secondary">Valor Total (R$)</label>
                            <input type="number" step="0.01" class="form-control bg-dark text-white border-secondary" @bind="novaVenda.Price" placeholder="0.00" />
                        </div>
                    </div>

                    <button class="btn w-100 fw-bold mt-2" style="background-color: #ffeb3b; color: #000;" @onclick="RegistrarVenda">
                        LANÇAR NO CAIXA <i class="bi bi-check2-circle ms-1"></i>
                    </button>

                    @if (!string.IsNullOrEmpty(erroMsg))
                    {
                        <div class="text-danger mt-2 small">@erroMsg</div>
                    }
                    @if (!string.IsNullOrEmpty(sucessoMsg))
                    {
                        <div class="text-success mt-2 small">@sucessoMsg</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm h-100" style="background-color: #111;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-white">Histórico de Vendas Avulsas</h5>

                    <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                        <table class="table table-dark table-hover align-middle">
                            <thead style="border-bottom: 2px solid #333;">
                                <tr>
                                    <th class="text-secondary">Data / Hora</th>
                                    <th class="text-secondary">Descrição</th>
                                    <th class="text-center text-secondary">Qtd</th>
                                    <th class="text-end text-secondary">Valor Total</th>
                                    <th style="width: 40px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (vendas != null)
                                {
                                    @foreach (var v in vendas)
                                    {
                                        <tr>
                                            <td class="text-muted small">@v.SaleDate.ToString("dd/MM/yy HH:mm")</td>
                                            <td class="text-white">@v.Description</td>
                                            <td class="text-center">@(v.Quantity ?? 1)</td>
                                            <td class="text-end text-success fw-bold">R$ @v.Price.ToString("N2")</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-link text-danger p-0" @onclick="() => ExcluirVenda(v.Id)" title="Excluir Lançamento">
                                                    <i class="bi bi-trash-fill"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="5" class="text-center text-muted">Carregando histórico...</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string ApiUrl = "https://localhost:7082";

    public class QuickSaleDTO
    {
        public int Id { get; set; }
        public string Description { get; set; } = "";
        public int? Quantity { get; set; }
        public decimal Price { get; set; }
        public DateTime SaleDate { get; set; }
    }

    List<QuickSaleDTO>? vendas;
    QuickSaleDTO novaVenda = new() { Quantity = 1 };

    string erroMsg = "";
    string sucessoMsg = "";

    protected override async Task OnInitializedAsync() => await CarregarVendas();

    async Task CarregarVendas()
    {
        try { vendas = await Http.GetFromJsonAsync<List<QuickSaleDTO>>($"{ApiUrl}/api/quicksales"); }
        catch { erroMsg = "Erro ao carregar histórico."; }
    }

    async Task RegistrarVenda()
    {
        erroMsg = ""; sucessoMsg = "";
        if (string.IsNullOrWhiteSpace(novaVenda.Description) || novaVenda.Price <= 0)
        {
            erroMsg = "Preencha a descrição e um valor válido."; return;
        }

        try
        {
            var res = await Http.PostAsJsonAsync($"{ApiUrl}/api/quicksales", novaVenda);
            if (res.IsSuccessStatusCode)
            {
                sucessoMsg = "Venda registrada com sucesso!";
                novaVenda = new() { Quantity = 1 };
                await CarregarVendas();
                await Task.Delay(3000); sucessoMsg = "";
            }
            else { erroMsg = "Erro ao registrar."; }
        }
        catch { erroMsg = "Erro de conexão."; }
    }

    async Task ExcluirVenda(int id)
    {
        try
        {
            await Http.DeleteAsync($"{ApiUrl}/api/quicksales/{id}");
            await CarregarVendas();
        }
        catch { }
    }
}